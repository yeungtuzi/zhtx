dbase (["notes":({(["author":"娜可露露","title":"sigh easts","time":924009514,"msg":"sigh eastssighee",]),(["author":"明月心","title":"走了","time":924189243,"msg":"eqqQ",]),(["author":"明月心","title":"走了","time":924189345,"msg":"faint ,临走了还不知道“使用内建列编辑器用 '~e'”怎么用。papaya wenll上个暑假接触纵横，在温柔的帮助下学会可做任务，在众多网友的关怀下幸福成长。thank all.每当我烦恼，不顺心时，玩玩mud都会让我开心，快乐。然而学习的滑坡使我现在不得不离开泥潭........",]),(["author":"明月心","title":"走啦","time":924190236,"msg":"?我决定把lgirl留华山的新手们做dummy name lgirl password 791212  希望能给newbie们带来一些帮助！",]),(["author":"娜可露露","title":"faint sutton","time":924772419,"msg":"【华山派】岳不群：苏乞儿临阵逃缩，丢尽我派脸面。",]),(["author":"黎明阳光","title":"嘿嘿","time":927380741,"msg":"faint 我又死了。hehe 是谁 easts? 还是sif? 别让我老死，当dummy也不能太面呀！xixi",]),(["author":"小紫衫","title":"skills","time":928487338,"msg":"",]),(["author":"圣者","title":"再游华山","time":930577072,"msg":"没有人了。",]),(["author":"黎明阳光","title":"我还想把sandman玩下去xixi","time":931446361,"msg":"虽然又老又面，可是我还是对华山有好感，我想把skills学完 hehe",]),(["author":"空恶","title":"..b","time":931571774,"msg":"谁说华山面，和我的***单挑，武当见鬼去吧。",]),(["author":"梨安","title":"梨安","time":932039801,"msg":"jake.我终于回来了.但却不知到怎样和你连络.快用一个新dummy吧.要不然我都不知你来了没有",]),(["author":"梨安","title":"梨安","time":932040066,"msg":"jake.我终于回来了.但却不知到怎样和你连络.快用一个新dummy吧.要不然我都不知你来了没有",]),(["author":"梨安","title":"jake","time":934807246,"msg":"hi, pairs, 我昨天回到了学校。回来后，很想知道现在的情况，也就是说考试如何？碰巧看到了你的留言，你可以mail to whjun@263.net.我有很多dummy的，可能你没有注意到，凡是与jake有关的id可能都是我的dummy.xixi! bye!",]),(["author":"小穷","title":"再游华山","time":935221840,"msg":"sigh 华山空无一人",]),(["author":"天剑","title":"不用华山的","time":935753304,"msg":"post 不用华山的.l",]),(["author":"张惠妹","title":"xixi","time":945173489,"msg":"s",]),(["author":"月华","title":"现在的华山真是人丁稀少啊！！！","time":945232499,"msg":"sighcryaddoil huashan",]),(["author":"超导","title":"jianghe_river@263.net","time":948629350,"msg":"welcome",]),(["author":"苇子","title":"还是华山好","time":953801813,"msg":"e虽然很面可我对她情有独钟",]),(["author":"行李包","title":"just post","time":955931178,"msg":"【 藏  尼 】大招寺第二十一代弟子「趟子手」行李包(Bbag);; 你是一位九十四岁的女性人类，庚寅