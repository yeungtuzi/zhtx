dbase (["capacity":1000,"no_get":1,"notes":({(["time":1027394093,"title":"abjut news center","msg":"","author":"小批萨",]),(["time":1027394705,"title":"b","msg":"","author":"小批萨",]),(["time":1027424101,"title":"gaibang dagou-bang add a pfm","msg":"perform ban 拌字绝","author":"小批萨",]),(["time":1027588912,"title":"about 离线练功","msg":"离线练功的指令是schemeu can help scheme to get help","author":"小批萨",]),(["time":1027602549,"title":"scheme help","msg":"help offline 可以帮助你学习如何使用scheme不是很难偶addoil","author":"小批萨",]),(["time":1027649484,"title":"sorry to u","msg":"现在cun = deposit qu = withdraw cha = balance duihuan = convertdazuo = exercise fangqi = abandon lian =practice bai = apprentice","author":"小批萨",]),(["time":1027913662,"title":"about chaoting task","msg":"这个是关于新朝廷的任务系统简介欢迎大家指出缺点与不足，在下会尽量改正help chaotingtask","author":"小批萨",]),(["time":1028274532,"title":"about newbie gift","msg":"为了提高zh2人气和为了体谅大家newbie时的辛苦为了让大家尽快进入正题提高新手奖励500k exp200k potmax_force 1000basic skill 100lv爽了吧大家addoil","author":"晓风残月",]),(["time":1028290217,"title":"about shizhe","msg":"暂时取消了新手拥有潜能的上限暂时取消了新手做quest时的潜能上限新手奖励增加一项faith改为在京城广场（李白的位置） ask shizhe about gift","author":"晓风残月",]),(["time":1028602386,"title":"正式开放新任务（朝廷任务）","msg":"大家可以help chaotingtask获得相关的帮助addoil all","author":"晓风残月",]),(["time":1028691935,"title":"about task fangqi","msg":"give 5 gold to yuan shuai can fangqi连续完成2次以上有gold等物品奖励","author":"晓风残月",]),(["time":1028698788,"title":"about score","msg":"鉴于玩家要求隐藏天赋现在可以看score","author":"晓风残月",]),(["time":1029142824,"title":"about cttask","msg":"重新编译了任务，一般都可以找到killer加入苏乞儿在yuan shuai e n可以在要完task后ask su qier about killer来得知killer的藏身位置当然要破费一点修正了springsword dragonarmor的bug还有对不起玩家门让你们等了这么长时间很抱歉","author":"晓风残月",]),(["time":1029165757,"title":"about cttask","msg":"适当下调了任务难度（杀手方面）","author":"晓风残月",]),(["time":1029223693,"title":"[ 少林公告 ]","msg":"[ 少林公告 ]由于最近少林寺在江湖中的威望日益减弱所以我少林寺达摩院首座玄悲决定把以下少林绝技传于本门少林弟子[  大金刚神通  ] Perform jingang[  金钟罩神功  ] Exert jzz[ 一苇渡江神功 ]  Exert dujiang希望能挽救当今少林派的颓势，为中原武林尽一分力量因为以上原因少林寺除新入寺弟子外其他带技弟子一律不收望其他门派也不要收留我少林弟子。以免少林绝学外传玄悲 ","author":"晓风残月",]),(["time":1029382345,"title":"关于新的离线练功系统","msg":"新的离线练功系统已经更新完毕，具体内容请参见help offline上面有详尽的介绍请仔细阅读quit有了一点改动，如果首次连线时间小于一小时，则此id被认为是大米ID或者是选人ID不能存档这样可以节省资源，还可以加快选人速度addoil","author":"晓风残月",]),(["time":1029467732,"title":"about daizong","msg":"增加exp上限到1m每次放弃需要交纳1 gold 罚款","author":"晓风残月",]),(["time":1029509965,"title":"[唐门公告]","msg":" [36m广告： 唐门新研发出了新型毒药配合原无影毒合成新无影毒 [0m [36m    欢迎广大武林认识前来品尝！！ [0m [36m武功： 最近得仙人晓风残月指点，唐诗剑法又有了新的招数 [0m [36m     并且新研究出一种特殊攻击方式 剑镖回环 perform huihuan [0m [36m新业务： 唐宏开发新业务 为本门弟子武器淬毒，配合唐诗剑法，威力无敌 [0m [36m欢迎广大待业青年前来投奔，如有门派唐门一律不收，也希望 [0m [36m别门别派不要包容唐门弟子 [0m [36m发布人： 唐门门主 唐云 [0m","author":"晓风残月",]),(["time":1029689513,"title":"今日更新","msg":"今天重写了戴宗任务，朝廷任务戴宗任务提高了效率，系统喘气快点朝廷任务 再次杀手降低难度 并且fight改为一次fight即可sweat 好累","author":"晓风残月",]),(["time":1031392753,"title":"注意命令速度","msg":"如果你在平时输入大于40个命令/秒，就会命令无效如果你在离线修炼中输入大于60个命令/秒，就会被kickout增加一种任务形式quest -s为了那些对系统，秘密不熟悉的玩家为了那些对系统，秘密不熟悉的玩家建议：大家都走慢点，大家速度都快点","author":"晓风残月",]),(["time":1031478456,"title":"关于选人时的天赋输入方式和管理密码","msg":"选人时的天赋输入方式不再象以前那样1/-10总觉得不太好，现在变为先选天赋项目在设定数值请自己设定管理密码以后例如自杀，磐石，放弃武功等重要功能都要求输入管理密码","author":"晓风残月",]),(["time":1035209128,"title":"关于少林武功的调整","msg":"damo-jian 攻击力和攻击速度提高exert jzz 消耗内力减少为600perform jingang 膂力bug修复 膂力可以达到相应效果","author":"晓风残月",]),(["time":1035362267,"title":"关于武当的更新","msg":"具体情况 help wudang ","author":"晓风残月",]),(["time":1035379950,"title":"关于修改后的补偿问题","msg":"想回原门派的玩家可以找我要求以学的无用武功我可以负责给转为潜能算是一点补偿吧","author":"晓风残月",]),(["time":1036588497,"title":"取消了自动听新闻，好像很烦的样子","msg":"","author":"晓风残月",]),(["time":1036684212,"title":"26","msg":"华山见风清洋几率提高，由原来的2%变为现在的1/8希望广大玩家体验华山。接天楼langfanyun pangban liruohai 出装备几率调整阵法制作中，以后欢迎光临接天楼","author":"晓风残月",]),(["time":1037107454,"title":"about zh2 public ip","msg":"发信人: yeung (流星雨), 信区: mud标  题: zh2 chinanet IP更改通知发信站: BBS 曙光站 (Tue Nov 12 10:02:39 2002)zh2 chinanet IP 现在更改为：211.101.171.57原211.101.xxx.xxx失效。                                                        ","author":"晓风残月",]),(["time":1037430610,"title":"about 论坛","msg":"纵横天下2以后使用固定的域名http://zhtx2bbs.yeah.net做为论坛地址以后不会改变新论坛已经架设成功，欢迎注册会员，申请版主。","author":"晓风残月",]),(["time":1049882647,"title":"zhII重新开站","msg":"zhII重新开站咯","author":"一点红",]),(["time":1050394380,"title":"关于新手成长","msg":"新手初期成长可以去京城市中心e,n,在戴宗处领取送信任务，顺便熟悉地图","author":"一点红",]),(["time":1051066784,"title":"新手进步奖励","msg":"1.新手过阵，怒龙锦胄（200 armor_vs_force）、风泉之剑(dam 100，加各项后天天赋若干)、霓虹羽衣（加各项后天天赋若干），这三件物品中可以任选一件，但只限一件，丢失不补。qq","author":"道全",]),(["time":1051067350,"title":"新手进步奖励","msg":"1.新手过阵，怒龙锦胄（200 armor_vs_force）、风泉之剑(dam 100，加各项后天天赋若干)、霓虹羽衣（加各项后天天赋若干），这三件物品中可以任选一件，但只限一件，丢失不补。2.学完自己门派最高级master的高级内功（茅山要求necromancy150，武当200太极神功，少林要求可以运用jzz),奖励lv3 ring一件，我只保证加气，加的多少，具体质量怎么样我不管，看每个人的运气，丢失降低lv等级补偿。3.内力大点达到2000点时(茅山1950即可)，奖励血剑blood sword(dam 120,加kee200，20防御有效等级)或者天蚕忘情丝si（whip，dam 50，加kee200，gin，shen各100），自选，丢失不予补偿。4.经验值达到2M时，奖励lighting sword或者lighting blade一把，丢失或者打断不予补偿。5.经验值做到1M以后，做任务遇到没有刷新的时候，如果我在线，可以找我update，但我只负责update。","author":"道全",]),(["time":1051598774,"title":"新手须知","msg":"1、在京城长安李白处可以找新手使者要礼物，ask shizhe about gift,奖励50000经验，20000潜能。2、潜能在经验值小于50万时，退出不能保存，relogin变为500，当经验值大于50万时，潜能无上限，relogin不变。3、新手使者那里可以要flybag，可以飞到各处，还有patit指令，恢复精，但会消耗食物点。4、新手可以从京城李白处，e,n,向戴宗要送信的任务（输入task），可以做到100万exp,找到NPC以后，giveto id，注意给邪派人物送战书和秘函的时候他可能对你autokill,小心为妙。5、新手成长有各种各样的奖励，详情参见news 32。6、请玩家注意，zh2的西藏，明教，华山，古墓区域和老纵横不同，尤其华山的路比较难走，轻功不高的不要轻易前往。","author":"道全",]),(["time":1051669746,"title":"关于新手进步奖励的改动","msg":"鉴于lighting sword的效果过于明显，特做出如下改动，希望广大玩家体谅：news 28中的第四款，改为当前十个玩家id经验值达到2M时，奖励lighting sword或者lighting blade,丢失或者打断不予赔偿。","author":"道全",]),(["time":1051669810,"title":"关于几点修改","msg":"1.选新人被卡的bug已经基本修复，如果还有被卡的人请联系masterall2.选好几个大米杀master出厉鬼刷装备的bug已经修复，厉鬼只会出现在玩家互杀的事件中，而且是超级变态的杀手，自动杀人，满街跑的大家还记得吴一物吗？请大家洁身自爱，pk是不被人欢迎的。3.统一销毁所有利用ghost bug刷出来的armor sword等等，请知道后自动上交给在线wiz，如果wiz发现库存大于5的所有id不管大米主号，统一purge4.关于门派平衡，唐门，步玄近期要有所改动，请关注news","author":"晓风残月",]),(["time":1051716945,"title":"几点更新","msg":"1.戴宗task时遇到的带有颜色npc的任务不能完成的bug已经修复，如果还有问题请联系masterall2.增加一个新武器 鬼  手 (lighting glove) 放置于幽明山庄效果同lighting sword，为空手装备，目前只支持cuff鼓励玩家修炼空手武功，效果不损内力，以后如果需要加入对其他空手武功的支持","author":"晓风残月",]),(["time":1051784407,"title":"关于5.1礼物","msg":"李白 s e 的地方新出现个女郎中，为大家免费发放非典预防药希望大家在5.1期间身体健康，节日快乐女郎中摆放到5.8日，5.8 日以后自动消失","author":"晓风残月",]),(["time":1051870405,"title":"关于更新","msg":"1.玩家反映jch兵器铺没有暗器的购买，现增加上。2.玩家反映jch没有可以睡觉的地方，现在在南城客栈二楼增加睡房，每晚十两银子，欢迎光临。3.新版纵横2各个门派的帮助已经更新完毕，请有需要的玩家自己察看like : help menpai / help wudang","author":"晓风残月",]),(["time":1052297781,"title":"新手任务须知","msg":"为了节省系统资源，请玩家在做robot送信的时候适当放慢一下节奏，别做的太过分，一旦发现警告仍不听劝阻将面临严重后果，请大家都自我节制一下，自己稍微慢点，大家都快点。","author":"道全",]),(["time":1053174929,"title":"禁止无限制重复连线","msg":"请个别玩家注意自己的行为，为了获取某些物品而无限制的重复login, logout,给系统和其他玩家都带来了不良的影响。再有类似情况将禁止该IP连入","author":"飞离尘世",]),(["time":1053253753,"title":"关于今天的更新","msg":"1.两个命令 score gift 以后天赋和score分开用，gift帮助请看help gifts，选人请用gift2.暂时取消暗器的自定3.纵横天下2所有主题帮助编写完毕，请用help查看所有地图，门派帮助，活动帮助，任务帮助，新手帮助重写完毕，不懂的请查看。4.任务系统采用新引擎搜寻人物地点，保证所有任务都可以完成新手任务中的动物，随机人物将消失，quest -s、cttask中的找不到地方的bug更正。颜色npc可以完成新手任务5.关于江湖历练关系到您所能学到的最大武功等级，相关帮助请查看help experience，此项目尚未完成，等待通知。6.修正分号bug","author":"晓风残月",]),(["time":1053318439,"title":"几点修改","msg":"1.修正了daizong task中一些新手不可能完成的任务,比如魔域里面的npc，如果还有bug欢迎举报2.聊天频道对内颜色NPC说话或者emote的时候的颜色BUG修正，统一颜色为频道颜色，否则很乱3.增加一个set变量 line_num_brief 作用请看help settings","author":"晓风残月",]),(["time":1053321142,"title":"关于纵横2所有地图、部分描述、NPC位置的下载","msg":"http://home.cd200.com/dongsw/download/help.exe","author":"晓风残月",]),(["time":1053393511,"title":"关于近期停止新手进步奖励的通知","msg":"考虑到现在不少玩家已经成长起来，可以去魔域和山庄自己杀装备了，兹决定从下个月1日起停止新手进步奖励，请玩家们今后相互帮助。想要最后领取奖励的玩家要在这10天内多多努力，lighting目前一共才发放了6把。不要错过最后的机会哦！。","author":"道全",]),(["time":1053406355,"title":"关于查看所在位置地图功能","msg":"1.新增指令 help here 用来查看自己所在位置地图。  不明白请看 help maps。2.在此精简 npclist，删除不可能到达的铁雪山庄NPC。","author":"晓风残月",]),(["time":1053417472,"title":"几点改动","msg":"1. 选人时设置天赋的方式增加为两种：随机设置和自主分配。2.选任和登陆最大连线时间设置为五分钟。节省资源3.去除了选人时 真实性命、住址等暂时无用的设置。4.杨过那里的bug已经修正，游戏不允许在那里降经验。 玩家勿论","author":"晓风残月",]),(["time":1053500078,"title":"戴宗任务的修改","msg":"近些天管理巫师发现有人利用戴宗任务，利用机器人走戴宗任务然后降经验，取得了非法的数据现规定如下：戴宗任务只能做到500k 500k以后请quest，quest 500k - 1m的任务不能资源浪费对于利用降经验和机器人获得利益的玩家请和有关巫师联系本游戏不鼓励玩家用机器人来增加经验和潜能，失去有游戏的意义。","author":"晓风残月",]),(["time":1054021543,"title":"关于新手进步奖励","msg":"lighting目前已经发放了9把，得到的玩家是：tonggui,hmn,laugh,phenix,mud,chenghao,flyman,alcatel,cdma希望玩家为最后一把继续努力。另外近期可能会出台人气宣传奖励，请随时关注news。","author":"道全",]),(["time":1054095274,"title":"有奖征集资源","msg":"1。征集能用的机器人，比如打做，领悟，任务等等，   有兴趣的把robot和email发到 dongsiw@sohu.com  1 robot = 1 ptz，如果有重复的按照先来后到的    原则，时间早的给奖励。2。征集玩家经验类文章，比如，任务经验啊，门派经验  啊，只要写了就有奖，按文章的使用程度给奖励。    并且告知所有玩家。","author":"晓风残月",]),(["time":1054141004,"title":"关于主页","msg":"主页已经完工，欢迎访问、浏览，同时有奖征集资源。主页地址：http://home.cd200.com/dongsw","author":"晓风残月",]),(["time":1054314714,"title":"论坛升级","msg":"地址：http://www.meiliyuan.com/cgi-bin/lb5000/leoboard.cgior http://zhtx2bbs.yeah.net以后不会在换了,欢迎注册、发帖。","author":"晓风残月",]),(["time":1054439536,"title":"更新内容","msg":"为了充分利用论坛资源，以后发表news在论坛的更新手记版块推出。本次更新地址：http://www.meiliyuan.com/cgi-bin/lb5000/topic.cgi?forum=8&topic=1&show=0","author":"晓风残月",]),(["time":1054447245,"title":"关于连续quest奖励","msg":" 连续奖励对普通quest或quest -s均适用。;连100个以后有机会出现各种珍稀物品和武林声望，先天容貌，先天福缘的奖励。;另外还有机会获得 战斗经验，潜能和师门忠诚度的额外奖励。  ","author":"飞离尘世",]),(["time":1054602539,"title":"关于给玩家recover的问题","msg":"纵横天下巫师组已经对给玩家的recover问题做出严格要求，玩家也请自己琢磨一下是否符合recover的要求，今天给cdma recover了档案，原因：昨天公众网端口有问题，导致玩家断线死亡证人：laugh，chenghao以后每一次recover都会这样公布出来，也请广大玩家监督我们，一起管理繁荣这个mud。","author":"道全",]),(["time":1054649679,"title":"关于任务系统的更新","msg":"请查看论坛更新专区http://www.meiliyuan.com/cgi-bin/lb5000/topic.cgi?forum=8&topic=2&show=0","author":"晓风残月",]),(["time":1054889442,"title":"鼓励老玩家多写点新手帮助","msg":"alcatel完成武当新手帮助的撰写，特奖励一亿正气。虽然质量有待考证，但精神可嘉，特予以嘉奖。也希望老玩家踊跃投稿，但提出以下几点要求：1、内容要详细全面2、尽量避免用mud里的术语，要让新手一目了然，通俗易懂3、要能体现出门派的特色，专门有所侧重的介绍4、格式尽量工整一点，仿照现在的门派帮助即可5、尽量避免错别字，嘿嘿今后将根据文章的质量给予玩家相应的奖励，也请大家监督。","author":"道全",]),(["time":1055123953,"title":"关于严肃处理有些人违反玩家守则的问题","msg":"特别通知：请所有在线玩家详细查看玩家守则 help rules。鉴于zhiruo已经违反了第4条，特做出如下处理：长期封禁ip，看其悔过态度而决定。另外对玩家piano提出警告一次原因：不要因为自己是老玩家就可以向wiz恣意寻衅。请所有玩家都严于律己，如果还让我发现有类似情况发生，处罚起来绝不手软。外面的世界已经够肮脏的了，请让纵横II变成一块净土。","author":"道全",]),(["time":1055146836,"title":"关于恢复新手进步奖励的通知","msg":"为了继续鼓励广大玩家，在原来奖励的基础上做出一些改动，此奖励办法将长期维持，希望大家继续努力。1.新手exp过80万，怒龙锦胄（400 armor_vs_force）、风泉之剑(dam 200，加各项后天天赋若干)、霓虹羽衣（加各项后天天赋若干），这三件物品中可以任选一件，但只限一件，丢失不补。2.学完自己门派最高级master的高级内功（茅山要求necromancy150，武当200太极神功，少林要求可以运用jzz),奖励lv3 ring一件，我只保证加气，加的多少，具体质量怎么样我不管，看每个人的运气，丢失不予补偿。3.内力大点达到2000点时(茅山1950即可)，奖励血剑blood sword(dam 120,加kee200，20防御有效等级)或者天蚕忘情丝si（whip，dam 50，加kee200，gin，shen各100），自选，丢失不予补偿。4.exp过6.4M奖励黑丝背心一件，50 tenthousand-cash，丢失不予补偿。5.exp达到12.8M奖励lv5一件，自选，丢失不予补偿。6.原先的lighting物品奖励取消。7.原先的update奖励取消。","author":"道全",]),(["time":1055206836,"title":"阶段性进步魔法套装奖励","msg":"为了进一步提高广大玩家的积极性，特在原来新手进步奖励的基础上推出阶段性进步魔法装备套装奖励：1、学完本门派最高级master的所有武功(指你能学到的，包括空手功夫和零七八碎的功夫，茅山派以林忌为准，铁血大旗门以云九霄为准，日月神教以独孤峰或者东方不败为准，唐门特殊功夫有两套，学一套即可)，奖励level 2装备一套。考虑到特殊门派成长难度比较大，华山派(风清扬)和武当派学完所有skills，奖励lv 4一套，明教(张无忌，可以不学七伤拳)，少林(达摩老祖)，奖励lv3一套。2、Reseach一项基本武功到250级，奖励lv3一套。必须是research的，而不是可以learn的，类似literate的，少林的buddhism等等。3、Rearch一项高级武功到250级，奖励lv4一套。必须是research的，而不是可以learn的，类似少林的金刚拳，混元一气功，武当的太极神功等等。茅山派情况特殊，Necromancy不可research,所以practice到230可领取此奖励。4、Rearch所有武功到250级，奖励lv5一套。这里的所有武功指的是所有你能research的，除少林，铁血大旗门以外的门派可以不包括空手功夫。其中少林的功夫以达摩老祖的为准(包括达摩剑)，华山的以风清扬为准(可以不包括华山剑法和华山身法，但要求燕双飞，气宗要求紫霞神功，剑宗要求狂风快剑)，日月神教以独孤峰或者东方不败的为准，唐门特殊功夫有两套，research一套即可，逍遥派以无崖子的为准(包括从段誉那里学来的六脉神剑)。茅山派特殊，要求research完解密后从金花婆婆那里学来的月影舞步。注：1、在第一条中给出的奖励装备等级如果和后面的装备等级出现重叠，只能领一套，遗失不补。2、只保证基本质量，如果连续三件同样的装备出现残次品，只能怪自己运气不好3、本奖励办法只限没杀浪翻云和庞斑的玩家，玩家如果完成了接天楼的任务，则相当于自动放弃了今后享受此奖励的权利。4、本奖励办法的最终解释权归纵横天下巫师组，如有问题请与在线巫师联系。","author":"道全",]),(["time":1055301055,"title":"奖励玩家chenghao lv 5ring一件","msg":"鉴于chenghao写了很全面完善的少林新手帮助，特奖励其lv5 ring一件，质量不错。希望广大玩家踊跃投稿，奖品丰厚。","author":"道全",]),(["time":1055484374,"title":"post 关于新手第一次登陆出现的问题","msg":"所有玩家请注意，新id第一次登陆以后，一定要等一段时间存档，大约十分钟，然后quit重新login，档案才可以真正保存，在这期间千万不能断线。否则将导致档案丢失，切切。","author":"道全",]),(["time":1055668414,"title":"关于daizong任务","msg":"由于戴宗的送信任务设置的完成和退任务条件过于容易，导致玩家能轻松用robot完成前500K exp的任务。送信任务的宗旨是让玩家通过送信，达到熟悉纵横天下环境的目的。现在的情况不符合这个宗旨。因此，近期将对送信任务做出适当调整，特此提前通知。","author":"飞离尘世",]),(["time":1055772294,"title":"有奖征集新手帮助主题文章","msg":"请到纵横天下论坛新闻发布版观看详细内容。文章太长，发不了。。PP","author":"飞离尘世",]),(["time":1055867060,"title":"关于帮助文章的奖励","msg":"以后奖励的记录都会公布在论坛更新手记版，欢迎大家监督","author":"飞离尘世",]),(["time":1056291087,"title":"关于更新","msg":"昨天更新的，论坛不能帖，今天补上，给这个公告。http://www.meiliyuan.com/cgi-bin/lb5000/topic.cgi?forum=8&topic=5","author":"晓风残月",]),(["time":1056526242,"title":"挖宝和6.4M任务段调整","msg":" 对挖宝和6.4M-12.8M任务段做了些调整: 师门任务里宝物数量减少为4个，同时添加了少量任务。 挖宝中去掉了新手村相关区域。如有bug，请及时报告。 ","author":"飞离尘世",]),(["time":1056678276,"title":"奖励第一次杀人接天楼的玩家tonggui，cdma","msg":"这是重新开站以后玩家第一次自己杀入接天楼，tonggui一直杀到接天楼的第七层，厉若海处，非常值得庆贺，特奖励tonggui，cdma各lv5 ring一件，希望广大玩家继续努力，杀庞斑，浪翻云的日子不远了！","author":"道全",]),(["time":1056706124,"title":"今天的更新","msg":"又reboot了，在这里对大家说声对不起啦。呵呵迫不得已。请看论坛http://www.meiliyuan.com/cgi-bin/lb5000/topic.cgi?forum=8&topic=9&show=0","author":"晓风残月",]),(["time":1056962529,"title":"乾坤教总舵入口加入","msg":"地点在襄阳城东北方向，欢迎广大玩家体验乾坤教。也请大家帮忙找找bug，发现者有奖励。","author":"道全",]),(["time":1056978166,"title":"奖励玩家cdma tonggui各10点武林声望","msg":"原因：继上次杀入接天楼后，于今日斩杀厉若海。tonggui,cdma相互协作，积极配合，精神可嘉，特奖励其各10点武林声望，也请广大玩家继续发扬相互配合的精神，争取早日迈向纵横武林新的颠峰。","author":"道全",]),(["time":1058343442,"title":"乾坤教宝库完成","msg":"乾坤教宝库完成1、乾坤教区域npc身上加入比较好的装备，装备效果随基本技能等级提升，不能典当。2、乾坤教区域加入秘密地点宝藏库，路上危险重重，机关密布，，玩家探险的时候务必小心谨慎。3、宝藏库里有不少很好的东西，请玩家自行发掘。传说中的门派特殊武器都在里面，想要到的就赶快去吧。4、exp低于5m的玩家最好不要轻易前往，否则的话。。。。。嘿嘿5、关于特殊武器的说明：特殊武器必须要求一门特殊功夫达到250或者250以上才可以得到特殊武器随身，退出不会掉。特殊武器的效果随特殊技能等级提升。特殊武器特殊效果各个门派的不一样。各个门派要求技能茅山：spells  唐门：mantian-huayu, 步玄:mystsword,少林:250 cuff and strike 可以得到铁罗汉，250riyue-bian可以得到黑索全真：tonggui-jian 晚月：snowwhip 明教:男，shenghuo-shengong,女，essence-sword乾坤教：fuliu-jian 逍遥：liumai-shenjian 太监：pixie-sword天邪：spring-blade  丐帮：dagou-bang 武当：taiji-jian喇嘛：cloudstaff  日月神教：mo-jian-jue华山:250 dugu-jiujian 紫薇软剑 300 玄铁重剑，350木剑","author":"道全",]),(["time":1058404713,"title":"关于最新门派改动的通知","msg":"详情参见：http://www.meiliyuan.com/cgi-bin/lb5000/topic.cgi?forum=8&topic=10&show=0鉴于目前还属于测试阶段，纵横天下II巫师组保留进一步改动的权利。欢迎广大玩家多帮忙找bug，有奖励的哦。bow all,sweat.","author":"道全",]),(["time":1058486685,"title":"修改了bracelet,casket的bug","msg":"原先在busy状态下也可以用，现在加入busy状态时的限制，鉴于这是历史遗留问题，从此获益的玩家不予追究，但为了纵横II能向更健康的方向发展，修改这个bug还是必要的，请广大玩家理解并支持我们的工作。","author":"道全",]),(["time":1058490235,"title":"关于内力修炼的调整","msg":"鉴于目前玩家打坐需要漫长的时间，比较枯燥，为了增加游戏的可玩性，将打内力的速度提高一倍，同时内力瓶颈开放到8000，若发现有问题请及时报告bug","author":"道全",]),(["time":1058750335,"title":"关于一些bug的改动","msg":"门派特殊武器一律调整damage为300，为了防止某些bug的出现，有的兵器可能damage会高一点点。另外山庄刷新物品加入lighting glove。魔法装备的获取必须亲手杀死对方才可以获得，以前靠拣尸体而获取装备的bug被修正。茅山的符现在不能乱烧了。就这么多，以后会逐步完善起来，这才是一个健康的游戏，这些改动不是针对哪个玩家的，完全是为了公平和这个mud的前途，希望广大玩家理解。","author":"道全",]),(["time":1058835190,"title":"关于更新","msg":"1、武当太极剑的bug修正，以后250太极剑请教了张三丰才可以出拨云瞻日2、古墓加入双剑互搏和天罗地网式，有兴趣的玩家可以前往一试3、雪亭镇的公德箱修改，往里面放钱不再降杀气，而减自己的杀人数。4、独孤九剑改为250级以后可以practice。","author":"道全",]),(["time":1058965271,"title":"新加入一些help文件for新手","msg":"help skill,combat,money,wealth,equipment,forces,book,secret,medicine,menpai_gift需要的玩家可以查看，有问题就提出来。","author":"道全",]),(["time":1059118814,"title":"关于奖励玩家tonggui和cdma","msg":"今天是纵横II重新开站以来值得庆贺的日子，玩家tonggui和cdma通过自己的努力终于斩杀庞斑成功，为了奖励二人的杰出表现，特奖励tonggui，cdma高质量的lv6一件，以兹鼓励。也希望他们两人能够尽量多帮助其他的玩家成长，共同繁荣这个mud。","author":"道全",]),(["time":1059121192,"title":"关于提升玩家lucifer成为app","msg":"鉴于lucifer有很强烈的热情和很高的积极性，以及一定的工作能力，特提升其成为纵横天下II巫师工作组中的一员，希望广大玩家与其多沟通和交流，也一起监督和帮助他的工作。","author":"道全",]),(["time":1059400848,"title":"关于严肃处理有些人违反玩家守则的问题","msg":"purge cmda, wanyue, 理由如下：用及其污秽的语言辱骂巫师。希望所有的玩家都能维护zh2的纯洁环境.外面的世界已经够肮脏的了，请让纵横II变成一块净土。","author":"飞离尘世",]),(["time":1059556846,"title":"请广大玩家去论坛上对cdma和flyaway事件进行投票","msg":"给大家一次实行民主权利的机会,呵呵.","author":"道全",]),(["time":1059901036,"title":"lighting glove修正","msg":"现在的lighting glove可以定义decide成为各种空手武器但不支持互备,感谢lazypig做出的工作,请各位玩家有条件的帮忙测试一下,找找bug.","author":"道全",]),(["time":1060073346,"title":"一些改动","msg":"1.玩家exp<800k死亡不会掉潜能了,感谢lazypig的帮助2.加入help safety,help ketou,感谢热心的玩家3.今后准备陆续对派系进行一些改动,请大家随时关注论坛,多提一些合理化建议.","author":"道全",]),(["time":1060075417,"title":"增加了一些help,感谢所有热心的玩家","msg":"help shaolin_help,help wudang_help,help safety,help goutong,help hp,help magic_item,help xinshoucun,help research","author":"道全",]),(["time":1060219398,"title":"关于这次当机的说明","msg":"由于本人昨天修改文件误操作,导致整个系统crash,特向所有玩家表示歉意,玩家经历此当机丢失的物品可以找在线wiz补偿.再次致以深深的歉意,希望大家理解.bow all,sorry for all!","author":"道全",]),(["time":1060220080,"title":"关于玩家天赋悟性的修改","msg":"现在玩家的天赋中先天悟性上限调整到100,贺知章那里可以将literate学到400.对于research很多的玩家会考虑给予适当补偿,但要求不可太过分.否则一点都不给了,呵呵.","author":"道全",]),(["time":1060243145,"title":"关于年龄增大开始掉精气神的修改","msg":"从原来的40岁改至80岁才开始掉,女性从70岁开始掉魅力,男性80岁开始掉.有bug请快速报告.","author":"道全",]),(["time":1060245761,"title":"关于cttask的修改","msg":"现在连续完成20个以上的朝廷任务,会有一定几率得到wlshw的奖励,获得的概率和玩家的先天福缘相关,奖励的wlshw的点数是随机的1到2点.大家加油了要,呵呵!","author":"道全",]),(["time":1060247701,"title":"关于补偿玩家潜能的原则","msg":"由于修改了悟性的上限,所以需要给老玩家的潜能给予一定补偿,1.exp>6.4M的玩家才可以找wiz要求补偿2.补偿的潜能为你所用过的潜能的1/53.不得与wiz讨价还价,否则一个子都没有.4.此补偿办法只限此消息发布前exp>6.4M的玩家,后面达到者不可再予以索要","author":"道全",]),(["time":1060332487,"title":"一些改动today","msg":"1.开放transfer age,玩家可以用10点wlshw的代价使自己减一岁，最多只能减到16岁2.unwield bug修改，busy的时候不能unwield3.偏好是左手的学习进度修改.","author":"道全",]),(["time":1060334723,"title":"关于cdma,flyaway事件最终处理决定","msg":"鉴于玩家cdma已经在论坛上公开认错，态度较好，予以从轻处理，处罚如下：收回奖励其的JP加kee的lv6 ring.希望所有的玩家都能以此为鉴，严格遵守玩家守则，但愿这种不愉快的事情永远都不要再发生。这里是玩家娱乐的天堂，不是吵架的地方，呵呵，就这么着吧。","author":"道全",]),(["time":1060566452,"title":"lingting系列其余兵器完成","msg":"与其他lighting系列一样放置于shanzhuang和jtl,以百宝囊形式出现，可以演化(pull and repull)为如下兵器：whip,fork,halberd,hammer,hook,spear,staff,axe效果与其他lighting系列同，感谢lucifer的工作。有问题请及时报告bug.","author":"道全",]),(["time":1060650752,"title":"关于逍遥派master无崖子的一些修改","msg":"加入skills:bahuang-gong,staff,tianshan-zhang,flattering其中bahuang-zhong可以与beiming-shengong相互切换。初期的逍遥不会太面了。","author":"道全",]),(["time":1060677936,"title":"纵横天下II两个重大改动 请所有玩家关注","msg":"1.加入指令age2force,玩家可以将自己的年龄转换为内力,help age2force最少使用的修炼时间是1小时,可以将内力修炼到自己的上限,也就是force*8+adv_force*5,修炼的速度和自己的内功修为,内力大小,气的长短都有直接的关系,修炼完成后会有一定时间的busy,修炼到上限以后多余的时间也会从玩家的年龄中扣除,请玩家在修炼时计算好修炼时间,不要造成不必要的浪费.另外修炼设置了玩家最大内力值下限要求400,上限8000.有bug请玩家及时报告,纵横天下巫师组保留进一步修改的权力.先前自己打坐修炼的玩家不予以任何补偿,请勿找巫师索要.2.quest上限调整到19.2M也就是19200000,另外去掉了段誉和花夜来的任务.","author":"道全",]),(["time":1060741609,"title":"乾坤教宝库修改","msg":"加入新版九花玉露丸,神仙茶,欢迎广大玩家前往品尝,以后还会陆续推出一系列的滋补品,敬请关注.BTW:宝库里的有些NPC现在会用perform了,小心为妙","author":"道全",]),(["time":1060766676,"title":"乾坤教宝库改动","msg":"继加入新版九花玉露丸和神仙茶后，加入新物品：忘忧果和金蚕王。新版九花玉露丸->内力小点翻四倍神仙茶->法力小点翻倍忘忧果->降低一次死亡次数金蚕王->随机增加福缘、口才、神秘、意志、远见各一点，最多可以吃到30点。另外乾坤教宝库里的NPC都加强了一些，有些会用很厉害的perform,大家再去探险的时候小心点。有bug及时报告。","author":"道全",]),(["time":1060846462,"title":"关于刘老农bug的问题","msg":"由于本人工作失误,导致这个bug的产生,很多玩家利用这个bug涨了不少潜能请利用这个bug牟利的玩家在今明两天自动向在线巫师报告,逾期不报者一旦查处得以证实,将予以purge的处分.请大家配合我们的工作,心存侥幸的到时候可别怪我翻脸无情了啊,呵呵.bow all.","author":"道全",]),(["time":1060853431,"title":"乾坤教宝库更新","msg":"加入NPC牛魔王,身上有个很好的东东,呵呵另外里面不会死,但是一旦被打出来会损失所有潜能,请玩家慎之,欢迎大家来探险夺宝.","author":"道全",]),(["time":1061089033,"title":"几点修改","msg":"1.乾坤教宝库加入lighting armor,但是那个NPC现在很不好惹,小心为妙2.taiji-jian>200以后没有taiji-shengong限制要求3.门派特殊武器还存在一些bug,出现问题的玩家请帮忙记录log,并汇报.4.灵葫仙丹做了一些调整,吃挂的几率减小,但是如果你衰的话还是会倒霉,譬如cloth.hehe5.乾坤教里的牛魔王比庞斑还厉害,没事不要随便去惹他,你以为自己是至尊宝啊,escape~~","author":"道全",]),(["time":1061277703,"title":"乾坤教宝库修改","msg":"1.前面守门的NPC加强了许多,但身上的好东东也多了许多,还可以随机通过杀死NPC得到1点wlshw2.考虑到现在进入宝库比较难了,另外开辟了一条新路径,请玩家自己寻找,提示：仔细研究一下大地图就会发现了,很容易的,但有exp限制，还会掉5k exp","author":"道全",]),(["time":1061347123,"title":"茅山派修改","msg":"1.加入NPC地狱圣火diablo,可以和他学八识神通和天外神识,但是拜他有严格的要求,250magic,250spells,当然也必须拜了张天师才可以research到这么高.2.manashield修改,spells的enable等级达到100以后就可以使用,不再存在成功率的问题.3.diablo那个NPC放在泰山,原因嘛,呵呵,不说了.4.关于茅山派近期可能还会有一些调整,请广大玩家关注,也请大家有空来体验茅山,享受役鬼通神的乐趣.","author":"道全",]),(["time":1061367603,"title":"关于接天楼的一些改动","msg":"1、在第九层上杀死庞斑可以到达虚空，里面加入NPC不知火舞和龙象每个人身上都有1件lv6,杀死可得到3点wlshw,但比较BT，想要lv6又不怕死的就来吧2、下面的乾罗加强了一点，以前纯粹就是个面瓜。3、BTW,winda和banruok都有很牛的空手，以为把他们兵器磕掉就能灭了的玩家还是不要打这个算盘了，呵呵,祝大家玩的开心，以后还会陆续把扫地僧和独孤求败加上，大家拭目以待吧。","author":"道全",]),(["time":1061540260,"title":"丐帮的一些修改","msg":"1.降龙十八掌加强，并加入perform hubo,左右互搏2.perform hubo要求180xianglong-zhang,偏好均衡，要去找郭靖讨教3.郭靖现在先放在襄阳地界。","author":"道全",]),(["time":1061625797,"title":"rysj一些修改","msg":"1、加入特殊武器混世魔剑，在独孤峰身上。2、那把剑很牛，有破甲的效果，即使老玩家最好也不要轻易去惹他。3、mo-jian-jue的perform tianmo要求mo-jian-jue等级降低到220级，可以早点爽了。","author":"道全",]),(["time":1061988618,"title":"几点改动","msg":"1.少林派特殊武器铁罗汉修改，不能和其他武器同时装备另外加入特殊效果磕兵器，以后打不飞的兵器找laugh好了，呵呵2.明教的yitian jian修改，只有内力大点>3500,先天臂力50,明教或者乾坤教的弟子才可以使用,请广大玩家理解，充分发掘其他搞飞兵器的途径，不要按住一个yitian jian不放。","author":"道全",]),(["time":1062467115,"title":"接天楼的一点改动","msg":"1、厉若海处加入庞斑的弟子方夜羽，和庞斑功夫差不多，面点，但会反击，小心为妙。2、杀死方夜羽会随机得到1或者2点wlshw3、方夜羽身上有两只三八短戟，是很好的武器，不能当，可以用来做second weapon，类似dagger","author":"道全",]),(["time":1062483758,"title":"唐门的一些改动","msg":"1、加入一种特殊武功－阴功(yin-gong),可以激发为parry,force,dodge,move,claw,攻击有特殊效果，而且可以practice，但要求250tangmen-xinfa才可以学得到。2、加入NPC唐缺，放在唐门大门处，无性唐门弟子，force有效等级达到350可以拜他为师，BTW：不是太监也学不了阴功，现在已有唐门ID如果想转换性别可以来找在线wiz3、阴功有一个exert double,可以暂时将气的小点double，受内伤时此效果无法使用。。","author":"道全",]),(["time":1062559692,"title":"帮助系统更新","msg":"1、详情参见help for_newbie2、另外专门加入路径help path,对地图不熟悉的玩家可以用来查看，帮助自己做一个全面的alias，这样干什么都方便3、如果发现help path里那条路径有错误的请及时报告4、少林特殊武器铁罗汉做了一些调整，仅仅为了平衡起见，并非针对哪个玩家，请谅解。5、另外特别感谢先前撰写帮助的热心玩家，欢迎大家继续投稿","author":"道全",]),(["time":1062724163,"title":"关于硬功的一些修改","msg":"鉴于目前整体攻击力都增强了，硬功效果特做出如下调整：1、硬功效果加倍2、壳被打破以后仍可以化解一部分伤害，如果打不破就对对方造成反震伤害另外对防具和兵器加parry和dodge的上限做了一些调整，提高到50由于硬功这个改动比较大，玩家在游戏期间发现bug或者反常的问题请及时汇报。bow all.","author":"道全",]),(["time":1062898537,"title":"一些修改","msg":"1、硬功的反震效果调整回以前的状态，但防御效果仍然有，再发现问题的玩家请及时报告。2、北冥神功的maxsuck调整，最大吸取内力点数等于北冥神功等级*25，这样学六脉神剑相对容易一点。3、东方不败的葵花神功和辟邪剑法调整到220级，欢迎大家体验太监。4、感谢大家提出的意见和建议，也请大家今后发现情况及时报告，但少一点牢骚和埋怨，多一点建设性的想法，让我们一起建设维护发展好这个游戏。","author":"道全",]),(["time":1062905670,"title":"关于晚月庄的修改","msg":"1、master eelon的功夫调整为220 dodge和stormdance,以前180是低了点。2、snowwhip加入perform shuang「月冷如霜」,感谢lucifer的工作3、意寒毒的效果调整，中毒者会随机产生1 busy。发现问题请及时报告。","author":"道全",]),(["time":1062983378,"title":"增加指令status","msg":"1、指令score恢复到以前的状况，另外增加一条指令status，以便区分，原来的score太长了。2、status里加入一项新的功能可以查看自己的中毒状态，玩家能够遇到的毒全部收录进去了，如果发现有问题请及时报告。","author":"道全",]),(["time":1063013088,"title":"关于唐门的一些改动","msg":"1、唐诗剑法加入perform huihuan，剑镖回环。要求180 tangshi-jian和mantian-huayu,2000内力已经学了另外一种剑法和高级throwing的玩家可以找巫师transfer另外想拜唐缺的玩家也可以来变性，今天就有一个就范了，呵呵2、阴功的学习要求修改，research 250 force就可以拜唐缺学了。但属于特殊内功，切换的时候需要散功，enable成为parry,claw,dodge,move的时候没有要求，欢迎大家体验唐门，有bug请及时报告。","author":"道全",]),(["time":1063024214,"title":"侠客岛初期建成","msg":"1、应广大玩家的急切需要，我只好先给侠客岛安了个地方，完成金花银叶、金花婆婆、西夏任务以及杀死庞斑的玩家可以向赏善使者要赏善罚恶令，凭借此令上岛找自己门派前辈拜师，但拜师会扣掉50wlsw，所以拜成的玩家不要轻易再拜别人了。BTW：赏善罚恶令可以作为dagger，auto_load,是个不错的东东，不要乱丢。2、派系会陆续加入，比较强的门派学其他门派的功夫会有一些限制。不明白的玩家可以来找我咨询。3、另外派系的问题还想请大家多提点好的建议，平衡的问题很难搞，我头痛得很，我尽量保证一碗水端平。4、相对比较面的门派的perform要求都会下调，大家不要对这些门派失去信心。例如：天邪，日月神教等等。5、由于整个游戏现在都处在一个完善发展的状态，所以出现这样那样的问题都在所难免，我们的工作如果做得有不周到的地方请大家原谅，今后一定会逐步的完善起来，也请大家多支持我们的工作。","author":"道全",]),(["time":1063067618,"title":"门派特殊武器调整","msg":"鉴于当初门派武器要求条件比较苛刻，很多玩家都拿不到，因而下调了一些，希望可以调动一下大家的积极性。详情参见help special_weapon。有问题或者有什么意见建议请及时提出。","author":"道全",]),(["time":1063178840,"title":"乾坤教宝库的一点改动","msg":"欢迎大家前往探索，会有意想不到的收获哦！言尽于此，到时候不要超我扔臭鸡蛋就是了。BTW:一旦沾染了不干净的东东自己想办法弄掉，呵呵。","author":"道全",]),(["time":1063249398,"title":"中秋快乐！！","msg":"今天是中秋佳节，纵横天下工作作祝愿大家节日快乐，万事如意，特于今天（且只限今天）发放节日礼物，经验值大于5万的玩家可以到京城广场ask ji liang about 节日礼物，会有意想不到的收获哦。","author":"道全",]),(["time":1063325863,"title":"quest -s修改","msg":"对于乾坤教徒的任务，如果杀了别人的教徒，会有不同的提示信息，并且受到降低5万点exp，quest连续数目清零的惩罚，大家以后做任务的时候小心了。","author":"道全",]),(["time":1063437370,"title":"119","msg":"明天正式开始周比武，以后每周每月进行比武，有奖励，关于具体奖励大家可以先提意见，明天拍板，明晚20：00正式开始比武大会。sseseeeeeeeeesssssesssssssssssessssswswwwwwssssswswswswswswssssssssssnwwwsseseseesessssseseeeeeeeeesssssesssssssssssessssswswwwwwssssswswswswswswssssssssssnwwwsseseseesesss","author":"一点红",]),(["time":1063442159,"title":"120","msg":"0┊明天正式开始周比武，以后每周每月进行比武，有奖励，关于具体奖励大家可以先提意见，明晚20：00正式开始比武大会。","author":"一点红",]),(["time":1063539250,"title":"121","msg":"今天比赛分组初步定为：14-20，21-30；30-99,另外组织一次14-99的比赛，取总冠军，个人单挑现在报名。","author":"一点红",]),(["time":1063544306,"title":"122","msg":"第一届周比武大赛圆满成功（人比较少 blush）。为了纪念本届比武大赛，特奖励所有参赛者wlsw 1点。14-20组冠军产生：小桂子 cgs,奖励qn 1w点。20-30组冠军：冷若霜(Frosta)，奖励wlsw 5点。30-99组冠军：闭月羞花(Cloth)，奖励max_force 50点（注：cloth是降年龄的，分到30-99组）。小桂子(Cgs)与 原来如此(Jansen)比武获胜，鉴于小桂子(Cgs)的出色表现，另奖励wlsw 2点。希望大家努力备在，在下一届周赛中取得好成绩。","author":"一点红",]),(["time":1063589175,"title":"一些perform调整","msg":"1、重写了essence-sword的perform tisha，应该更华丽一点，也更适用，但对付比自己强得多的人可能会受到内力的损伤和反击，用的时候小心为妙。2、武当太极剑perform ninth改回原来的最大数目9 hits，但太极剑>250以后有额外的damage和attack加乘，而且此perform运用的效果还和自己的正气和对方的正气有很大关系，总体运用效果和原来差不多但考虑到18连击还是过于bt，所以采取了这个折衷的办法，大家有什么意见和建议都可以反映上来。3、步玄派的hasten最大数目调整到12hit，但要注意的是不是每次都有机会出招的，出招的机会和自己的胆识以及对方的定力有很大关系。另外perform使用完成后的busy会随mysterrier等级的提升而减少。4、修改了辟邪剑法的perform cimu的bug，如果还有问题请及时报告。","author":"道全",]),(["time":1063679148,"title":"一些改动","msg":"1、特殊任务quest -s的bug修复，杀死别人的killer不会断自己任务的连结数目，但会掉5000潜能和50000exp，请大家注意，领了任务以后不能quit，如果这样重新连线进来杀的killer不是自己的，还要受惩罚。2、逍遥派六阳掌的perform shengsi生死符调整，发现bug请玩家及时汇报。3、昨天我写了一篇关于现在perform的综述，请大家有兴趣的务必去论坛上看看，可能会有很多收获和心得，有什么问题和想法都可以提出来。","author":"道全",]),(["time":1063721205,"title":"开封处不痴大师修改","msg":"应广大玩家的要求，加入特殊解毒功能，中毒的玩家可以在开封找不痴大师解毒，一般情况下玩家遇到的毒都可以解，但那个所谓的圣人可不是白给你解的，要给他样东西才成，具体怎么搞请玩家自己想办法，我不能再提示了，应该有人知道。出现问题请及时报告。另外药王谷药王处修改，可以找他问天仙玉露的配方，搜集够材料就可以让他给你配制传说中的圣药——天仙玉露。","author":"道全",]),(["time":1063765594,"title":"关于独孤九剑的perform修改","msg":"1、一旦自己施用独孤九剑perform po-jian等等(perform po-throwing除外，因为是打全体)对手有一段时间不能用perform，不能exert,conjure,cast,但对手没有busy，可以set attack 100狂K之，呵呵，但使用自己使用独孤九剑perform的busy不做改变。2、如果对手被破，将不能自己设置enforce，也就是无法运用enforce指令，这招似乎在比武的时候比较有效。npc由于比较笨，也就无所谓了。3、运用独孤九剑perform以后只有对手是玩家才不能用perform,exert等，对NPC无效。4、这几类perform的命中率和自己sword有效等级，后天灵性悟性以及对方经验值，后天灵性悟性有关。有问题请及时报告。","author":"道全",]),(["time":1064212815,"title":"关于这次长时间断线","msg":"由于服务器调整以及安装防火墙，很抱歉让大家等了这么久，我代表纵横天下II巫师组对所有的玩家表示深深的歉意，也希望大家能够一如既往的支持我们的工作，为弥补这次断线对大家造成的煎熬和精神上的损失，特再次发放一次月饼，方法和以前相同，在长安广场ask ji liang about 节日礼物祝愿大家都玩的开心。","author":"道全",]),(["time":1064216448,"title":"关于侠客岛","msg":"侠客岛目前已经初步建成，主要有以下几点请玩家注意：1、上侠客岛的条件：破解金花婆婆、金花银叶、西夏赫连铁树的秘密，并且杀死魔师庞斑，战斗经验达到12.8M就可以，注意上岛以后不再有武林声望要求。上岛前先要向赏善使者要赏善罚恶令，在蓬莱yell boat就可以上岛了。2、上岛之后可以向岛主龙亦凡要腊八粥喝，有什么效果看你自己的造化了。3、侠客岛后山山洞内可以yandu wall，一共24个石洞，可以将相应的基本skills从200研读到250，给大家省去了漫长的research过程，但会消耗一定的潜能，比起research来说这点潜能根本不算什么。但请大家一定一定要注意，那个石壁可不是随随便便就能读的，仔细看一下《侠客行》，应该能明白其中的奥妙。4、各个石洞内会有各自门派的前辈，满足条件者可以拜师，但拜师有一定50wlshw要求，还会有一些skills的要求。目前的NPC可能还不大全，以后会逐渐补齐。5、侠客岛目前已经正式对玩家开放，但还处于测试阶段，纵横天下巫师组保留进一步修改的权力。6、可能岛上会有一点点小bug，但不会影响正常的玩家活动，以后会修复。7、发现问题请大家及时报告，报告者有奖励。","author":"道全",]),(["time":1064390050,"title":"一些改动","msg":"1、侠客岛上岛条件12.8M改为8M,也就是可以做cttask的时候就可以去了2、独孤九剑perform po-jian和perform po-qi做了一些调整，如果自己经验和独孤九剑等级足够高，可以让对方一开始有一段时间的busy，另外成功率也有一些变化，有什么问题请及时反应。3、西藏喇嘛加入火焰刀(nutrifux)可以拜雪山寺习得。4、侠客岛陆续加入新的门派master，有条件上岛的可以先去看看，找找有什么问题没有，因为一时做得比较匆忙。5、步玄的master是重炮，可以找他修习一门功夫：书法之技，等级高到一定程度可以涨先天定力和胆识，但比较难涨，需要学的级别很高，不过别急，重炮有500的书法之技，有空可以慢慢学，呵呵。另外拜了重炮之后使用mysterrier就开放一个新的perform link，四式连环可以将mysterrier其他几个没什么大用的perform联合在一起使出，效果相当好，步玄的玩家不要泄气。6、京城广场处的月饼发放已经于昨晚取消，没有要到的玩家就不要再抱怨了。","author":"道全",]),(["time":1064461370,"title":"关于西藏喇嘛教的几点改动","msg":"1、加入火焰刀自动特殊攻击火焰掌力，可以破上限和造成内力的伤害，玩家遇上了千万小心，另外火焰刀加入perform fan,烈火焚身2、五行轮做了一些调整，很可能砸碎对方的兵器，大家遇上了千万留神自己的兵器。3、五行轮perform wuxing五行连击做了一些修改，加入五行各个属性的攻击效果。4、西藏喇嘛教今后还会陆续调整一下，做成一个统一的一体派系，类似乾坤教，请大家密切关注，也欢迎广大玩家体验西藏各教派。","author":"道全",]),(["time":1064477229,"title":"今天新加入的两个exert","msg":"1、桃花内功加入碧海潮生曲exert bhcs，要求180taohua-force,150 music,身上有玉箫，可以攻击对方全体，对玩家无效，使用的效果和自己的内力，桃花内功等级，以及对方的内力，先天定力，music等级有关。2、嫁衣神功加入嫁衣神通exert jiayi_powerup,可以给自己和对方加powerup，提升战斗力，但对别人使用时会掉一点内力大点，所谓为人作嫁，不掉点也不合适。","author":"道全",]),(["time":1064477879,"title":"进入侠客岛条件修改","msg":"鉴于广大玩家的强烈要求，现在去掉8M exp的要求，改为25点wlshw，杀了一两次庞斑，浪翻云，把几个秘密解了基本也就差不多了，如果自己订了衣服那就认命，自己慢慢攒武林声望，关于侠客岛上岛条件这是最后一次修改，再抱怨什么也只能这样了。","author":"道全",]),(["time":1064544516,"title":"加入纵横兵器谱秘密","msg":"1、首先感谢巫师zephyr的辛勤工作。2、纵横兵器谱是一个终极的amulet，auto_load,玩家可以通过解密获得，战斗中会随机出现兵器贩子帮助佩带有纵横兵器谱的玩家战斗，效果很强。3、给大家一点提示：纵横兵器谱的秘密可以去苏州问问一些江湖阅历资深的NPC，或许会有一些新的发现。4、在这里我严正警告，任何巫师不得透露办点有关此秘密的内容，也不得帮助任何玩家破解此秘密，如果一旦让我发现，就地降级，并根据情节予以更为严厉的处分，另外玩家在解密过程中如果发现什么bug可以向masterall和zephyr发出疑问，但不得提出任何违规要求，否则一并处理。5、这个纵横兵器谱zephyr耗费了很多心血，也请大家自动遵守玩家和巫师守则，并且尊重别人的劳动成果，这样才能在其中享受到真正游戏的乐趣。祝大家好运。","author":"道全",]),(["time":1064654384,"title":"一些改动和需要注意的问题","msg":"1、由于火焰刀有破上限和伤内力效果，玩家在魔域和quest -s的时候一定要小心谨慎，另外一定要提防五行轮的破兵器，用锤子的可能不好惹。2、星宿加强星宿毒掌已经腐尸毒的效果，不是从星宿出师拜的无崖子的玩家今后会在侠客岛上学到，并且可以用北冥神功激发，玩家做任务的时候小心点丁春秋，以及用星宿毒掌的乾坤教徒。3、魔域加入魑魅魍魉四个NPC，身上有不少丸子，但比较难杀，比较面的玩家不要轻易去试，以免挂掉。4、由于现在空手功夫威力普遍都加强了，所以把对方兵器磕飞不一定是什么好事情，在摸不透对方底细的情况下不要贸然和对方拼空手。。","author":"道全",]),(["time":1064657681,"title":"接天楼两个NPC修改","msg":"莫意闲skills改为星宿毒掌，赤尊信改为五行轮，会用perform wuxing，玩家小心为妙，可以体验一下新加的功夫。","author":"道全",]),(["time":1064828547,"title":"国庆节礼物开始发放","msg":"此礼物以任务形式发放，经验值大于5万的玩家可以在京城广场ask li bai about 精忠报国然后去杀倭寇，割下首级交给李白从而获得奖励。注意几点问题：1、玩家要一个一个去，不能一起上。2、倭寇的水平和玩家自身水平相当，精气神长点，但攻击比较面。3、倭寇那里不会死，一次不成，可以继续努力，再杀一次。4、千万不要幻想利用什么bug牟利，否则将会受到非常严厉的惩罚。5、另外如果发现有问题请及时报告。6、祝大家国庆节快乐，顺便杀点小日本，表表爱国心。最近小鬼子实在太可气了，good luck for all!!","author":"道全",]),(["time":1065364180,"title":"137","msg":"qkj大家暂时不要去了，等问清楚masterall后再说，以后凡是在qkj死的人不要找我了。（不管是不是bug）","author":"一点红",]),(["time":1065600356,"title":"138","msg":"cloth顺利当选为9月份帮助新手最多的玩家。应cloth的要求，奖励cloth 50w exp, addoil all","author":"一点红",]),(["time":1065686717,"title":"一个重大改动！！","msg":"所有的高级内功加入exert force-shield,真元护体，除taiji-shengong,hunyuan-yiqi,jiuyang-shengong,以及茅山学了necromancy,不能使用之外，其余高级内功都可以使用，效果与jiuyang-shield类似，但效果不如jiuyang-shield好，使用要求：1、内力大点达到40002、基本内功心法等级达到3003、内力小点>内力大点＋1000，也就是体内必须有真气这个shield主要是对气的上限伤害予以防御，如果自己本身防御很强，没有被破上限，就不会体现出效果来，另外尤其需要注意的一点是真元护体的效果存在的必要条件为内力小点要大于内力大点，也就是有所谓的真气，才可以产生效果，如果被对方击中，shield发生作用，则会相应的损失一些内力，这个效果和jiuyang-shield相同，不明白的玩家可以去问问明教的玩家。由于此shield和硬功不冲突，所以硬功的效果到时候会相应的改弱一些，到时候玩家请不要抱怨，如果大家有什么问题，可以及时提出，发现bug请及时报告，这个改动应该会提高所有门派的积极性了。","author":"道全",]),(["time":1065689064,"title":"transfer改动","msg":"加入transfer avf，可以将自己的wlshw换成avf，3wlshw->1 avf,自身avf上限是1000，不会再多，同时全真先天功取消exert zhenqi,玩家tonggui请来向我报到，发现问题请及时汇报。","author":"道全",]),(["time":1065698484,"title":"西藏完成统一大业","msg":"修改了master gelun,  大招寺第二十代主持 葛伦(Master gelun)西藏喇嘛教四个门派的玩家通过特殊途径可以找到他拜他为师，非大招寺弟子要先ask master about 入教，accept以后就统一归入大招寺，然后就可以拜葛伦修习西藏喇嘛教所有武学，拜葛伦的条件主要是220藏传佛法，在布达拉宫有个地方可以读到220，大家自己去找，很容易，非喇嘛派弟子不要轻易寻找葛伦，否则可能会遭杀身之祸。发现问题请及时报告。另外可能要对整个西藏喇嘛的功夫的兼容性进行一些调整，主要还是以龙象般若功 (banruo)为主，建议想尝试西藏的玩家先拜金轮寺。","author":"道全",]),(["time":1065701897,"title":"八识神通的几点改动","msg":"1、bless_sense改为用内力恢复自己的灵力小点，与gouyee的灵神诀类似。2、mercy_sense改为当八识神通高于100级后可自行修炼，但比较难，修炼的进度和玩家的神秘和灵性有关。3、在山庄可以使用shade_sense。","author":"道全",]),(["time":1065763698,"title":"自订装备修改","msg":"在京城棉花坊那里可以继续将原来已经补完的衣服再补上几层，效果还是加armor，因为原来加armor_vs_force有bug，所以还是改成加armor，续补的要求每次要花5点wlshw，以及大把的gold，（现在钱变得有些不值钱了），如果是续补，描述会有所不同，变成如下描述：老板娘从柜台后面拿出一匹金蚕丝来，在「****」上面又添了块布料，说道：好了！所以如果你不想先续补，一定要先看清楚自己补了的衣服的armor是多少，不知道第一次全部补完一件衣服是多少armor的玩家请向老玩家请教，免得造成不必要的损失，玩家发现问题请及时报告。","author":"道全",]),(["time":1065840254,"title":"修正几个bug","msg":"1、乾坤教宝库以后如果不能吃就不能拿仙丹了，如果拿到回自动回到枫林小站。以前利用robot获利的玩家不予追究，但发现bug总知情不报让我监听发现，这样继续下去可以要严厉处罚的。2、朝廷任务修正两处bug，一如果被killer打昏，交钱后仍然可以连接任务的bug修正，感谢玩家alcatel报告，予以10点wlshw奖励。二关于劝架的bug，这个任务等于白送，现在做了一些调整，以后没那么爽了，不要抱怨。","author":"道全",]),(["time":1065881787,"title":"关于兵器谱秘密的一点补充","msg":"1、考虑到这个谜语的确有点长，有点难解，所以最近又给bingqi pu增强了一点功能。简单介绍如下：2、与兵器贩子的相性增长超过1000之后，昏迷状态下有一定几率被兵器贩子救醒。（与七彩宝石戒指功能相似）。","author":"悟饭",]),(["time":1065881877,"title":"关于兵器谱秘密的一点补充","msg":"1、考虑到这个谜语的确有点长，有点难解，所以最近又给bingqi pu增强了一点功能。简单介绍如下：与兵器贩子的相性增长超过1000之后，昏迷状态下有一定几率被兵器贩子救醒。（与七彩宝石戒指功能相似）。相性超过1000之后，同时根据玩家的自身情况和相性高低，在救醒玩家的同时有一定几率兵器贩子对打晕玩家的npc或者player进行比例攻击。相性越高，攻击越强。相性达到5000的时候，玩家被救醒时兵器贩子对敌人的强力攻击可能会使整个战局大逆转。2、有人拿到bingqi pu之后，注意几点：1、因为第一次拿到兵器谱的时候，和兵器贩子的相性（相亲性，姑且这么讲吧，表示和兵器贩子的和谐程度，随着召唤成功的次数而增长）为0，所以召唤出兵器贩子的几率是很低的。耐心等待吧。慢慢成长。成长的速度和福缘与统御有关。随着与兵器贩子的相性的增加，战斗中出现兵器贩子的几率会越来越高。2、只有wear着兵器谱才有可能出现兵器贩子。非战斗状态下也不会出现。召唤成功一次后有一段时间无法召唤，但是这段时间不长，很快就能再召唤了。3、可以使用feel bingqi pu命令来看自己与兵器贩子的相性是多少4、相性超过1000之后开始有机会在unconcious状态被救醒，并且恢复满精神和一定的气。相性更高的时候兵器贩子甚至会在救醒玩家之后对打晕玩家的敌人（包括npc或者player）进行比例攻击，相性越高，扣掉的hp比例越高。5、兵器谱的成长是非常非常缓慢的，如果大家发现相性增长过快，视为bug，请报告。6、本人因为近期面临多项考试，最近不连了，有事情请发在这里或者发到我的信箱ttongcc@163.com谢谢合作","author":"悟饭",]),(["time":1065882565,"title":"一个严正公告","msg":"鉴于目前为止关于仙丹的另外一个bug还没有玩家向我主动自首，我再给一天时间，请利用bug吃仙丹的玩家主动向我报告，予以1000内力大点的惩罚，让我查到又知情不报的，予以去掉一半内力的惩罚。如果想维护好一个游戏，必须形成公平公正的环境，我这么做希望大家可以理解。也请大家自觉一点，不要以为我什么都不知道，我希望大家都能通过正当途径成长，这样起码对那些不知道bug辛辛苦苦成长起来的玩家算是一个公平的交待。最后期限是明晚11：30之前，然后我就要开始处理了，请玩家相互转告，最近没上线的玩家如果看到此news请立即向我报告。","author":"道全",]),(["time":1065885629,"title":"关于xiandan问题的处理","msg":"玩家cdma,coldstar,chenghao,diablo主动报告，扣除1000内力大点，其中chenghao报告了另外一个bug，予以奖励，只扣除500点内力大点，仙丹的间隔时间大家意见不小，还是尊重大家的意见，改为原来的500点心跳，但注意不要吃到假的，假的吃完就是1000点心跳以后才能吃了。感谢大家配合支持我的工作，我也为自己的工作失误为大家造成的影响向全体玩家表示深深的歉意，毕竟我做巫师时间不是太长，肯定有很多欠缺的地方，以及经验的不足，希望大家都能够多一点理解和包容，来帮助我一起维护发展好这个mud，这次的仙丹事件我负主要责任，但也请大家体谅我的苦衷，不得已而为之。","author":"道全",]),(["time":1066040609,"title":"关于增加门派复仇者的通知","msg":"经验值大于8000000的玩家如果杀了一个门派的master，或者一些比较特殊的npc，会随机出现门派复仇者追杀此玩家，复仇者的水平和玩家相当，有点像吴一物，杀死复仇者会得到一定的奖励，但如果被复仇者杀死也就挂了，注意是真死！由于目前是测试阶段，如果玩家不慎被复仇者杀死，可以要求巫师recover，但只限今明两天，以后就靠你自己小心了。另外注意一点复仇者是在你行凶之后间隔一段时间才出现的，而不像以前的厉鬼马上就出来，所以一定要谨慎。江湖中多一点风险，我想可以更加促进大家玩mud的乐趣，如果感觉有什么意见和建议尽早提出来。","author":"道全",]),(["time":1066062828,"title":"几处改动","msg":"1、通过被cttask的killer打昏连续吃仙丹的bug修改(菩提子同)。2、乾坤教幽明游神位置变动，而且会守住入口，想进去必须杀了他。3、门派复仇者最后修改测试完毕，于10月15日正式投入使用，从10月15日起，因此而死亡的任何玩家不得向巫师请求recover。杀死复仇者会随机得到经验，潜能，以及一些物品，甚至wlshw的奖励，但不要想着靠这个来成长，一个复仇者会比你想象得厉害得多的，因此没用绝对的把握不要去招惹是非。4、少林寺道象禅师修改，可以找他打听大还丹的消息，不限门派，但想得到大还丹难度比较大，而且即便得到不能随便吃，有时间限制限制条件和菩提子相同，大还丹可以吃到400force的内力瓶颈，也就是12000但每要一次大还丹就会被扣掉一点wlshw，每吃一次大还丹加的内力随机，如果发现问题请及时报告，注意，内力大点不够8000的千万不要轻易去嗑这东西，否则会死得很惨。","author":"道全",]),(["time":1066112440,"title":"抑止通货膨胀通知","msg":"鉴于目前钱已经不值钱了，特于今日起抑止通货膨胀，主要办法为：接天楼NPC身上出现tenthousand-cash概率调整，厉若海下面的npc身上的ttsh出现概率可能比较低，越往上走越高，虚空的NPC维持原来的不变。以后钱得省着点花，不要太铺张浪费了哦。","author":"道全",]),(["time":1066213315,"title":"加入物品goldencloth","msg":"是目前为止最好的cloth，不能给人，不能auto_load,当穿着时被击打到一定程度的时候就会破损。破损以后就会消失，想穿还得重新弄。比较麻烦哦，但我认为是值得的，呵呵。这个物品需要解密才可以获得，提示：从我最近写的区域入手，仔细看看描述，会有发现。发现bug请及时报告。","author":"道全",]),(["time":1066282183,"title":"关于兵器谱","msg":"现在已经有几个玩家得到了纵横兵器谱了。解迷的速度的确很快，集体的力量就是大啊。呵呵可是，我说过，这个秘密里面还套着秘密，如果大家愿意继续探索也许会有其他收获。good luck","author":"悟饭",]),(["time":1066356960,"title":"加入指令xiulian","msg":"为方便新手快速成长，现加入xiulian指令，战斗经验达到50万，内力大点达到1300，就可以使用修炼指令，help xiulian通过耗费一定的年龄可以将基本force内功心法从101修炼到201，201级以后就不能再修炼了，需要通过其他途径来成长。","author":"道全",]),(["time":1066359051,"title":"加入dushu指令","msg":"继续带给大家好消息，加入指令dushu，可以通过耗费自己的年龄提高自己的读书识字水平，要求如下：1、litearte等级达到150，也就是读完shu4才可以开始使用dushu指令2、内力大点达到25003、战斗经验达到50万4、身上必须同时有shi1,shi2,tushu1,tushu2才可以开始读。5、最多可以读到201，方法与xiulian相同想练新id的可以很快上手了，addoil all!","author":"道全",]),(["time":1066375689,"title":"调整复仇者","msg":"为了防止player为从复仇者那里拿到奖励而故意去杀某些门派的master现在降低杀死复仇者得到的奖励，通常就是几个gold，运气好有个九花丸如果真中六合彩了还是有lighting armor等奖励，但是没有内力奖励了另外调整了复仇者的参数，如果杀的master过多，可能会招致比较凶悍的复仇者那就怪不得别人了。","author":"悟饭",]),(["time":1066633129,"title":"京城药铺进新货了","msg":"先加入九花玉露丸，5gold一个，每次刷新出现数量随机，不要奢望杀死扬中顺等刷新，他死不了的。呵呵。。。以后会根据大家的需要继续进货，想要什么赶紧说，但不要离谱，太爽的东东是不可能卖的。","author":"道全",]),(["time":1066725056,"title":"京城丰有福处修改","msg":"体谅到大家挣钱的难处，特开通另外一种挣钱渠道，exp小于800000年满18岁的玩家可以在他那里work，挣到的钱随机，有可能是1 silver，也没准是1 gold,甚至可能是1 thousand-cash或者1 ttsh每次工作会耗费200点kee，并且有一点busy。有什么意见和建议可以尽管提出来，以期尽早修改。","author":"道全",]),(["time":1066748504,"title":"好久没发新闻了,哈哈,说个更改.","msg":"因为老有人说杀手在不可战斗的房间里面不出来所以现在可以ask killer about 乾坤教就可以让他动动地方了，呵呵。。","author":"晓风残月",]),(["time":1066891003,"title":"复仇者改动","msg":"现在经验不够800万的玩家杀master杀到一定数量也会随机出复仇者但是几率较低。","author":"悟饭",]),(["time":1067269036,"title":"一些公告及改动","msg":"1、渡难那里要到菩提子的概率调整，一般情况下有1/2的机会会成功。2、丰有福那里干活挣钱得到大面值钞票的几率提升。3、西藏喇嘛教加入特殊武器紫金锤，可以zhaohuan护法神物保护自己，同其他门派武器一样，可以在乾坤教获得，使用装备条件相同4、目前整个mud需要比较全面的完善和系统化，希望老玩家有空多写一点相关的帮助，主页上有一些，继续努力，大家感觉哪里有不合理的地方尽早提出来，现在进入整合时期。bow all.。","author":"道全",]),(["time":1067270978,"title":"福州城读千里处修改","msg":"加入一个新活计抄书copy，要求非文盲，exp<800000,抄的时候耗精，可以从1级抄到151，每抄一次会挣一两银子的外快。欢迎众多新手前往打工，老怪物也就免了吧。另外literate >151就不能抄了，钱估计也该挣得七七八八了，不要嚷着没钱买书了。","author":"道全",]),(["time":1067497750,"title":"长期开放杀倭寇的任务","msg":"作为另外一种新手奖励，重新开放杀倭寇的任务，每个人只能杀一次，国庆节杀了的也就不能杀了，有几点改动请注意：奖励取消10点wlshw，杀死倭寇只能得到一件level3的魔法装备（原先是lv5）鉴于很多新手都不大了解这个任务，我做一下介绍，在京城李白处ask li bai about 精忠报国，他会送你去一个地方，将那里的倭寇杀死，割下首级回来交给李白就可以领取奖励。有几点需要注意的是：1、倭寇的水平和玩家自己的水平相当，对于新手来说可能还比较厉害，所以杀的时候拿上最好的装备，带足丸子再去。另外自己的功夫要高点才行。2、倭寇那里即便打不过也不会死，失败后只会到枫林小站。3、李白那里要任务的时候如果之前有人去杀了，就不能去了，需要等待下一次刷新。4、千万不要妄想利用什么bug牟利，否则会招致严厉的惩罚，丑话我说在前面。5、现在的奖励是一件lv3(随机，杀死倭寇即得)，20万exp，10万潜能(给了首级获得)希望这个任务的重新开放会提高大家的积极性，也让每个炎黄子孙都有一点爱国心，勿忘国耻！","author":"道全",]),(["time":1067579104,"title":"tieflag加入一个perform","msg":"tie-steps的perform dodge.twelve <target>使对手busy，效果和多项天赋有关。描述也还不错，铁血十二式嘛，自然变化多点，但效果一样，不会有差异。","author":"道全",]),(["time":1067585201,"title":"乾坤教宝库门派武器修改","msg":"降低了能够得到的概率，如果失败，会损失一部分经验。另外近期可能会对游戏难度做一些调整，先打个招呼，大家做好心理准备，不过会在大家能够接受的范围内。老这么玩的确有点没意思，玩mud还是更加有点追求的好。先说这么多，大家底下可以讨论一下。","author":"道全",]),(["time":1067590240,"title":"关于bracelet,casket的一些改动","msg":"晚月庄拿到的玛瑙手镯bracelet，以及无崖子身上的玛瑙手镯统统改为unique属性，不明白的新手可以请教老玩家，另外降低了bracelet pray start的成功率，山庄得到的bracelet(就是不能给人的那种)成功率高点，也不是unique的。casket持续时间减为20分钟。","author":"道全",]),(["time":1067680156,"title":"兵器谱秘密增加新内容","msg":"兵器谱秘密里面的枝节进一步增加提示一下，不同的拿法可能拿到不同属性的兵器谱最容易拿到的自然效果最差了","author":"悟饭",]),(["time":1067680832,"title":"新兵器新效果","msg":"l pu斩铁剑：盘古死后乘乱捡得，上古神物，吾不敢多言。.....出跸刀：名刀出跸，乃一柄黄杨木雕的弯刀，无鞘，刀身长三尺半，上面雕........        无属性攻击。特殊效果：不知","author":"悟饭",]),(["time":1067680878,"title":"新兵器新效果2","msg":"温柔：原为.......................        无属性攻击。特殊效果：必杀。","author":"悟饭",]),(["time":1067699991,"title":"一点关于兵器的改动","msg":"降低赏善罚恶令的效果，建议玩家还是ji dagger比较好，原来的ling效果太强，把自订装备給废了，这是我的工作失误，在此向大家致歉，也请大家理解这个改动，游戏毕竟需要向合理化发展。BTW:赏善罚恶令只能要一次，丢了就没了，不过无所谓了，拿着玩玩就是。我还是希望纵横的兵器多样化，不要都一个样子，是吧，呵呵～～～","author":"道全",]),(["time":1067706981,"title":"关于加强玩家和巫师守则管理的通告","msg":"help rules加入第八条，请广大玩家自动遵守。从下周起，每周定期在论坛上公布所有巫师call player以及其他相关log，请大家监督，也请所有巫师自动遵守巫师规范。出现问题不要怪我翻脸无情。只有创造公平的环境，这个游戏才会健康的发展。","author":"道全",]),(["time":1067707693,"title":"找宗师xuexi的要求降低","msg":"改为8Mexp特此通知，另外魔域和quest -s今后将不会再出现会易筋经的npc，请放心。","author":"道全",]),(["time":1067709819,"title":"乾坤教宝库改动","msg":"原先从武当钻洞的路径封闭，堂堂江湖大侠总钻洞不好。玩家必须从乾坤教找路进去，里面的npc相对弱了很多，但身上的物品出现是随机的。这也算是加大游戏难度一个方面，至少我认为你们应该能够感到游戏的乐趣。good luck for all!BTW：如果发现自己打不过那些NPC还是找些牛人来杀，效率会高点。","author":"道全",]),(["time":1067782801,"title":"门派武器的一个bug修正","msg":"请利用此bug的玩家自动向巫师报告，惩罚1Mexp，否则杀无赦。","author":"道全",]),(["time":1067784684,"title":"关于暗灵(An ling)bug的处理","msg":"鉴于sunfree,danny,fiy,sweet已经自动承认，给予fiy,sweet减去0.5Mexp的惩罚，以示惩戒。考虑sunfree，danny是新手，严重警告一次。我知道还有别人的玩家利用过这个bug，请主动站出来承认。另外乾坤教宝库关于stone的bug我已经发现，请利用此bug的玩家自动向我报告，惩罚2K内力。逾期不报者杀无赦。出现了这么多bug实在是很抱歉，说明我的工作还有很大的缺陷和漏洞，但请大家注意每次我发news的时候最后都会提到一句发现bug请及时报告，话早说在前面了，所以到时候我处理谁是情理之中的事情，请大家予以谅解。","author":"道全",]),(["time":1067864987,"title":"lighting系列修改","msg":"降低出招不耗内力的效果，有一定的概率才会有此效果。加入wield要求2000内力大点，不过分吧。玩家如果死亡，lighting就会飞掉，拣不回来了。BTW:如果lighting效果出来会有描述，没描述就说明没效果。","author":"道全",]),(["time":1067924948,"title":"good news for newbie","msg":"这几天可能变得东东太多了，让大家有些不爽，很是抱歉，再次感谢大家的支持。由于bracelet比较难拿，flybag的flyup做调整，改为<2Mexp都可以使用，但进魔域和山庄经验值要求增加到2.2M。","author":"道全",]),(["time":1067931419,"title":"几个bug修正","msg":"1、为了有效防止溢出，做了一些改动，还是溢出的也没办法了。耐心等待吧2、朝廷任务和quest -s去掉killer出现在少林寺和星宿海两个区域，尽情的享受任务吧，呵呵。","author":"道全",]),(["time":1067933221,"title":"推出纵横天下II人气宣传奖","msg":"详情请见help xuanchuan_gift,大家努力拉人啊，好处大大的。","author":"道全",]),(["time":1067958141,"title":"180","msg":"近期masterall休息一段时间，管理的任务由我来接手，呵呵。希望大家多多帮忙，有什么好的建议和想法尽管提，正当的均可满足。希望多在论坛上灌水和讨论。（本人水平太差，所以bug问题上我绝不手软）","author":"一点红",]),(["time":1067958203,"title":"181","msg":"近期masterall休息一段时间，管理的任务由我来接手，呵呵。希望大家多多帮忙，有什么好的建议和想法尽 管提，正当的均可满足。希望多在论坛上灌水和讨论。（本人水平太差，所以bug问题上我绝不手软）","author":"一点红",]),(["time":1067997193,"title":"关于茅山的一点改动","msg":"1、特殊武器暗灵取消pray start功能，既然减少了得到bracelet的几率，茅山也就不该有特殊了。2、特殊武器暗灵加入偷mana功能，效果和自己的神秘，灵性，enchant相关3、提高taosword的attack，使茅山砍人成为可能。4、加入召唤时的busy，原来的居然没有busy，对其他门派不公平。","author":"道全",]),(["time":1068006259,"title":"182","msg":"cloth拉人lvyou,奖励减半","author":"一点红",]),(["time":1068013035,"title":"星宿派腐尸毒功加入perform dugong.attract","msg":"可以吸引毒虫来为自己作战，一共有三种毒虫：赤精蜈蚣，青冠巨蟒，碧血寒蚕会随机放毒，攻击对手，最多只能召唤三只，，腐尸毒功等级越高，召唤高等级毒虫的可能性越大毒虫的状态和玩家的状态相当，只能在战斗中使用。使用要求：120腐尸毒功，5000faith，2000内力小点，有神木王鼎在身上。现在拜了无崖子的玩家以后可以通过拜侠客岛的师父来学习这么功夫。","author":"道全",]),(["time":1068040392,"title":"185","msg":"qkj中开过的箱子不要再开，已经强调过了。现在虽然不会死，但是点背的话，也会付出一定代价的说。","author":"一点红",]),(["time":1068048702,"title":"丰有福处干活涨工资了！！！","msg":"随机的，但比以前多多了，欢迎广大新手前往刨钱。","author":"道全",]),(["time":1068050220,"title":"another good news","msg":"bracelet的改动对玩家影响比较大，因此采取一个相对折衷的办法。取消原来晚月bracelet的unique属性。所有的bracelet必须装备之后才可以使用。（山庄的也不例外，这原来就是一个bug）无崖子身上出现bracelet的概率调整为1/5.good luck for all.","author":"道全",]),(["time":1068090327,"title":"隐退两个月","msg":"最近因为马上要考试，无法分太多时间写东西了masterall让我改进一下武器装备系统，最近实在无法抽时间来做完，实在抱歉不过两个月后我还是很愿意来继续把这个系统完成，现在先把我的一些想法贴在了论坛上，大家可以抽空去看一看，发表一下意见","author":"悟饭",]),(["time":1068115548,"title":"增加新手基本成长途径","msg":"考虑到乾坤教的书比较难拿，又不能给人，现增加新的锻炼skills的途径，可以锻炼的skills有:force,sword,parry,dodge。级别可以从180->201，分别在四个不同的地方，需要通过不同的方式来成长。提示：以前曾经有过相关的成长途径，现在在这个基础上修改，适应于所有门派。个别的地方可能还会有一点点危险，新手请小心。最先把所有的成长方式探明并且第一时间在论坛上公布的玩家奖励10点wlshw。大家赶紧找啊，呵呵。","author":"道全",]),(["time":1068316213,"title":"关于门派特殊武器修改通知","msg":"门派特殊武器改动1、乾坤教宝库里look box有提示2、所有武器均改为adv_weapon,属性同blood sword,si以及魔法装备。3、所有武器增加的属性全部减为20点。4、华山取消木剑，玄铁重剑，保留紫薇软剑(提高破上限效果)5、古墓派增加玄铁重剑(效果：和对方对耗内力)6、武当派真武剑取消lighting效果，改为对有邪气的对手伤害提高，如果对方有正气，自己反受伤害7、少林取消黑索8、原先所有的门派特殊武器全部取消，玩家必须自己去寻找。9、第一次得到门派武器会得到很高的奖励。10、目前还处在一个调整测试期间，发现bug请大家及时报告。11、上侠客岛增加一个条件：必须得到门派特殊武器。12、门派特殊武器只有自己只身前往才能得到，利用bug或者企图利用bug的会受到严厉惩罚。忙了好久，终于搞完了，sweat.good luck for all!。","author":"道全",]),(["time":1068380289,"title":"191","msg":"关于明教和lama合并的skills不能使用的问题已修改，但是80必须用banruo支持.","author":"一点红",]),(["time":1068392427,"title":"一些修改","msg":"1、考虑到玩家成长的问题，将上侠客岛的条件改为原先设置状态，得到门派特殊武器只会在侠客岛拜师的时候做要求。2、一些门派特殊武器效果修改，详情见help special_weapon3、得到门派特殊武器出去的办法就是在那里吼一嗓子，具体用什么指令不用我说了吧。4、乾坤教宝库那里如果先前有人翻了箱子不知情者再去翻同样的一个箱子，很可能会导致直接死亡，请大家一定要等刷新再去，我在这里特别申明一下，今后如果还有玩家因此丧命一概不恢复档案，这个问题不属于bug，只是一个trap而已。","author":"道全",]),(["time":1068393442,"title":"京城李白处bug修正","msg":"以前曾经有人利用此bug背着人去杀倭寇攒lv3，现将此bug修正，再敢用这个bug的就是一个字“死”，不怕的可以去试试。用过此bug的玩家请向我报告，惩罚主id 200000exp，以示惩戒。BTW:大家不要以为用了什么bug偷偷摸摸不吭气我就不知道，有些问题还是要早点汇报的好省得到时候抱怨我处理的手重！","author":"道全",]),(["time":1068452897,"title":"194","msg":"以后凡是借领取奖励的机会在我家存档的，一经发现全部purge","author":"一点红",]),(["time":1068456340,"title":"一些门派特殊武器修改","msg":"1、真武剑效果改为对有邪气的对手造成伤害，对正气小于自己的对手双方同时受伤（不严重）对正气高于自己的自己则会受重伤。2、紫薇软剑增加效果及描述，可以随机破上限，伤精或者神，甚至破内力，以及减弱对方的attack效果出现要求：激发sword为独孤九剑，sword,force,strike,whip,spear,blade,throwing250级。3、玉竹杖效果改为降对方的防御，dodge，parry。4、少林特殊武器的效果等待通知请大家耐心点。","author":"道全",]),(["time":1068511097,"title":"recover 记录","msg":"恢复coldstar因为cttask非正常死亡的","author":"悟饭",]),(["time":1068532996,"title":"接天楼龙象，不知火舞修改","msg":"提高出现lv7的几率，运气好的可以杀到，呵呵addoil for all!","author":"道全",]),(["time":1068538202,"title":"挖宝系统更新","msg":"1、取消了原先exp 6.4M的上限，现在无上限2、增加特殊奖励天赋：平衡，身法，定力，胆识，悟性，魅力，灵性，福缘最大可以挖到40点悟性可到1003、特殊奖励avf最大可到1000，由于我测试不太方便，请大家积极帮我测试，有问题请报告。","author":"道全",]),(["time":1068601842,"title":"挖宝系统奖励物品全部更新","msg":"特等奖：天赋福缘，灵性，定力，胆识，悟性，容貌，平衡，身法（上限50，悟性为100）一等奖：灵葫仙丹二等奖：lighting sword，lighting glove，极品迷幻巾纶三等奖：菩提子，人参果。四等奖：配天仙玉露的四样药材，全真蜂王蜜，峨嵋人参，养精丸，还神丹（后四样物品属性都已经修改）欢迎大家继续来寻宝，奖励天天有，惊喜日日现！","author":"道全",]),(["time":1068608187,"title":"一些飞行项目修改","msg":"为了保证挖宝对于所有门派的公平性，对一些飞行项目做了限制，八识神通，九阴神功，exert dujiang，在挖宝的时候都不能使用。另外bracelet和casket也禁止在挖宝时使用。这些改动可能会触及到一些玩家的利益，但为了整个游戏长远打算，希望大家能够予以理解。bow all！","author":"道全",]),(["time":1068725422,"title":"加入指令age2mana,age2atman","msg":"效果同age2force，要求150点法力或者灵力，40级spells或者magic。最大上限可以修炼到4000。每次修炼增加的灵力和法力点数有一定的随机性，但和自己后天的灵性和神秘有关。","author":"道全",]),(["time":1068797353,"title":"几点修改","msg":"1、丰有福干活处取消，防止过多dummy影响系统速度，请大家谅解。2、接天楼NPC身上恢复以前的1 ttsh per npc。3、武当太极剑ninth取消独孤九剑的限制。4、无崖子身上bracelet出现概率提高到1/25、没了,无言………………","author":"道全",]),(["time":1068827232,"title":"几点修改","msg":"1、bracelet使用成功率提高。2、stormdance描述颜色加为粉红色。3、essence-sword的perform tisha可以由enforce控制，enforce>100可以busy对手，但对手一定要是男性。4、少林铁罗汉加入特殊效果可以自动解毒，但有些毒还是不能解的，哪些能解哪些不能解自己去尝试一下就知道了。每次解毒会出一定的描述，而且使用者会损失500内力，切记。","author":"道全",]),(["time":1068913084,"title":"加入当街行凶之倭寇","msg":"随机会出现几个小日本出现在全国各地，见人就杀，遭到杀害的npc会向全体玩家报告。倭寇可能很强，也可能很面，只有杀比自己exp高的倭寇才会得到奖励。奖励和自己先天福缘相关。杀之前最好先看看倭寇再说，不要轻易开杀，很可能遭到杀身之祸。有问题请及时报告。","author":"道全",]),(["time":1068914618,"title":"倭寇修改一点","msg":"每次刷新随机出现一到两只倭寇，任何人杀都可以获得奖励。奖励提高，并增加武林声望的奖励。倭寇不会在不能战斗的地方杀人，请大家放心。","author":"道全",]),(["time":1069091976,"title":"茅山道术cast invocation修改","msg":"可以一次性召唤出N个怪物位自己作战。N=茅山道术等级/50+1每召唤一个怪物就减自己100法力，60的神，召唤后的busy数为怪物数N其实基本设定与步玄七诀的perform dodge.mirror同，不同在于步玄的mirror不会被对手charge，而invocation则可以被对手charge。有问题请报告。","author":"道全",]),(["time":1069176062,"title":"一个好消息","msg":"考虑到中期玩家成长相对比较困难，现将quest -s中出现quest的任务几率降低了一半，但还是有可能会出现，但已经比以前好多了。addoil all!","author":"道全",]),(["time":1069210557,"title":" 正气溢出问题解决","msg":"设置上限为21亿，不会再多了。正气高于此数值的玩家请找在线巫师修改到21亿，如若隐瞒不报出现其他任何后果自负。以前曾经溢出的玩家可以找在线巫师修改到上限值。","author":"道全",]),(["time":1069240944,"title":"接天楼NPC龙象不知火舞相对削弱","msg":"注意只是相对，被一招杀的可能性还是有的。但总算提高了点胜率。addoil!","author":"道全",]),(["time":1069315439,"title":"几个通知","msg":"1、玩家shuang，daxia做为本站做广告，符合help xuanchuan_gift第一款，特各奖励金蚕王5颗，以资奖励。2、挖宝的一个重大修改：今后得到的特殊奖励不会再出现0点，至少有1点，如果再出现此问题请及时报告。","author":"道全",]),(["time":1069421361,"title":"朝廷任务中的三个任务修改","msg":"规劝，废武，活捉现改为不能将killer打死，如果打死，killer会自动苏醒，发起更加凶猛的反击，大家小心为妙，最好一次成功，不然就越搞越难搞了，呵呵。有问题请及时报告。","author":"道全",]),(["time":1069429031,"title":"朝廷任务改动","msg":"当连续完成朝廷任务达到100以上时，福缘足够高的玩家有可能得到一些特殊物品：目前开放的有四种：1、大内密宝之－龙髓凤骨丸（增加先天定力，胆识，悟性，统御）上限50,50,100,50.2、大内密宝之－九转凝香丹（增加先天容貌，身法，减一岁年龄）上限50,50,年龄下限16岁。3、大内密宝之－七彩宝石戒指（不同于山庄无崖子的）非unique物品，但只能解毒和从昏迷中苏醒，无法疗伤。4、玄机箱子（留点神秘给你们吧，反正是好东西。）如果有谁发现问题请及时汇报。good luck for all!。","author":"道全",]),(["time":1069665383,"title":"兵器谱set no_get","msg":"兵器谱设置no_get属性","author":"悟饭",]),(["time":1069665687,"title":"京城售卖的丸子修改","msg":"以前居然可以pawn，没一个玩家报告，很让我ft。现改为不可典当，加入存在时间为15分钟，购买之后15分钟内不用掉自动消失，没有描述。但京城的丸子颜色会和其他地方搞来的稍有不同，以做区别。希望这样事情今后不会再次发生。","author":"道全",]),(["time":1069690125,"title":"步玄派mirror的bug修正","msg":"以前如果mirror的兵器被搞飞了，脱离战斗状态后玩家自己的damage会减少，先将此bug修正，如果大家还发现有问题请及时报告。sweat!","author":"道全",]),(["time":1069730904,"title":"关于复仇者","msg":"复仇者会破壳的功夫，以前大家不知道吧。这里提醒一下。有壳的对复仇者也不要掉以轻心啊。","author":"悟饭",]),(["time":1069732916,"title":"应大家要求兵器贩子进行一个小改动","msg":"以后兵器贩子不幸死亡之后，玩家和他的相性会有小小的降低...","author":"悟饭",]),(["time":1069760476,"title":"增加新手礼物","msg":"出村，exp在5万到50万之间的玩家可以在长安广场姬良那里ask ji liang about gift或者ask ji liang about 礼物，领取新手礼物，奖励随机，为exp，qn，或者faith，wlshw，或者两种天赋组合。每个人只能领一次，而且只能享受自己领到的礼物，发现问题请及时报告。good luck for all!","author":"道全",]),(["time":1069834046,"title":"revenger","msg":"revenger加强了一点（主要是内力和气涨了）另外加强了破壳功能另外还加了一些说话的动作","author":"悟饭",]),(["time":1069912991,"title":"加入门派叛徒","msg":"现在加入一个新随机npc：门派叛徒各门派会随机出一些叛徒，而且这些叛徒都是学完了本门武功的有的甚至青出于兰胜于兰，非常厉害尤其是会一种特殊的真气决，十分厉害叛徒杀了师父并且不断的残害本门同胞但是对本门经验低于叛徒的玩家，他不会主动攻击大侠们可以伸张正义，铲除这些叛徒，并且会得到一定的奖励","author":"悟饭",]),(["time":1069914319,"title":"加入resetgift指令","msg":"参见help resetgift重新设置完之后要去姬良那里走一趟到时候会有提示，出现问题请及时报告。","author":"道全",]),(["time":1069931091,"title":"加入恐怖的………………","msg":"现在大内也有叛徒横行了！据说是乾坤教派道大内的奸细，伺机要杀死大元帅奸细会用计谋把大元帅骗到随机的一个地点，然后杀他。幸好大元帅也不赖，功夫也不差，气也不短，两人激斗之余，大元帅还会呼救大家只要帮他把奸细杀了，他就自然回元帅府了。这个点子毒吧。别扔石头啊，不是我的主意","author":"悟饭",]),(["time":1070030926,"title":"少林醉棍加入perform staff.zuida『八仙醉打』","msg":"顾名思义，必须喝酒才能用了，喝到什么程度自己去感受吧。注意的一点是如果在perform中把对方灭掉，自己也会醉昏。使用要求：激发staff，parry为少林醉棍，使用混元一气作内功。少林醉棍200级。顺便提及的是喝得越多，此perform威力越大。有问题请及时报告。忘了说的是少林弟子以后如果带着酒气回寺会蹲监狱的，切记！","author":"道全",]),(["time":1070178498,"title":"门派叛徒和大内奸细已经调整完毕","msg":"叛徒有的是面瓜，有的是牛人，大家出手之前小心的看看再说大致可以从他/她的师父水平看出一二。除非的确bug导致死亡，今后一般情况下再被叛徒和奸细杀了不能恢复了。","author":"悟饭",]),(["time":1070280957,"title":"山庄，魔域修正一个bug","msg":"不可以再用九阴神功exert fly了。以前居然都没人吱声，让我也很faint。关于force-shield的问题我一会修正，请利用过这个bug牟利的玩家自觉向我报告，惩罚20万exp，5万潜能，另外会给报告此bug的玩家40万exp，10万潜能的奖励。","author":"道全",]),(["time":1070282769,"title":"关于shield的bug修复","msg":"jiuyang-shield,force-shield,manashield如果被打破，也就是被对方击破失去效果后不能再次使用。必须relogin才可以重新使用。由于本人的工作失误这个bug一直长期存在，我在此向大家致以深深的歉意，感谢报告此bug的玩家。","author":"道全",]),(["time":1070331490,"title":"玄铁剑法加入perform sword.billow","msg":"「怒海狂涛」也就是连招了，但是要注意几个问题：1、连招数目和玩家的胆识，自己和对手内力小点之比有关。2、连招的伤害力和自己与对方的内功有效等级有关。刚刚写完，请能用的玩家帮忙测试一下，有问题请报告。","author":"道全",]),(["time":1070419456,"title":"zhxx升任app","msg":"请大家多监督、支持和帮助他的工作。老前辈的说，呵呵。","author":"道全",]),(["time":1070544102,"title":"229","msg":"fiy拉新手shuang,符合人气宣传奖第二条,奖励 五十万经验值,二十万潜能，十点武林声望，dodge提升10级","author":"一点红",]),(["time":1070551352,"title":"230","msg":"tonggui 举报bug,因为已经用了一段时间,所以不给予奖励,也不惩罚了","author":"一点红",]),(["time":1070613465,"title":"惩罚玩家tonggui 1.5M战斗经验","msg":"[原因]：发现bug知情不报，利用之后才报告。[惩罚力度]：利用bug获益*2附注：我再公布一点：1、发现可以牟利的bug立即报告的将会得到高额奖励。2、发现bug自己牟利之后再报告的予以利用牟的利益*2的处罚3、发现bug利用而且知情不报的一经发现予以牟利*5的处罚4、发现bug不但牟利知情不报，而且四处散布的予以purge账号的处罚5、向巫师检举别人利用bug的玩家也会予以一定程度的奖励。特此公告，请大家引以为鉴。不要把利用bug当成顺理成章的事情，这个惩罚力度已经很轻了。大家多自觉点，我们的工作也好做点，这个游戏也能更完善点。最重要的一点：凡是利用bug的都要严惩。纵容姑息就会毁了这个游戏。","author":"道全",]),(["time":1070614417,"title":"泰山去掉盟主，赏善使者，罚恶使者","msg":"可以避免一堆bug的出现。同时茅山拜张天师取消对武林盟主的要求。","author":"道全",]),(["time":1070647223,"title":"232","msg":"","author":"一点红",]),(["time":1070647541,"title":"234","msg":"根据投票多少，得出评选结果,有意见可以在论坛上提出:特等奖一名: chenghao(chenghao)   《朝廷任务帮助》系列一等奖两名:cloth(fanny)         《武当剑派（武当－华山）完全帮助》　             coldstar(coldstar)   《朝廷任务之明教篇》二等奖三名:long(naga)           《写一篇关于死亡的回忆，以警后人，以谢前辈》                  jansen(jansen)       《纵横兵器谱的取得方法》　                  krelian(starsren)    《逍遥新手经验（for真正的新手）》一、二　三等奖五名:littlestone(littlestone) 《我也曾醉过也为你哭过－－我的mud人生》　           sunfree(sunfree)     《茅山的一些我的经验》　               windmoon(beanbean)   《喇嘛指南征求意见稿（before 12.8m)》               rob(danny)           《铁血大旗门前期成长经验漫谈》              laurent(dam)         《太监前期上手指南》　其余为鼓励奖,其中有一部分是个人意见!","author":"一点红",]),(["time":1070866612,"title":"乾坤教功夫一些调整","msg":"1、spicyclaw特殊效果中破kee上限的效果和自己enforce相关，另外还加入了破精神的效果，和自己的enchant相关。2、摧心掌加入特殊效果破对方enforce和内力。效果和对方的enforce以及自己的enforce相关。3、提高了封山剑法的parry系数到1.2另外perform counterattack的busy时间加长。4、桃花内功的exert bhcs效果加强，所耗内力减为500点。由于没有进行完整的测试，近期可能还会有一些调整。发现问题请大家及时报告。以后乾坤教的人可不好惹了，呵呵。","author":"道全",]),(["time":1071131370,"title":"good news for newbie","msg":"新手村小青年修改，可以ask yong about 天赋，将自己隐藏天赋中不足20的天赋调到20，>=20的天赋保留不变。一个id终身只能修改一次。以后新手选人应该不用那么痛苦了。发现问题请及时报告。","author":"道全",]),(["time":1071131766,"title":"全真和古墓空手功夫调整","msg":"九阴神功支持一阳指。一阳指可以和黯然销魂掌互备。","author":"道全",]),(["time":1071132616,"title":"步玄派加入空手功夫穿云指","msg":"从纵横I偷来的，没啥可说的了，呵呵escape~~~~~~不过可能会根据zh2的情况再调整一下。","author":"道全",]),(["time":1071216487,"title":"天邪神功加入exert summon","msg":"可在战斗中召唤灵兽为自己作战。灵兽一共有三种，啸天犬，天邪虎，火麒麟随celestial等级提升出现高级别灵兽的概率。灵兽的水平和玩家自己想当，越高级越强。但没有特殊攻击效果。最多可以召唤3只。需要至少200celestial和一定faith。发现问题请及时报告。","author":"道全",]),(["time":1071217645,"title":"八识神通，九阴神功修改","msg":"禁止飞向一个玩家。防止很多bug的出现，以及pk等等，对不能飞的门派相对公平些。","author":"道全",]),(["time":1071747798,"title":"删除巫师帐号dvunix","msg":"快一个月都没见人，什么都没干，开除出巫师队伍。另外请所有的新老巫师都警醒一下，如果不是真的特别忙，最好不要一天到晚无所事事。我最近忙于考试，来的不多，请相关巫师负责管理日常事务。","author":"道全",]),(["time":1071802301,"title":"整风运动","msg":"最近发现游戏里风气不太好，很多玩家和巫师采用比较XX的nick或者dummy帐号，请相关人等自觉suicide掉这样的dummy，把nick改回去，让我再发现严惩不贷，也请巫师以身作则，净化这里的环境。另外平时大家聊天什么的注意自己的言语，不得有任何针对别人的脏话，一经发现并且被人记录log，直接purge其所有id，绝不宽容。切切。","author":"道全",]),(["time":1071835973,"title":"开始发放圣诞礼物","msg":"在京城广场有棵圣诞树，你们自己研究吧。我要特别提示的有几点：1、领到什么样的礼物很大程度上取决于玩家的dodge高低。dodge越高越高，400的最好，呵呵。2、每个人只限领一个，而且只能使用自己领到的。3、不要有任何妄想利用bug的企图，否则会死得很惨，不信就试试看。4、此礼物发放至2004年1月2日结束。最后祝大家圣诞快乐，happy,happy and happy.","author":"道全",]),(["time":1072147001,"title":"关于飞行包的修改","msg":"这是一个历史问题，由于bra已经恢复成和以前一样，飞行包还是改成只能使用到80万经验，同时魔域和山庄进入条件降回原来的100万经验。可能有一些玩家在这个时期利用飞行包成长的很快，只能说是历史问题了，勿怨。","author":"道全",]),(["time":1072315691,"title":"玄铁剑法perform的大bug修正","msg":"相关人等予以封禁perform三天思过的处罚。","author":"道全",]),(["time":1072317135,"title":"关于此次bug的惩罚处理","msg":"始作俑者tonggui惩罚1/10的exp，以示惩戒。其他相关玩家免于处罚，但请大家引以为戒。tonggui是老玩家我不多说什么了，自己反思吧。","author":"道全",]),(["time":1072333798,"title":"九阳神功加入阴阳之盾","msg":"九阳神功等级大于300之后，在使用jiuyang-shield的时候会随机出现阴阳之盾，可以帮助玩家防止kee的小点的伤害，九阳神功等级越高，阴阳之盾出现概率也就越高，防御效果也就越好。机理与jiuyang-shield,force-shield同，也是通过内力来防止受到的伤害。在防止受到伤害的同时，会损失一部分内力，当内力为零时，阴阳之盾自动消失。目前出在测试阶段，有问题请及时报告。","author":"道全",]),(["time":1072405601,"title":"关于接天楼NPC邪气调整以及相关NPC调整通知","msg":"接天楼以及山庄所有NPC的邪气统一改为固定数值，不再随玩家正气变化。NPC丹玛邪气降低，适当增加武当初期难度。杀出正气了也就杀了，没杀的认倒霉，以后自己慢慢攒。此项问题绝对不可更改，请相关玩家不要再有异议。如果新手觉得武当起步难，建议换个好练些的门派。","author":"道全",]),(["time":1072418289,"title":"少林混元一气功修改","msg":"只要杀人数>0就不能学了，也不能research，找地方降杀人数吧。","author":"道全",]),(["time":1072426923,"title":"关于唐门的一些修改","msg":"今后唐门弟子只可以给本派门人解毒，不再义务为其他门派提供服务。同时唐门无影毒对有少林或者武当的壳的对手效果加强少林的铁罗汉对唐门无影毒的解毒效果消除。","author":"道全",]),(["time":1072438938,"title":"唐门修改最终方案","msg":"鉴于大家对唐门的解毒意见很大，我采取一个折衷的方案解毒还是可以解的，但是有条件。必须有真气，也就是内力小点要高于内力大点200以上，每解一次耗费200内力，不管对方是不是中毒，只要你开始运功，就会耗费内力，你要是有足够的丸子养着小米就那么解吧，我也不说什么了。","author":"道全",]),(["time":1072439485,"title":"飞行包修改","msg":"patit不再需要消耗食物，很多新手身上装着一堆大饼经常造成新手礼物领不到但是要是让自己饿着，还是不能patit的。","author":"道全",]),(["time":1072534241,"title":"253","msg":"雪蛤蟆解毒次数太少，可用性不高，改为可以使用5次。","author":"一点红",]),(["time":1072687453,"title":"夫妻互学修改","msg":"指令修改为huxue，防止使用xuexi和从宗师那里学功夫冲突。夫妻互学增加条件学习者的经验值不能大于自己伴侣的2倍。防止功立婚姻的出现。BTW：大光明还是会改的，时间定在2月10日。到时候不要抱怨。","author":"道全",]),(["time":1072861767,"title":"新年快乐！","msg":"辞旧迎新之际，我代表纵横天下全体巫师祝各位玩家新年快乐！感谢大家一年来对这个游戏的关注，支持和投入。新的开始，新的起点，新的心情，新的生活，当然别忘了老的游戏，老的朋友。今晚和明天全天开放倭寇身上的玄天秘笈。有1/3的概率会出现，新老玩家都会获益。good luck and Happy New Year for all!","author":"道全",]),(["time":1072869162,"title":"开放生日礼物奖励","msg":"详情参加help birthday.","author":"道全",]),(["time":1072929104,"title":"essence-sword的perform tisha bug修正","msg":"居然可以空手使用，比较让人faint，玩家windmoon利用此bug牟利并未报告，也并未宣传，予以3天封禁perform的处罚，希望光大玩家引以为戒。BTW：处罚会越来越重的，不信就试试看。","author":"道全",]),(["time":1072930141,"title":"加强法制化建设","msg":"监狱做了一些调整，在监狱服刑的玩家wiz不能再summon了，另外给wiz也弄了监狱，哪位巫师违规也进去蹲会。我都不敢进去，进去我都出不来，呵呵。","author":"道全",]),(["time":1072969550,"title":"最佳新手投票进行第二轮","msg":"经巫师组协商一致决定，因为有人使用马甲进行投票，取消其中一人的被选举权，剩下的两位玩家票数一致，进行第二轮选举，详见论坛。马甲id：moyini，于今日注册。谁在里面捣鬼我就不说了，相关人等反思吧。BTW：以后选举请在论坛上标注自己在游戏中的主id，否则选票无效。","author":"道全",]),(["time":1073053735,"title":"关于这次最佳新手选举的说明","msg":"1、给rcon平反，论坛上的id：moyini已经有人来认领，和其无关。上个月的最佳新手rcon领一份，作为一点精神补偿，已经在第二轮胜出的laurent也照发。2、以后的选举每位玩家只能投一票，而且要在投票的同时在下面跟贴，说明自己在游戏中的主id，对所有人一视同仁，新老玩家一样。否则投票无效，屡禁不止的封杀论坛id。3、此次事件我个人负有一定责任，选举制度还不够完善，请相关玩家谅解。最后送给大家的话，“不经历风雨，怎么见彩虹。”","author":"道全",]),(["time":1073443610,"title":"look指令修改","msg":"鉴于现在整个游戏玩家攻防指数相比以前有了很大提高，原先的look看到的描述：武功看起来好象××××，出手似乎××。已经不在适应现在的新的形势。现在将这两个描述出现级别的要求做了调整。武功看起来好象××××，提升到原来的3倍要求。出手似乎××，提升到原来的2倍要求。打个比方说，原来可能2Mexp，enforce 100,damage 100就看到是深不可测，出手极重了。现在则至少6Mexp，enforce 200,damage 200才有可能看到的是这样的描述。由于整个look描述要求上调，看着比较面的NPC还是会相当厉害，请新手小心为妙。","author":"道全",]),(["time":1073540709,"title":"侠客岛内洞开放新功能","msg":"地点：侠客岛后山内洞作用：可以在那里闭关修炼，无限制提高自己的内功心法(force)等级。指令：anneal要求：1.武林声望>100, 2.战斗经验>40m, 3.8000永久内力, 4.400级内功心法说明：1、每次闭关修炼时间为1个小时，在里面老老实实呆着，什么都干不了，甚至不能quit。2、每次闭关修炼完成后提高一级force等级，但相应减去100wlshw，和50万战斗经验。3、闭关修炼可以无限制的提高force等级，如果你有足够的exp和wlshw。4、侠客岛内洞处不能战斗，也不会死，场景属性同枫林客栈，想去修炼的玩家可以放心前往。5、由于今后force等级可以无限制提高，能够practice force的武功，例如yin-gong等等，限制能够practice到的最高级别为380级。6、此功能刚刚开放，可能还会做一些调整和改动，发现问题请大家立即报告。","author":"道全",]),(["time":1075189041,"title":"玄机箱子多增加一个按钮","msg":"对自己内功修为,福缘,和人品没有信心的玩家不要随便按,不过如果成功了好处还是大大的,呵呵。","author":"道全",]),(["time":1076165963,"title":"说几个事情","author":"道全","msg":"1、奖励玩家qdlinux生日礼物第四款，所有天赋增加3点，算是迟到的祝福吧。2、假期在家闲暇无事有了很多关于纵横II今后的发展想法，需要在职的巫师与我通力合作，请各位巫师速与我联系。3、最近游戏中如果出现什么bug还请知情的玩家尽快报告，不要等到我处理的时候叫屈。4、关于开发五行系统的想法届时我会在论坛上谈谈，请广大玩家密切关注。5、京城的圣诞树发放的礼物从今天起取消，今后该发的时候还会再发的。昨天才回的北京，在这里给大家拜个晚年，呵呵，享受游戏，享受生活。----Masterall",]),(["time":1076171077,"title":"乾坤教回风拂柳剑加入perform sword.heji","msg":"刀剑合击要求：200级回风拂柳剑fuliu-jian和200级雁行刀yanxing-dao,效果：会很大程度上提升攻击的命中率和攻击速度，其威力堪比wind-sword。另外提高了一点fuliu-jian本身的攻击速度。攻击效果在使用perform之后会在剑招中夹杂雁行刀的刀法，从而使攻击速度得到极大提升。相关NPC的skill已经做了改动，发现问题请尽快报告。","author":"道全",]),(["time":1076210111,"title":"江湖传说","author":"道全","msg":"乾坤教峨嵋分舵秘密研制出了绝迹江湖多年的霹雳雷火弹，限乾坤教和天邪派弟子使用，威力非同小可。有暗器手法和邪气要求。",]),(["time":1076214032,"title":"朝廷人物救人质bug修正","msg":"这么久了居然都没人告诉我，这回要开始严厉处罚。请每个利用此bug的玩家主动向我承认，惩罚100万exp，拒不承认的封perform 10天。使用bug方式，drop ren zhi命令改成drop zhi,这样就省去了等待人质苏醒的时间，就会出现人质感谢带他回朝的信息就可以回去交任务了。给所有使用此bug玩家的忠告，自觉点承认好。以前有利用bug牟利记录在案的玩家惩罚加倍。","author":"道全",]),}),"location":"/d/wizard/newsroom","id":"newsboard","board_id":"news_b","name":"[1;33m新闻发布中心[2;37;0m",])
