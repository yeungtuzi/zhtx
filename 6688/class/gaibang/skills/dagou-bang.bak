int practice_skill(object me)
{
	object weapon;

	if (!objectp(weapon = me->query_temp("weapon"))
	|| (string)weapon->query("skill_type") != "staff")
		return notify_fail("你使用的武器不对。\n");
	if ((int)me->query("kee") < 50)
		return notify_fail("你的体力不够练打狗棒法。\n");
	me->receive_damage("kee", 40);
	return 1;
}

string perform_action_file(string action)
{
	return __DIR__"dagou-bang/" + action;
}

string *parry_msg = ({
        "却见$n倏地伸出$v，棒头搭在$N的$w腰里，轻轻向下按落，正是打狗棒法中一招「压肩狗背」的精妙招数，力道恰到好处，竟将$w压住。\n",
        "只见$n$v疾翻，搭在$w离头尺许之处，顺势向外牵引，$N只感$w似欲脱手飞出。\n",
	"$n右手食中二指倏取$N的双目，同时左足翻起，已将$w压住，正是一招「獒口夺杖」。\n",
	
});

string *unarmed_parry_msg = ({
        "$n猛击$N的面门，逼得$N中途撤回$w。\n",
        "$n以守为攻，猛击$N的手腕。\n",
        "$n左手轻轻一托$N$w，引偏了$N$w。\n",
        "$n脚走阴阳，攻$N之必救。\n",
        "$n左拳击下，右拳自保，将$N封于尺外。\n",
        "$n双拳齐出，$N的功势入泥牛入海，消失得无影无踪。\n",
});

string query_parry_msg(object weapon)
{
        if( weapon )
                return parry_msg[random(sizeof(parry_msg))];
        else
                return unarmed_parry_msg[random(sizeof(unarmed_parry_msg))];
}

mapping enable_req() {

        return( ([
                "force":"huntian-qigong",
                "dodge":"xiaoyaoyou",
        ]) );

}

mapping level_req(int level) {

        return( ([
                "huntian-qigong":10,
                "xiaoyaoyou":30,
        ]) );
}

int query_faith_req(int skill) {
        return skill*14+10;
}

string query_force_type() {
        return("佛家内功");
}

mapping query_action(object me, object weapon)
{
        int i, level;
	mapping ac;
	object *enemys;
	
        level   = (int) me->query_skill("dagou-bang",1);
        ac= ([
		"action": "$N眼中射出一道青芒，手中$w使出「天下无狗」，分取$n的周身各处大穴",
		"dodge":-20,
		"parry":-10,
		"attack":30,
		"force":  200,
		"damage": 200,
		"undodgeable":20,
		"attack_array":1,
		"unparryable":20,		
		"damage_type": "挫伤"
	    ]);
	    
        	if (random(me->query_skill("staff")) > 200 &&
	    		me->query_skill("force") > 60 &&
	    		me->query("force") > 500 &&
	    		weapon->query_weight() < 3000  &&
	    		weapon->query("weapon_prop/damage") > 50 && 
	    		(string) weapon->query("skill_type")== "staff" ) 
	    		{
				if(!wizardp(me))
					me->add("force", -500);
				CHANNEL_D->do_channel(me,"sys",sprintf("ok"));
        			enemys = me->query_enemy();
        			me->clean_up_enemy();
        			me->reset_action();
				if(sizeof(enemys)>1)
				{
					for(i=0;i<sizeof(enemys);i++)
				  	{
				  		if(living(enemys[i]))
							COMBAT_D->do_attack(me,enemys[i],me->query_temp("weapon"),ac);
						else continue;
					  }	
				}
			}
        for(i = sizeof(action); i > 0; i--)
                if(level > action[i-1]["lvl"])
                        return action[NewRandom(i, 20, level/5)];
}
