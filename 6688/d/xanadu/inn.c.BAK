inherit "/std/room/doom.c";

void create()
{
	set("short", "枫林小栈");
	set("long", @LONG
	这是枫林渡口旁边的一个小酒家，破烂的酒旗在北风中飞舞。自从幽明
山庄的凶讯传扬开去之后，这里就变得非常冷清了。只有要去幽明山庄探明究竟
的人才会在这里喝点酒，壮一壮胆，攒足精神。
LONG
	);

	set("valid_start_room",1);
	set("sleep_room",1);
	set("no_fight",1);
	set("no_poison",1);
	set("no_magic",1);
	set("exits", ([ /* sizeof() == 2 */
	  "north" : __DIR__"dukou",
	  "southeast" : __DIR__"lianhuanwu",
	]));                                     
/*
	set("objects", ([
			__DIR__"npc/yuwenxiu" : 1,
		])
	);
*/
