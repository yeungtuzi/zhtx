#/std/bboard.c
dbase (["long":"这是一个特殊的留言板供巫师报告自己的工作进度。","location":"/d/wiz/jobroom","id":"job board","name":"巫师工作进度报告","no_get":1,"board_id":"wizard_j","notes":({(["title":"sigh","author":"小霖","time":887800959,"msg":"500点经验，500点潜能。sorry",]),(["title":"roar被骗了","author":"玩家","time":888247514,"msg":"roar, 你被骗了. 现在玩家数据都有备分了, 所以我建议以后恢复数据都直接拷备分.中间的一点损失玩家自负. 对wwwl骗来的skill, mana, 我要改回去.石头(shi) call 温暖(wwwl)->set_skill(huashan-jianfa,130) on Thu Feb 19 11:46:52 1998石头(shi) call 温暖(wwwl)->set(max_mana,322) on Thu Feb 19 11:50:51 1998石头(shi) call 温暖(wwwl)->set(combat_exp,182000) on Thu Feb 19 11:51:19 1998龙五(roar) call 温暖(wwwl)->set(max_mana,412) on Fri Feb 20 11:43:12 1998龙五(roar) call 温暖(wwwl)->set_skill(literate,134) on Fri Feb 20 11:45:12 1998龙五(roar) call 温暖(wwwl)->set_skill(huashan-shenfa,138) on Fri Feb 20 11:45:36 1998龙五(roar) call 温暖(wwwl)->set_skill(huashan-jianfa,142) on Fri Feb 20 11:46:04 1998",]),(["title":"Re roar被骗了","author":"道可道","time":888289039,"msg":"现在因为有quit数据备份，请巫师们不要再随便给人恢复数据。	dao",]),(["title":"re 27 and 28","author":"龙五","time":888301695,"msg":"sigh为什么骗我呢？今天的调查结果是dear的mana也就370,竟然要了我412决定把他的mana改到280,huashan-skills 125sorry all",]),(["title":"son has some error","author":"小霖","time":888740620,"msg":"son has post in /d/wizard/guest_room,就最近的问题来说，我建议给arch多一点的权限，否则当玩家有问题时，心有余而力不足。sigh",]),(["title":"巫师们请守规则","author":"玩家","time":889531141,"msg":"巫师不但不能随意call玩家的数据, 为帮玩家完成任务, 随意clone, update也是不允许的, 这一方面不公平, 另一方面也破坏了quest的平衡, 使quest失去难度,至于为了帮玩家挽回死亡的损失, 不惜reboot mud, 这是绝对不允许的.昨天iwx骂了一晚上的巫师, 虽然言辞过激, 但却可以理解.我了解到, iwx是自费在公司里上网玩的, 有时为了能多玩几小时, 晚上回不了家,就在录像厅里过夜. 面对这样的玩家, 我们还有什么理由不守规则呢?",]),(["title":"something wrong","author":"小霖","time":889780021,"msg":"今天少林三渡变成五个了，所以我update了，玩家tangzhan因有五个而死，要求恢复经验，我给他恢复了。",]),(["title":"202.38.201.41不断地用频道封屏.","author":"石头","time":889939915,"msg":"建议作个ban id的命令.否则对这样的玩家不好办",]),(["title":"agree shi","author":"玩家","time":889973879,"msg":"第一次聚会时不就确定做一个吗?",]),(["title":"to dao or disc","author":"小霖","time":890271358,"msg":"nelly的密码出错了。请帮她一下。今天clone了一些东西，因为eve用茅山道术出错,调试时需要",]),(["title":"建议封掉几个id","author":"玩家","time":894015339,"msg":"combatd已被封了建议再封掉maskman蒙面人blackman黑衣人另外mengzhu武林盟主, shangshan赏善使者, fae罚恶使者也可以考虑封掉.",]),(["title":"写好了press","author":"玩家","time":896983960,"msg":"press在方柔身旁, 有人kill fang时, press将kill该人, 反之有人kill press时fang将kill该人.顺便改了要驻颜丹条件, 要求唐门女弟子, 20岁以上, 200faith以上. 今晚我就呆在那1小时, 有5,6个dummy反复来要驻颜丹.另外把驻颜丹的value从5gold改到了50silver.need copy/d/tangmen/obj/zhuyandan.c/d/tangmen/keting.c/class/tangmen/press.c/class/tangmen/fangrou.c",]),(["title":"几个老的BUG又出来了","author":"流星雨","time":914779426,"msg":"是不是和8686做文件同步的后果?还是当初根本就没有改?/d/hangzhou/temple 那里仍然可以多次talk tie shui生成多个duan yu每个身上都有gold,而且只要tie shui不死,duan yu要多少有多少.我去改了文件. 在8686, /d/hangzhou/npc/tieshui.c            Yeung        12/27",]),(["title":"现在可能有的老BUG又出来了","author":"流星雨","time":914780430,"msg":"如题.是否需要整理一下以前报告过(改过和没有改过的)的BUG?然后再仔细检查一遍?",]),(["title":"faint","author":"小话","time":933088952,"msg":"呵呵 我还有一个情况说一下 disc把在帐号给玩家了call了一点数据 现在我已经把这个事情解决了disc现在我先控制了！PowerChen你和disc说一下 我给他f发mail;给退回了.                                                               ",]),(["title":"bug","author":"爱相随","time":933176935,"msg":"0走了过来。???",]),(["title":"这帮巫师们","author":"龙妞","time":935341219,"msg":"都在干些啥?瞧瞧你们的wizlog...都有好几兆了~~~",]),(["title":"kok gege","author":"无极","time":937992312,"msg":"hehe",]),(["title":"这个东东不用了吧已经？","author":"玄浮大师","time":952395004,"msg":"一不小心走了进来，到处看看，原来这个板好长时间不用了。",]),(["title":"0走是个超老的bug","author":"流浪猫","time":959200985,"msg":"动物没性别move里返回不了rankd给俩组合英俊+女孩/或者0这算老es系统的特征bughehe",]),(["title":"现在鬼王也是bug","author":"流浪猫","time":959201049,"msg":"我read new 到34居然也踢我严格的连续发令(不管时间隔多久)就踢kok and rascal真正封屏的都是几条命令交替发还不如老鬼王按速度踢呢kok and rascal 鬼王smash 鬼王",]),(["title":"logs注意","author":"张问心","time":963188674,"msg":"逍遥子和李秋水的prevent_learn改成accept_learn",]),(["title":"logs注意","author":"张问心","time":963188883,"msg":"我的那些休息室都有些问题",]),(["title":"问题","author":"春风醉","time":986992934,"msg":"【 平  民 】 /obj/user/user#7329(Pantene)0",]),(["title":"我update了王重阳","author":"春风醉","time":987236495,"msg":"xixi今天王那不刷新，也不能教弟子学习，我update了",]),(["title":"新巫师申请","author":"流星雨","time":1003871389,"msg":"姓名：于洋性别：女年龄：20学校：北工大兴趣：网络泥巴擅长：c lpc java 网页以前做过arch在开发站，开发了很多新东西擅长做门派skill perform job 等等希望谋得稳定的巫师一职希望巫师组考虑",]),(["title":"大家觉得意见如何，请在这里反馈","author":"流星雨","time":1003871413,"msg":"谢谢。",]),(["title":"about help","author":"晓风残月","time":1014246866,"msg":"logs 我现在让老玩家写help，然后给于一定奖励，这里的help太烂了！",]),(["title":"about edit","author":"晓风残月","time":1014502768,"msg":"\"adm/daemons/aliasd.c\"  can't be opened for writing!kick logs给我解决我写不了",]),(["title":"奖励请适度","author":"流星雨","time":1015223394,"msg":"不要奖励太多了，一般wlshw和最大内力、以及年龄，天赋之类得玩家不可克服得东西，不应该奖励dongsw这几个奖励过大了。",]),(["title":"请各位讨论一下关于pk的规则","author":"流星雨","time":1015331054,"msg":"我个人的意见是如何防范那种针对无辜新手的出气行为,至于老玩家之间的个人恩怨相互PK 之类的属正常现象用不着干涉,关键是如何界定一个有效可执行的规则,请各位讨论一下发表在这里.",]),(["title":"fanny请解释一下自己的update记录","author":"流星雨","time":1017131554,"msg":"如题",]),(["title":"33","author":"方舟","time":1017144047,"msg":"近期的？。",]),(["title":"promote lance to immortal","author":"晓风残月","time":1021481627,"msg":"lance is smile 主要让他帮助我addoil all",]),(["title":"关于华山拜风清扬","author":"蓝天","time":1027317862,"msg":"修改了/d/huashan/hshouyuan.c 使可以到达思过崖修改了/class/huashan/linghu.c 使气宗和剑宗的人均可以进入山洞但是几率为1/100;修改了/class/huashan/feng.c 使气宗和剑宗的人均可以拜师，但各有要求，气宗必须有至少201的zixia-shengong剑宗必须有至少201的wind-swordsmilexixi准备再看看fox来增加一条拜风清扬的路",]),(["title":"限制了mirror+blade的变态组合","author":"晓风残月","time":1028511601,"msg":"我把combatd.中对杀气的东西改了限制了这种组合",]),(["title":"about /quest/killer.c","author":"飞离尘世","time":1054043200,"msg":"         if(!place || place->query(\"no_fight\") || place->query(\"no_magic\") ||加一个判断：place->query(\"sleep_room\")免得杀手出来在sleep room",]),(["title":"有位player的数据有问题","author":"飞鱼","time":1058244626,"msg":"窈窈目前一共学过十八种技能：;  纵跃闪躲之术 (dodge)                     - 深不可测 1000/   21;□独孤九剑 (dugu-jiujian)                  - 深不可测 1000/    0内功心法 (force)                         - 深不可测 1000/    0基本硬功 (iron-cloth)                    - 深不可测 1000/    0;□金刚不坏功 (jin-gang)                    - 深不可测 1000/    0读书识字 (literate)                      - 深不可测 1000/    0基本轻功 (move)                          - 深不可测 1000/    0;□步玄七诀 (mysterrier)                    - 深不可测 1000/    5拆招卸力之法 (parry)                     - 深不可测 1000/    0听风辨器之术 (perception)                - 深不可测 1000/    0;□乾坤大挪移 (qiankun-danuoyi)             - 深不可测 1000/    0奇门八卦 (qimen-bagua)                   - 深不可测 1000/    0;□七宝天岚舞 (stormdance)                  - 深不可测 1000/    0基本掌法 (strike)                        - 深不可测 1000/    0基本剑术 (sword)                         - 深不可测 1000/    0;□太极神功 (taiji-shengong)                - 深不可测 1000/    0",]),(["title":"hehe","author":"思佛","time":1059158477,"msg":"到处转了半天，用了不少update指令，请大家放心，没有做别的事情。特别报告一下。",]),(["title":"masterall","author":"思佛","time":1060512272,"msg":"已经测试好了，文件目录没动，主文件是nang.c",]),}),"capacity":50,])
