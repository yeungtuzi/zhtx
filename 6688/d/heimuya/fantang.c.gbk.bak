#include <ansi.h>

inherit ROOM;

void create()
{
	set("short","ｷｹﾌﾃ");
	set("long", @LONG
	ﾒｻｸｹﾌﾃ,ﾖﾐｼ萪ｻﾕﾅﾆ豕､ﾎﾞｱﾈｵﾄｳﾔｷｹﾗﾀ｣ｬﾉﾏﾃ豌ﾚﾖｸﾅﾌｲﾋ
ﾒｻｿｴｾﾍﾊﾇﾆﾕﾍｨｽﾌﾖﾚｳﾔｷｹ(chifan)ｵﾄｵﾘｷｽ.｡
LONG
	);

	set("exits", ([
		"east"  :__DIR__"dingfeng5.c",
	]));

	setup();
}

void init()
{
        add_action("do_chifan", "chifan");

}

int do_chifan()
{
	this_player()->start_busy(5);
	write(YEL "ﾄ聆ﾂﾀｴｱ･ｱ･ｵﾘｴﾔﾁﾋﾒｻｶﾙ\n" NOR);
	write(YEL "ﾖｱｳﾔｵﾃｶﾇｷﾊｳｦﾂ嵂ﾅﾐﾄﾂ昮籏羞ﾘﾕｾﾆ暲ｴ\n" NOR);	
	if( (int)this_player()->query("food") >= (int)this_player()->max_food_capacity() )
	return notify_fail("ﾄ耡ﾑｾｭｳﾔﾌｫｱ･ﾁﾋ｣ｬﾔﾙﾒｲﾈ軏ｻﾏﾂﾈﾎｺﾎｶｫﾎﾋ｡｣\n");
       	this_player()->set("food",this_player()->max_food_capacity());
       	this_player()->set("water",this_player()->max_water_capacity());
	return 1;
}
