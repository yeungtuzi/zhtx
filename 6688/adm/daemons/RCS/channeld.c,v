				"msg_emote": HIW "【拍卖】%s" NOR,
				"new_use":1
			 ]),

	"rumor":([	"msg_speak": HIM "【谣言】%s：%s\n" NOR,
				"msg_emote": HIM "【谣言】%s" NOR,
				"filter": (: $1["MUDLIB"]=="Venturing in a New World" :) ,
