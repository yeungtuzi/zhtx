	carry_object(__DIR__"obj/skirt")->wear();
	carry_object(__DIR__"obj/gangjian")->wield();
	if( clonep() ) CHANNEL_D->register_relay_channel("chat");
}

int add_phrase(string who, string msg)
{
	msg = replace_string(msg, "?", "");
	msg = replace_string(msg, "？", "");
	msg = replace_string(msg, "？", "");
	msg = replace_string(msg, "!", "");
	msg = replace_string(msg, "！", "");
	msg = replace_string(msg, "啊", "");
	msg = replace_string(msg, "吗", "");
	msg = replace_string(msg, "耶", "");
	msg = replace_string(msg, "吧", "");

	if( msg!="" ) {
		add("memory/" + who, ({ msg }));
		return 1;
	} else return 0;
}


void relay_emote(object ob, string verb)
{
       if( !userp(ob) ) return;
	switch(verb) {

	case "ppp":
	case "kiss":
	case "qmarry":
	case "forcemarry1":
	case "forcemarry2":
	case "forcemarry3":

	if ( (string) ob -> query ("gender") == "男性"||(string) ob -> query ("gender") == "无性" )
	{
	command ("chat 救命呀，"+ ob->query("name") + "想要非礼我！\n") ;
	command("chat 哎哟，谁想得到这" + RANK_D->query_rude(ob)+"，竟也是一个好色之徒 。");
	}
	else
	{
	command("chat " + ob->query("name") + ",你我同为女儿身，再怎么喜欢也不要这样啊。\n");
	command("chat 想不到"+ ob->query("name") +"这" + RANK_D->query_rude(ob)+"，竟然是一个变态！");
	}
	message_vision("$N摇了摇头，对$n幽幽叹道：唉，你这又是何苦呢?\n",this_object(),this_player());
	if(wizardp(ob))
	{
	ob->set("env/immortal",0);
 	message_vision("$N"+HIR"信手一指，$n就惨呼一声倒在了血泊之中\n"NOR,this_object(),this_player());
	ob->set("","苍蝇");
	ob->die();
	return;
	}
	command("angry");
	message_vision("夜莺羞红了脸，嗔道：你...你...你不要这样嘛！\n");
