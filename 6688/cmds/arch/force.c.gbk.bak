 // force.c
inherit F_CLEAN_UP;
void create() { seteuid(getuid()); }
int main(object me, string arg)
{
        string dest, cmd;
        object ob;
        if( me != this_player(1) ) return 0;
        if( !arg || sscanf(arg, "%s to %s", dest, cmd) != 2 )
                return notify_fail("жИ Сю Иё ЪН ЊКforce <ФГ ШЫ> to <жИ Сю>\n")
;
           ob = find_player(dest);
       if (!ob) ob=find_living(dest);
        if( !ob )
                return notify_fail("УЛга" + dest + "етИіШЫЁЃ\n");
        if( !living(ob) )
                return notify_fail("ет Иі Юя Мў ВЛ Фм жД аа Уќ СюЁЃ\n");
        if(wiz_level(me) < wiz_level(ob)) return notify_fail(
"Фу УЛ га ЧП жЦ" + ob->name() + "жД аа ЕФ ШЈ СІЁЃ\n");
        if( userp(ob) )
                log_file("FORCE_PLAYER", sprintf("[%s] %s forces %s to %s\n",
                        ctime(time()), geteuid(me), geteuid(ob), cmd));
        return ob->force_me(cmd);
}
int help(object me)
{
        write(@Help
 жИ Сю Иё ЪН ЊКforce <ФГ ШЫ> to <жИ Сю>
 ЧП ЦШ ФГ ШЫ зі ФГ ЪТ, ЕЋ Фу ЕФ Юз ЪІ ЕШ МЖ Би аы БШ Жд ЗН Ип, Жј Чв Би аы ЪЧ
дк ЭЌ вЛ Иі ЗП Мф РяЁЃ
Help
        );
        return 1;
}
