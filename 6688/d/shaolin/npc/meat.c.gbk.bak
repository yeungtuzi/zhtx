	set("force", 4000);
	set("max_force", 8000);
	set("force_factor", 250);
	set("combat_exp", 5000000);
	set("score", 500000);
	set_temp("apply/armor_vs_force",150);
	set_temp("apply/armor",100);
	set_temp("apply/defense",100);
	set_temp("apply/attack",100);

	set_skill("force", 230);
	set_skill("hunyuan-yiqi", 250);
	set_skill("dodge", 220);
	set_skill("shaolin-shenfa", 220);
	set_skill("finger", 220);
	set_skill("strike", 220);
	set_skill("hand", 220);
	set_skill("claw", 220);
	set_skill("parry", 230);
	set_skill("nianhua-zhi", 220);
	set_skill("sanhua-zhang", 220);
	set_skill("qianye-shou", 220);
	set_skill("longzhua-gong", 220);
	set_skill("buddhism", 250);
	set_skill("literate", 200);
	set_skill("zui-gun",220);
	set_skill("staff",220);
	set_skill("damo-jian",220);
