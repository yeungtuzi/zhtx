                "action":
"$N大拇指一按，一招「"+HIG+"少商剑"NOR+"」，剑法大开大阖，气势宏伟，刺向$n的$l",
                "attack":               30,
                "dodge":                0,
                "parry":                5,
                "force":                440,
                "weapon":               "少商剑气",
                "damage_type":  "刺伤",
