private void _home(object pl)                // НЋгЮБъвЦЕНааЪз 
{ 
        mapping me=pl->query_temp("me"); 
        me["iCol"] = 1; 
        if (me["iS_Col"] == 1)_refresh_status(pl); 
        else        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], 1); 
} // _home() 
private void _insert(object pl)                // дкгЮБъЧАУцВхзж 
{ 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"]) == 0) return; 
        me["is_Command_Mode"] = 0; 
        _refresh_status(pl); 
} // _insert() 
private void _insert_line(object pl)        // дкгЮБъЩЯЗНМгвЛаТаа 
{ 
        string *text=({ }); 
        mapping me=pl->query_temp("me"); 
        me["is_Command_Mode"] = me["is_NewFile"] = 0; 
        me["is_Modify"] = 1; 
        // МьВщЪЧЗёгЮБъЩЯЗНЪЧЗёгаФкШн 
        if (me["iS_Row"]+me["iRow"]-3 >= 0) 
                text = me["sText"][0..me["iS_Row"]+me["iRow"]-3]; 
        text += ({ "" }); 
        text += me["sText"][me["iS_Row"]+me["iRow"]-2..<1]; 
        me["sText"] = text; 
        me["iCol"] = 1; 
        _refresh_screen(pl, me["iS_Row"], sizeof(me["sText"]), 1); 
} // _insert_line() 
private void _insert_exclam_mark(object pl) // дкгЮБъЧАУцВхШывЛИіЁИ!ЁЙзждЊ 
{ 
        mapping me=pl->query_temp("me"); 
        // вђЮЊЮоЗЈе§ГЃЪфШыЁИ!ЁЙЃЌЫљвдЬиЕиМгДЫКЏЪНвдЪфШыЁИ!ЁЙЁЃ 
        if (sizeof(me["sText"]) == 0) return; 
        me["sChar"] = "!"; 
        _process(pl); 
} // _insert_!() 
private void _join(object pl)                // НЋЯТааЮФзжвЦЕНДЫаассУц 
{ 
        string *text=({ }); 
        mapping me=pl->query_temp("me"); 
        if (me["iS_Row"]+me["iRow"]-1 >= sizeof(me["sText"])) return; 
        me["is_NewFile"] = 0; 
        me["is_Modify"] = 1; 
        _end(pl);                        // ЯШНЋгЮБъвЦЕНааЮВ 
        text = me["sText"][0..me["iS_Row"]+me["iRow"]-2]; 
        if (sizeof(me["sText"][me["iS_Row"]+me["iRow"]-1])) 
        {        // ШєЯТаагаФкШнИНМгЩЯРД 
                text[me["iS_Row"]+me["iRow"]-2] += (" "+ 
                        me["sText"][me["iS_Row"]+me["iRow"]-1]); 
                _right(pl, 1, 1); 
        } 
        text += me["sText"][me["iS_Row"]+me["iRow"]..<1]; 
        me["sText"] = text; 
        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
} // _join() 
private void _keymap(object pl)                // ЖЈвхаТЙІФмМќ 
{ 
        _message(pl, "ЧыЪфШыаТЖЈвхМќКЭд­ЙІ\ФмМќЃЈжБНгАД ENTER ШЁЯћЃЌвдПеАзИєПЊЃЉЉ", 
                "_keymap_done", ECHO); 
} // _keymap() 
protected void _keymap_done(string str, object pl) // ШЁЕУЖЈвхЙІФмМќ 
{ 
        string old, _new; 
        mapping me=pl->query_temp("me"); 
        _refresh_status(pl); 
        if (str != "") 
        {        // ШєгазЪСЯЪфШы 
                if (sscanf(str, "%s %s", _new, old) != 2) 
                        return _message(pl, "ЪфШыИёЪНДэЮѓЁЃ", "_message_done", 
                                HIDE); 
                me["keymap"][_new] = old; 
                _message(pl, sprintf("КУСЫЃЌДгДЫвдссаТЖЈвхМќЁИ%sЁЙОЭгад­ЙІ\ФмМќ? 
?sЁЙЕФЙІ\ФмСЫЃЁ", 
                        _new, old), "_message_done", HIDE); 
        } 
        else        get_char("_input", HIDE, pl); // ШЁЯћЪфШыЃЌМЬајЖСШЁЯТИіЪфШы 
} // _keymap_done() 
private void _left(object pl)                // гЮБъЭљзѓвЦвЛзж 
{ 
        mapping me=pl->query_temp("me"); 
        if (me["iS_Col"] ==1 && me["iCol"] ==1) return _refresh_status(pl); 
        if (--me["iCol"] < 1) 
        {        // гЮБъЕФаТЮЛжУдкд­Л­УцЭтЃЌашвЊжиЛцЛ­Уц 
                // ШєзѓвЦ 8 РИЬЋЖрЕФЛАЃЌОЭжЛзѓвЦвЛРИ 
                if (me["iS_Col"]-8 < 1) 
                        me["iCol"] = me["iS_Col"]-1; 
                else        me["iCol"] = 8; // ВЛШЛОЭЩшЖЈгЮБъдкЕк 8 РИЮЛжУ 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], 
                        me["iS_Col"]-me["iCol"]); 
                return; 
        } 
        _refresh_status(pl); 
} // _left() 
// дкзДЬЌСаЯдЪОбЖЯЂ 
private varargs void _message(object pl, string str, string callback, int hide, mixed arg) 
{ 
        printf(HOME + NOR + REV);        // вЦЖЏгЮБъЕН (1,1)ЃЌЩшЖЈЗДЯрзждЊЯдЪО 
        // ЧхГ§д­зДЬЌСаЕФбЖЯЂ 
        printf(" 
                "); 
        printf(HOME + str);                // вЦЖЏгЮБъЕН (1,1)ЃЌдйЯдЪОбЖЯЂ 
        input_to(callback, hide, pl, arg); // ЖСШЁЪфШызЪСЯ 
} // _message() 
protected void _message_done(string str, object pl) // НсЪјбЖЯЂЕФЯдЪО 
{ 
        _refresh_status(pl); 
        get_char("_input", HIDE, pl);        // МЬајЖСШЁЪфШызжДЎ 
} // _message_done() 
private void _next_match(object pl)                // ЫббА/ЬцЛЛЯТИіЗћКЯзжДЎ 
{ 
        mapping me=pl->query_temp("me"); 
        string str=""; 
        // ЩшЖЈЦ№ЪМЫббАЮЛжУЮЊгЮБъЯждкЮЛжУ 
        int    j=me["iS_Col"]+me["iCol"]-1, 
               i, ofs; 
        if (!stringp(me["sSearch"])) return; // ШєУЛЯШЩшЖЈЫббАзжДЎЃЌВЛзіЪТ 
        for (i=me["iS_Row"]+me["iRow"]-2; i<sizeof(me["sText"]); i++) 
        { 
                if ((ofs = strsrch(me["sText"][i][j-1..<1], me["sSearch"]))== -1) 
                        j = 1; // етааУЛевЕНЕФЛАЃЌЩшЖЈЯТааДгЕквЛРИПЊЪМев 
                else 
                {        // евЕНжИЖЈзжДЎСЫ, вЦЖЏгЮБъЕНФПЕФаа 
                        _goto_line_done(sprintf("%d", i+1), pl, 0); 
                       me["iCol"] = j+ofs; // МЦЫужИЖЈзжДЎЕФОјЖдЮЛжУ 
                        // ШєжИЖЈзжДЎТфдкд­Л­УцЭтЃЌдђжиЛцЛ­Уц 
                        if (me["iCol"]<me["iS_Col"] || 
                            me["iCol"]+strlen(me["sSearch"])>me["iS_Col"]+79) 
                                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], 
                                        me["iCol"]); 
                        if (stringp(me["sReplace"])) 
                        {        // ашвЊЬцЛЛзжДЎ 
                                me["is_NewFile"] = 0; 
                                me["is_Modify"] = 1; 
                                // ИНМггЮБъЧАФкШн 
                                str = me["sText"][i][0..me["iCol"]-2]; 
                                str += me["sReplace"]; 
                                str += (me["sText"][i][me["iCol"]+ 
                                        strlen(me["sSearch"])-1..<1]); 
                                me["sText"][i] = str; 
                                // ШєЬцЛЛзжДЎТфдкд­Л­УцЭтЃЌдђжиЛцЛ­Уц 
                                if (me["iCol"]<me["iS_Col"] || 
                                    me["iCol"]+strlen(me["sReplace"]) 
                                    > me["iS_Col"]+79) 
                                        _refresh_screen(pl, me["iS_Row"], 
                                                me["iE_Row"], me["iCol"]); 
                                // НЋгЮЦЏвЦЕНЬцЛЛзжДЎссУц 
                                me["iCol"] = me["iCol"]+strlen(me["sReplace"])- 
                                        me["iS_Col"]+1; 
                                printf(ESC "[%d;1f%-80s", me["iRow"]+1, 
                                        me["sText"][me["iS_Row"]+ 
                                        me["iRow"]-2][me["iS_Col"]-1 
                                        ..me["iE_Col"]-1]); 
                        } 
                        // НЋгЮЦЏвЦЕНЫббАзжДЎссУц 
                        else 
                                me["iCol"] = me["iCol"]+strlen(me["sSearch"])-me["iS_Col"]+1; 
                        _refresh_status(pl); 
                        break; 
                } // if found 
        } // for each row 
        if (i >= sizeof(me["sText"])) 
                _message(pl, "евВЛЕНжИЖЈзжДЎЃЁ", "_message_done", HIDE); 
        else        get_char("_input", HIDE, pl); // ЖСШЁЯТИіЪфШызжДЎ 
} // _next_match() 
private void _page_down(object pl)        // ЭљЯТОэвЛвГЃЈ22 ааЃЉ 
{ 
        mapping me=pl->query_temp("me"); 
        if (me["iS_Row"]+22 > sizeof(me["sText"])) return; // МьВщЪЧЗёВЛФмдйОэСЫ 
        me["iS_Row"] += 22;        me["iE_Row"] += 22; 
        // МьВщгЮБъЕФаТЮЛжУЪЧЗёГЌЙ§ЕЕЮВ 
        if (me["iS_Row"]+me["iRow"]-1 > sizeof(me["sText"])) 
                me["iRow"] = sizeof(me["sText"])-me["iS_Row"]+1; 
        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
        // ШєгЮБъЕФаТЮЛжУГЌЙ§ааЮВЃЌдђвЦЖЏгЮБъЕНааЮВ 
        if (me["iS_Col"]+me["iCol"]-1 > sizeof(me["sText"][me["iS_Row"]+ 
                me["iRow"]-2])) 
                _end(pl); 
} // _page_down() 
private void _page_up(object pl)        // ЭљЩЯОэвЛвГЃЈ22 ааЃЉ 
{ 
        mapping me=pl->query_temp("me"); 
        if (me["iS_Row"] <= 1) return; // МьВщЪЧЗёВЛФмдйОэСЫ 
        me["iS_Row"] -= 22; 
        if (me["iS_Row"] < 1) me["iS_Row"] = 1; // зюЖржЛФмЗ­ЕНЕквЛСа 
        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
        // ШєгЮБъЕФаТЮЛжУГЌЙ§ааЮВЃЌдђвЦЖЏгЮБъЕНааЮВ 
        if (me["iS_Col"]+me["iCol"]-1 > 
            sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])) 
            _end(pl); 
} // _page_up() 
private void _process(object pl)        // ДІРэЪфШыФЃЪНЕФзжДЎЪфШы 
{ 
        int    i, size; 
        string str, rest, *input; 
        mapping me=pl->query_temp("me"); 
        if (me["is_Modify"] ==0 || me["is_NewFile"] ==1) 
        { 
                me["is_NewFile"] = 0; 
                me["is_Modify"] = 1; 
                _refresh_status(pl); 
        } 
        if (!me["is_Substituted"] && (strsrch(me["sChar"], "\r")!=-1 || 
            strsrch(me["sChar"], "\n")!=-1)) 
                me["is_Substituted"] = 1; // ЩшЖЈФкТыДњЛЛЦьБъ 
        me["sChar"] = replace_string(me["sChar"], "\t", "        "); 
        me["sChar"] = replace_string(me["sChar"], "\r", "\rENTER\r"); 
        me["sChar"] = replace_string(me["sChar"], "\n", "\rENTER\r"); 
        input = explode(me["sChar"], "\r"); 
        size = sizeof(input); 
        for (i=0; i<size; i++)                // вЛДЮДІРэвЛааЪфШы 
        { 
                if (me["is_Substituted"] && input[i] == "ENTER") 
                {        // ЕБМќШы ENTER ЪБЃЌвЊНЋгЮБъжЎссЕФФкШнвЦЕНЯТУцЕФаТаа 
                        rest = me["sText"][me["iS_Row"]+ 
                                me["iRow"]-2][me["iS_Col"]+me["iCol"]-2..<1]; 
                        me["sText"][me["iS_Row"]+me["iRow"]-2] = 
                                me["sText"][me["iS_Row"]+ 
                                me["iRow"]-2][0..me["iS_Col"]+me["iCol"]-3]; 
                        _append_line(pl); // дкгЮБъЕзЯТМгвЛаТаа 
                        // аТааЕФФкШнЪЧд­гЮБъЮЛжУвдссЕФФкШн 
                        me["sText"][me["iS_Row"]+me["iRow"]-2] = rest; 
                        continue; 
                } 
                // ЪфШызжДЎВЛЪЧ ENTER ЪБ, ДІРэ TAB ЕФЖЈЮЛ 
                if (me["is_Substituted"] && input[i] == "TAB") 
                        input[i] = "        "[0..7-(me["iCol"]-1)%8]; 
                str = me["sText"][me["iS_Row"]+me["iRow"]-2][0..me["iS_Col"]+ 
                        me["iCol"]-3] + input[i] + me["sText"][me["iS_Row"] + 
                        me["iRow"]-2][me["iS_Col"]+ me["iCol"]-2..<1]; 
                me["sText"][me["iS_Row"]+me["iRow"]-2] = str; 
                _right(pl, sizeof(input[i]), 1); 
        } // for 
        printf(ESC "[%d;1f%s", me["iRow"]+1, me["sText"][me["iS_Row"]+ 
                me["iRow"]-2][me["iS_Col"]-1..me["iE_Col"]-1]); 
        _refresh_cursor(pl); 
} // _process() 
protected void _quit(mixed unused, mixed pl) // РыПЊБрМ­Цї 
{ 
        mapping me; 
        seteuid(geteuid(pl)); 
        me = pl->query_temp("me"); 
        if (me["is_Modify"]) 
                return _message(pl, "ДЫЕЕАИвбИќИФЃЌЧыЮЪашвЊДцЕЕТ№ЃЈy/n)ЃП[n]", 
                        "_confirm_save", ECHO); 
        me["iRow"] = 23; 
        _refresh_cursor(pl);                // вЦЖЏгЮБъЕНзюссвЛаа 
        printf(NOR "\r\n"); 
        // ШєЙІФмМќЖЈвхЖдееБэЪЧПеЕФЃЌОЭЧхГ§ЭцМвЩэЩЯЕФМЧТМЃЌВЛШЛОЭМЧТМдкЭцМвЩэЩЯ 
        if (sizeof(me["keymap"]) == 0) pl->delete("me_keymap"); 
        else pl->set("me_keymap", me["keymap"]); 
        map_delete(EditedFiles, pl->query_temp("me/sFileName")); 
        pl->delete_temp("me"); // ЧхГ§БрМ­ЦїгУЕНЕФднЪББфЪ§ 
} // _quit() 
private void _refresh(object pl)        // ИќаТЛ­Уц 
{ 
        mapping me=pl->query_temp("me"); 
        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
} // _refresh() 
private void _replace(object pl)        // зжДЎЬцЛЛ 
{ 
        _message(pl, "ЫббА/ЬцЛЛзжДЎ(жБНгАДENTERШЁЯћ,вдПеАзИєПЊ):", 
                "_replace_done", ECHO); 
} // _replace() 
protected void _replace_done(string str, object pl) // ШЁЕУЬцЛЛзжДЎ 
{ 
        mapping me=pl->query_temp("me"); 
        _refresh_status(pl); 
        if (str != "") 
        {        // гаЪфШызЪСЯЪБ 
                if (sscanf(str, "%s %s", me["sSearch"], me["sReplace"]) != 2) 
                {        // жЛгавЛИізжДЎЃЌОЭжИЖЈЮЊЫббАзжДЎЃЌвтМДФУЕєжИЖЈзжДЎ 
                        me["sSearch"] = str; 
                        me["sReplace"] = ""; 
                } 
               _next_match(pl); 
        } 
        else        get_char("_input", HIDE, pl); // МЬајЖСШЁЯТИіЪфШызжДЎ 
} // _replace_done() 
private void _right(object pl, int col, int extra)        // гЮБъЭљгввЦвЛзж 
{ 
        int    acc; 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"])==0 || me["iS_Col"]+me["iCol"]-1> 
            sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])-1+extra) 
           return; 
        me["iCol"] += col; 
        if (me["iS_Col"]+me["iCol"]-1 > sizeof(me["sText"][me["iS_Row"]+ 
            me["iRow"]-2])+extra) 
                me["iCol"] = sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])- 
                        me["iS_Col"]+1+extra; 
        if (me["iCol"] > 80) 
        {        // гЮБъЕФаТЮЛжУВЛдкПЩМћЪгДАФкЃЌашвЊЭљгввЦЖЏЪгДА 
                // ШєгввЦ 8 РИЬЋЖрЕФЛАЃЌОЭжЛгввЦЕНааЮВ 
                if (me["iE_Col"]+8 > sizeof(me["sText"][me["iS_Row"]+ 
                    me["iRow"]-2])+1) 
                        acc = sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])- 
                                me["iE_Col"]+1; 
                else        acc = 8; 
                me["iCol"] = 80-acc+1;         // МЦЫугЮБъЕФаТЮЛжУ 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]+acc); 
                return; 
        } 
        _refresh_status(pl); 
} // _right() 
private void _search(object pl)                // зжДЎЫббА 
{ 
        _message(pl, "ЧыЪфШыЫббАзжДЎЃЈжБНгАД ENTER ШЁЯћ)ЃК", "_search_done", 
                ECHO); 
} // _search() 
protected void _search_done(string str, object pl) // ШЁЕУЫббАзжДЎ 
{ 
        mapping me=pl->query_temp("me"); 
        _refresh_status(pl); 
        if (str != "") 
        {        // гаЪфШызЪСЯЪБ 
                me["sSearch"] = str;        me["sReplace"] = 0; 
                _next_match(pl); 
        } 
        else        get_char("_input", HIDE, pl); // МЬајЖСШЁЯТИіЪфШызжДЎ 
} // _search_done() 
private void _tab(object pl)                 // УќСюФЃЪНЯТ TAB МќЕФЖЈЮЛ 
{ 
        mapping me=pl->query_temp("me"); 
        _right(pl, 8-(me["iCol"]-1)%8, 0); 
} // _tab() 
private void _undef_key(object pl)        // ШЁЯћФГЙІФмМќЖЈвх 
{ 
        _message(pl, "ЧыЪфШыгћШЁЯћЖЈвхжЎЙІ\ФмМќЃЈжБНгАД ENTER ШЁЯћ)ЃК", 
        "_undef_key_done", ECHO); 
} // undef_key() 
protected void _undef_key_done(string str, object pl) // ШЁЕУжИЖЈЙІФмМќ 
{ 
        mapping me=pl->query_temp("me"); 
        if (str != "")        map_delete(me["keymap"], str); 
        _message_done("", pl); 
} // undef_key_done() 
private void _up(object pl)                // гЮБъЭљЩЯвЦвЛаа 
{ 
        int  acc; 
        mapping me=pl->query_temp("me"); 
        if (me["iRow"] ==1 && me["iS_Row"] ==1)        return; 
        if (--me["iRow"] < 1) 
        {        // гЮБъаТЮЛжУВЛдкПЩМћЪгДАФкЃЌОЭЩЯвЦЪгДА 
                me["iS_Row"]--; 
                me["iE_Row"]=me["iS_Row"]+22; 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
                me["iRow"] = 1; 
        } 
        // ШєгЮБъаТЮЛжУГЌЙ§ааЮВЃЌдђвЦЕНааЮВ 
        if (me["iS_Col"]+me["iCol"]-1 > sizeof(me["sText"][me["iS_Row"]+ 
            me["iRow"]-2])) 
                me["iCol"] = sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])- 
                        me["iS_Col"]+(me["is_Command_Mode"]?1:2); 
        // ШєДЫааЮозжЃЌдђЖЈЮЛдкЕквЛРИ 
        if (me["iCol"] ==0 && me["iS_Col"] ==1) me["iCol"] = 1; 
        if (me["iCol"] > 0) _refresh_status(pl); 
        else 
        {        // гЮБъаТЮЛжУВЛдкПЩМћЪгДАФкЃЌжиЛцЛ­Уц 
                acc = me["iCol"];
				me["iCol"] = 1; 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]+acc-1); 
        } 
} // _up() 
private void _write(object pl)                // ШЁЕУДЂДцЕЕАИУћГЦ 
{ 
        _message(pl, "ЧыЪфШыаТЕЕУћЃЈжБНгАД ENTER вдЪЙгУОЩЕЕУћ)ЃК", 
                "_write_done", ECHO, 0); 
} // _write() 
protected void _write_done(string str, object pl, int quit) // ДЂДцЕЕАИ 
{ 
        string callback; 
        mapping me=pl->query_temp("me"); 
        if (str == "") str = me["sFileName"]; 
        else        // ШЁЕУЕЕУћ 
                str = resolve_path(pl->query("cwd"), str); 
        if (quit) callback = "_quit"; 
        else callback = "_message_done"; 
        if (write_file(str, implode(me["sText"], "\n")+"\n", 1)) 
        { 
                if (me["is_Modify"]) 
                        log_file(LOGFILE, sprintf("[%s] %s %s %s\n", 
                                ctime(time()), getuid(pl), 
                                me["is_NewFile"]? "+": "*", str)); 
                me["is_Modify"] = me["is_NewFile"] = 0; 
                me["sFileName"] = str; 
                _message(pl, "ДцЕЕГЩЙІ\ЁЃ", callback, HIDE); 
        } 
        else 
                _message(pl, "ДцЕЕЪЇАмЁЃ", callback, HIDE); 
} // write_done() 
