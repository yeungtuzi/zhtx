emote (["makecat":(["others":"$N把一只大布袋拿在手上翻来翻去,不知道想搞什么鬼.","target":"$N把你塞进$P手上的魔法大布袋,喵~~!!把你变成了一只小猫.","updated":"mscat","others_target":"$N把$n塞进$P手上的魔法大布袋,喵~~!!把$p变成了一只小猫.","myself":"你要把谁变成猫?","myself_target":"$P把$n塞进手上的魔法大布袋,喵~~!!把$p变成了一只小猫.","others_self":"$N钻进一只大布袋,喵~~!!一只小猫钻了出来.","myself_self":"$P自己钻进大布袋,喵~~!!出来的时候变成了一只小猫.",]),"getarmor":(["others":"$N正低着头四处乱走,不知道在打什么主意.","target":"$N对$p嚷到:\"这个怒龙锦胄是我先看到的,应该归我!\"","updated":"logs","others_target":"$N和$n扯住一件怒龙锦胄争的不可开交,道可道摇了摇头,掏出一把大剪刀,把怒龙锦胄一剪两半,说:\"好了,别争了,一人一半!\" ","myself":"$P正低着头四处乱走,想捡个怒龙锦胄.","myself_target":"$P对$n嚷到:\"这个怒龙锦胄是我先看到的,应该归我!\"","others_self":"$N见到地上有一件怒龙锦胄,看看四下无人,偷偷地捡起来揣进自己的怀里.","myself_self":"$P鬼鬼祟祟地从地上捡起来一件东西,偷偷地揣进自己的怀里.",]),"robot":(["others":"$N疑惑的皱起眉头，说道：“大家怎么都不说话？都是机器人吗？”","target":"$N大声嚷道：“我发现$p这$r是机~~~~~~器~~~~~~人~~~~~~！！！！”仿佛像找到了什么宝贝似的。[。","updated":"xiaolin","others_target":"$N大声嚷道：“我发现$n这$r是机~~~~~~器~~~~~~人~~~~~~！！！！”仿佛像找到了什么宝贝似的。","myself":"$P疑惑的皱起眉头，说道：“大家怎么都不说话？都是机器人吗？”","myself_target":"$P大声嚷道：“我发现$n这$r是机~~~~~~器~~~~~~~人~~~~~!!!!”","others_self":"$N高兴的唱道：“我是个快乐的机器人～～～～～”","myself_self":"$P高兴的唱道：“我是个快乐的机器人～～～～～”",]),"?":(["myself_target":"$P对着$n露出迷惑的表情。","others":"$N脸上露出迷惑的表情。","updated":"xbc","target":"$N似乎不懂$p是什么意思。","others_target":"$N似乎不懂$n是什么意思。","myself":"$P露出迷惑的表情。",]),"kiss3":(["others":"$N绿着眼四处张望，想找个人kiss一下。","target":"$N向$p指了指$P的脸，想让$p在那来个kiss。","updated":"rio","others_target":"$N向$n指了指$P的脸，想让$n在那来个kiss。","myself":"$P吻了吻自己的手。","myself_target":"$P向$n指了指自己的脸，想让$n在那来个kiss。","others_self":"$N吻了吻$P的手。","myself_self":"$P吻了吻自己的手。",]),"u&me":(["others":"$N狂笑道：“天下英雄，唯我独尊！”","target":"$N豪情万丈地说道：“天下英雄，唯我与$n也！”","updated":"zhuang","others_target":"$N豪情万丈地说道：“天下英雄，唯我与$n也！”","myself":"$P狂笑道：“天下英雄，唯我独尊！”","myself_target":"$P豪情万丈地说道：“天下英雄，唯我与$n也！”","others_self":"$N狂笑道：“天下英雄，唯我独尊！”","myself_self":"$P狂笑道：“天下英雄，唯我独尊！”",]),"benger":(["others":"$N用手指弹了一下自己的脑门儿。","target":"$N在$p的头上弹了个清脆的脑崩儿，$p的脑门儿上立刻长出了个小臌包。","updated":"zhuang","others_target":"$N在$n的头上弹了个清脆的脑崩儿，$n的脑门儿上立刻长出了个小臌包。","myself":"$