private mapping EditedFiles=([ ]);              // БрМ­жаЕФЕЕАИ 
/* 
int iS_Row, iE_Row,                             // ПЩМћЪгДАЕФЪМФЉааКХ 
    iS_Col, iE_Col,                             // ПЩМћЪгДАЕФЪМЮДРИЮЛ 
    iRow,   iCol,                               // гЮБъЮЛжУ 
    is_Command_Mode, is_NewFile, is_Modify,     // ЕЕАИзДПіЦьБъ 
    is_Substituted;                             // ДњЛЛФкТыЦьБъ 
string *sText,                                  // ЕЕАИФкШн 
       sChar, sOldChar,                         // ЪфШызжДЎЃЈУќСюЃЉ 
       sCount,                                  // УќСюМЦЪ§ 
       sFileName,                               // БрМ­ЕЕУћ 
       sSearch, sReplace;                       // ЫббА/ЬцЛЛзжДЎ 
mapping keymap;                                 // ЙІФмМќЖЈвхЖдееБэ 
*/ 
void start_edit(string file)                // КєНаБрМ­ЦїЃЌПЊЪМБрМ­ 
{ 
        int  i; 
        mapping me; 
        if (objectp(EditedFiles[file])) 
        { 
                write(sprintf("%s е§дкБрМ­етИіЕЕАИЃЌЧыЩдКђдйБрМ­ЁЃ\n", 
                capitalize(EditedFiles[file]->query("id")))); 
                return; 
        } // if 
        this_player()->set_temp("me", ([ ])); 
        me = this_player()->query_temp("me"); 
        me["sFileName"] = file; 
        if (file_size(file) <= 0) 
        {        // ЕЕАИГЄЖШаЁьЖ 1 
                me["sText"] = ({ "" }); 
                if (file_size(file) < 0) 
                {        // аТЕЕ 
                        me["is_Command_Mode"] = 0; 
                        me["is_NewFile"] = 1; 
                } 
        } 
        else 
        { 
                string content=read_file(file), tabs="        "; 
                // ЕЕАИГЄЖШДѓьЖ 0 
                me["is_Command_Mode"] = 1; 
                me["is_NewFile"] = 0; 
                if (stringp(content)) 
                { 
                        me["sText"] = explode(read_file(file), "\n"); 
                        // НЋ TABЃЌвд 8 ИіПеАзДњЬцЃЌвдЗНБугЮБъЮЛжУЕФМЦЫу 
                        for (i=sizeof(me["sText"])-1; i>=0; i--) 
                        { 
                                int len=sizeof(me["sText"][i]); 
                                reset_eval_cost(); 
                                for (int j=0; j<len; j++) 
                                        if (me["sText"][i][j] == '\t') 
                                                me["sText"][i] = replace_string( 
                                                        me["sText"][i], "\t", tabs[0..7-j%8]); 
                        } 
                } 
                else me["sText"] = ({ "" }); 
        } // old file 
        me["sCount"] = ""; 
        me["sSearch"] = me["sReplace"] = me["is_Modify"] = 0; 
        me["iE_Row"] = 23; 
        me["iS_Row"] = me["iS_Col"] = me["iRow"] = me["iCol"] = 1; 
        EditedFiles += ([ file: this_player()->link() ]); 
        // ШЁЕУ/ЩшЖЈЙІФмМќЖЈвхЖдееБэ 
             if (!mapp(me["keymap"] = this_player()->query("me_keymap"))) 
                     me["keymap"] = ([ ]); 
        if (this_player()->query("me_no_help") || 
            this_player()->query_temp("no_me_help")) 
        {        // ЗЧЕквЛДЮЪЙгУБрМ­ЦїЃЌжБНгНјШыБрМ­Цї 
                _refresh_screen(this_player(), 1, 23, 1); 
                get_char("_input", HIDE, this_player()); 
        } 
        else 
        {        // ЕквЛДЮЪЙгУБрМ­ЦїЃЌЯШПДЙІФмЫЕУї 
                this_player()->set_temp("no_me_help", 1); 
                _help(this_player()); 
        } 
} // start_edit() 
private void _refresh_cursor(object pl)        // ИќаТгЮБъЮЛжУ 
{ 
        mapping me=pl->query_temp("me"); 
        printf(ESC "[%d;%df", me["iRow"]+1, me["iCol"]); 
} // _refresh_cursor() 
private void _refresh_status(object pl)        // ИќаТзДЬЌСа 
{ 
        mapping me=pl->query_temp("me"); 
        // вЦЖЏгЮБъЕН (1,1)ЃЌгУЗДЯрзждЊЯдЪОзДЬЌСа 
        printf(HOME + NOR + REV + "Са:%4d аа:%3d %-43s %10s [УќСюФЃЪН]" + NOR, 
                me["iS_Row"]+me["iRow"]-1, me["iS_Col"]+me["iCol"]-1, 
                sprintf("%s %s", me["sFileName"], (me["is_Modify"]? "(вбаоИФ)": 
                (me["is_NewFile"]? "(аТЕЕ)": "")))[0..42], 
                (me["is_Command_Mode"]? "?:ИЈжњЛ­Уц": "[ЪфШыФЃЪН]")); 
        _refresh_cursor(pl); 
} // _refresh_status() 
// жиЛцЛ­Уц 
private void _refresh_screen(object pl, int s_row, int e_row, int s_col) 
{ 
        int  i, temp; 
        mapping me=pl->query_temp("me"); 
        if (e_row < s_row)                // МьВщЪМФЉааКХЕФЯШссДЮађ 
        { 
                temp = e_row; 
                e_row = s_row; 
                s_row = temp; 
        } 
        if (s_row < 1) s_row = 1; 
        if (s_col < 1) s_col = 1; 
        if (e_row > sizeof(me["sText"])) // ВЛФмГЌЙ§ЕЕЮВ 
                e_row = sizeof(me["sText"]); 
        if (e_row-s_row > 22) e_row = s_row+22; 
        me["iS_Row"] = s_row;        me["iE_Row"] = e_row; 
        me["iS_Col"] = s_col;        me["iE_Col"] = s_col+79; 
        printf(REF+NOR);                // ЧхГ§Л­УцЃЌвЦЖЏгЮБъЕН (1,1) 
        for (i=me["iS_Row"]-1; i<me["iE_Row"]; i++) 
                printf("\r\n%s", me["sText"][i][me["iS_Col"]-1..me["iE_Col"]-1]);
        for (i=me["iS_Row"]+22-me["iE_Row"]; i>0; i--) 
                printf("\r\n~");        // ВЛзуааКХгУ ~ БэЪО 
        _refresh_status(pl); 
} // _refresh_screen() 
protected void _input(string str, object pl, int fresh) // ЖСЕУЪфШызжДЎ 
{ 
        int    i, size, bs=0; 
        string *chars; 
        mapping me=pl->query_temp("me"); 
        if (fresh) 
        {        // жиЛцЛ­Уц 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
                get_char("_input", HIDE, pl); 
                return; 
        } 
        me["is_Substituted"] = 1;       // ЯШЩшЖЈДњЛЛФкТыЦьБъ 
        if (str == "")                  // ДњЛЛЕє Backspace/Ctrl-Backspace 
        { 
                str = "BACKSPACE"; 
                bs = 1; 
        } 
        if (str[0] == 27) 
        { 
                chars = explode(str, ESC);      // внЭбТыЕФзжДЎЃЌвд ESC ЖЯПЊ 
                for (i=sizeof(chars)-1; i>=0; i--) 
                        chars[i] = ESC + chars[i];      // МгЛи ESC 
                if (sizeof(chars) == 0)                 // ШєжЛЪЧЕЅвЛзждЊ ESC 
                        chars = ({ ESC }); 
        } 
        else    
			chars = ({ str }); 
        size = sizeof(chars); 
        for (i=0; i<size; i++) 
        {        // зЊЛЛвнЭбТыЮЊБрМ­ЦїФкТы 
                switch (chars[i]) 
                { 
                case "\t":       me["sChar"] = "TAB";   break; 
                case "\r":       me["sChar"] = "ENTER"; break; 
                case ESC:        me["sChar"] = "ESC";   break; 
                case ESC "OA": 
                case ESC "[A":   me["sChar"] = "UP";    break; 
                case ESC "OB": 
                case ESC "[B":   me["sChar"] = "DOWN";  break; 
                case ESC "OC": 
                case ESC "[C":   me["sChar"] = "RIGHT"; break; 
                case ESC "OD": 
                case ESC "[D":   me["sChar"] = "LEFT";  break; 
                case ESC "OH": 
                case ESC "[H": 
                case ESC "1~": 
                case ESC "[1~":  me["sChar"] = "HOME";  break; 
                case ESC "[2~":  me["sChar"] = "INSERT";break; 
                case ESC "[3~":  me["sChar"] = "DELETE";break; 
                case ESC "4~":   me["sChar"] = "END";   break; 
                case ESC "[4~":  me["sChar"] = "END";   break; 
                case ESC "[5~":  me["sChar"] = "PAGEUP";break; 
                case ESC "[6~":  me["sChar"] = "PAGEDOWN";break; 
                case ESC "OP":   me["sChar"] = "F1";    break; 
                case ESC "OQ":   me["sChar"] = "F2";    break; 
                case ESC "OR":   me["sChar"] = "F3";    break; 
                case ESC "OS":   me["sChar"] = "F4";    break; 
                case ESC "m":    me["sChar"] = "F5";    break; 
                case ESC "[17~": me["sChar"] = "F6";    break; 
                case ESC "[18~": me["sChar"] = "F7";    break; 
                case ESC "[19~": me["sChar"] = "F8";    break; 
                case ESC "[20~": me["sChar"] = "F9";    break; 
                case ESC "[21~": me["sChar"] = "F10";   break; 
                case ESC "[23~": me["sChar"] = "F11";   break; 
                case ESC "[24~": me["sChar"] = "F12";   break; 
                default: 
                        if (sizeof(chars[i])==1 && 
                            0<chars[i][0] && chars[i][0]<27) 
                                switch (chars[i][0]) 
                                { // ДњЛЛФкТыЃЌЪЙдкЪфШыФЃЪНвВФмЪЙгУжИСю 
	                            case  1: me["sChar"] ="Ctrl-A"; break; 
                                case  2: me["sChar"] ="Ctrl-B"; break; 
                                case  4: me["sChar"] ="Ctrl-D"; break; 
                                case  6: me["sChar"] ="Ctrl-F"; break; 
                                case  7: me["sChar"] ="Ctrl-G"; break; 
                                case 10: me["sChar"] ="Ctrl-J"; break; 
                                case 11: me["sChar"] ="Ctrl-K"; break; 
                                case 12: me["sChar"] ="Ctrl-L"; break; 
                                case 14: me["sChar"] ="Ctrl-N"; break; 
                                case 15: me["sChar"] ="Ctrl-O"; break; 
                                case 16: me["sChar"] ="Ctrl-P"; break; 
                                case 17: me["sChar"] ="Ctrl-Q"; break; 
                                case 18: me["sChar"] ="Ctrl-R"; break; 
                                case 19: me["sChar"] ="Ctrl-S"; break; 
                                case 20: me["sChar"] ="Ctrl-T"; break; 
                                case 21: me["sChar"] ="Ctrl-U"; break; 
                                case 22: me["sChar"] ="Ctrl-V"; break; 
                                case 23: me["sChar"] ="Ctrl-W"; break; 
                                case 24: me["sChar"] ="Ctrl-X"; break; 
                                case 25: me["sChar"] ="Ctrl-Y"; break; 
                                case 26: me["sChar"] ="Ctrl-Z"; break; 
                        } // switch 
                        else 
                        { 
                                me["sChar"] = chars[i];            // ДЫЮЊЦеЭЈзжжДЎ 
                                if (!bs) me["is_Substituted"] = 0; // ЧхГ§ДњЛЛФк 
                        } // else 
                } // switch 
                // НЋзЊЛЛссЕФзжДЎЫЭЕНЗжХЩжИСюКЏЪНДІРэЃЌВЂЕШД§ЖСШЁЯТИіЪфШы 
                if (_dispatcher(pl) && i==size-1) get_char("_input", HIDE, pl); 
        } // for 
} // input() 
private int _dispatcher(object pl)                // ЗжХЩжИСюЕНВЛЭЌКЏЪН 
{ 
        int  i, count=1; 
        mapping me=pl->query_temp("me"); 
        if ( me["is_Command_Mode"] || 
            (me["is_Substituted"] && // ШУЪфШыФЃЪНвВФмЪЙгУФГаЉжИСю 
             // етЖўИіжИСюВЛдкетДІРэ 
             me["sChar"]!="ENTER" && me["sChar"]!="TAB") ) 
        {        // ЯждкЪЧУќСюФЃЪН 
                if (sizeof(me["sChar"])!=1 && !me["is_Substituted"]) 
                        return 1; 
                // МьВщЙІФмМќЖЈвхЖдееБэЃЌжиаТЖЈвхУќСю 
                if (!undefinedp(me["keymap"][me["sChar"]])) 
                        me["sChar"] = 
                        me["keymap"][me["sChar"]]; 
                if (!stringp(me["sChar"])) return 1; // Type checking... 
                // МьВщЪЧЪ§зжЕФЛАЃЌОЭЪЧИНМгЕНУќСюМЦЪ§Ря 
                if ('0'<=me["sChar"][0] && me["sChar"][0]<='9') 
                        me["sCount"] += me["sChar"]; 
                else 
                { 
                        sscanf(me["sCount"], "%d", count); 
                        me["sCount"] = ""; // МЦЪ§ЦїЙщСу 
                        // жиИВЩЯИіжИСю 
                        if (me["sChar"] == ".") 
                                me["sChar"] = me["sOldChar"]; 
                        else        // МЧТМетДЮЕФжИСю 
                                me["sOldChar"] = me["sChar"]; 
                } 
                for (i=0; i<count; i++) 
                        switch (me["sChar"]) // ЗжХЩжИСюЕНВЛЭЌКЏЪН 
                        { 
                        case "a":_append(pl);break; 
                        case "d": 
                        case "Ctrl-D": _del_line(pl);break; 
                        case "f": 
                        case "Ctrl-Z": _refresh(pl);break; 
                        case "g": 
                        case "Ctrl-G": _goto_line(pl);break; 
                        case "h": 
                        case "LEFT": 
                        case "Ctrl-J": _left(pl);break; 
                        case "i":      _insert(pl);break; 
                        case "j": 
                        case "DOWN": 
                        case "Ctrl-K": _down(pl);break; 
                        case "k": 
                        case "UP": 
                        case "Ctrl-O": _up(pl);break; 
                        case "l": 
                        case "RIGHT": 
                        case "Ctrl-L": _right(pl, 1, (me["is_Command_Mode"]?0:1));break; 
                        case "m": _keymap(pl);break; 
                        case "n": 
                        case "Ctrl-N": _next_match(pl);break; 
                        case "o": _append_line(pl);break; 
                        case "q":        // БэЪОВЛдйЖСШЁаТЪфШыЃЌНсЪјБрМ­ 
                        case "F4": 
                        case "Ctrl-Q": _quit(0, pl);return 0; 
                        case "r": 
                        case "Ctrl-R": _replace(pl);break; 
	                    case "s": 
                        case "Ctrl-S": _search(pl);break; 
                        case "u": _undef_key(pl);break; 
                        case "w": 
                        case "F2": 
                        case "Ctrl-W": _write(pl);break; 
                        case "x": 
                        case "DELETE": 
                        case "Ctrl-X":   _del_char(pl, 0);break; 
                        case "A": 
                        case "HOME": 
                        case "Ctrl-A":   _home(pl);break; 
                        case "B": 
                        case "PAGEUP": 
                        case "Ctrl-B":   _page_up(pl);break; 
                        case "E": 
                        case "END": 
                        case "Ctrl-E":   _end(pl);break; 
                        case "F": 
                        case "PAGEDOWN": 
                        case "Ctrl-F":   _page_down(pl);break; 
                        case "J": 
                        case "Ctrl-P": _join(pl);break; 
                        case "O": _insert_line(pl);break; 
                        case "U": 
                        case "Ctrl-U": _file_head(pl);break; 
                        case "V": 
                        case "Ctrl-V": _file_end(pl);break; 
                        case "?": 
                        case "F1": 
                        case "Ctrl-Y": _help(pl);break; 
                        case "~": 
                        case "Ctrl-T": _insert_exclam_mark(pl);break; 
                        case "BACKSPACE": _backspace(pl);break; 
                        case "ESC": _esc(pl);break; 
                        case "TAB": _tab(pl);break; 
                        } // switch 
        } // if me["is_Command_Mode"] 
        else 
                _process(pl);                // ДІРэЪфШыФЃЪНЕФзжДЎЪфШы 
        return 1;                        // БэЪОМЬајЖСШЁаТЪфШыЃЌМЬајБрМ­ 
} // dispatcher() 
private void _append(object pl)                // дкгЮБъссУцМгзж 
{ 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"]) == 0) return; 
        me["is_Command_Mode"] = 0; 
        _refresh_status(pl); 
        _right(pl, 1, 1); 
} // _append() 
private void _append_line(object pl)        // дкгЮБъЕзЯТМгвЛаТаа 
{ 
        string *text; 
        mapping me=pl->query_temp("me"); 
        me["is_Command_Mode"] = me["is_NewFile"] = 0; 
        me["is_Modify"] = 1; 
        text = me["sText"][0..me["iS_Row"]+me["iRow"]-2] + ({ "" }) + me["sText"][me["iS_Row"]+me["iRow"]-1..<1]; 
        me["sText"] = text; 
        _refresh_screen(pl, me["iS_Row"], sizeof(me["sText"]), 1); 
        me["iCol"] = 1; 
        _down(pl); 
} // _append_line() 
private void _backspace(object pl)        // ЩОГ§гЮБъЧАЕФзж 
{ 
        mapping me=pl->query_temp("me"); 
        if (me["iS_Col"] == me["iCol"])        return; 
        _left(pl); 
        _del_char(pl, 1); 
} // _backspace() 
protected void _confirm_save(string str, object pl) // РыПЊБрМ­ЦїЧАШЗШЯДцЕЕ 
{ 
        mapping me=pl->query_temp("me"); 
        if (str=="y" || str=="Y") return _write_done("", pl, 1); 
        me["is_Modify"] = 0;                // ЩшЖЈЁИЮДаоИФЁЙЦьБъ 
        _quit(0, pl); 
} // _confirm_save() 
private void _del_char(object pl, int bs)                // ЩОГ§гЮБъЩЯЕФзж 
{ 
        int    go_left=0;                // ЪЧЗёдкЩОГ§ссвЊзѓвЦгЮБъ 
        string str; 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"])==0 ||  sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])==0) 
             return; 
        if (me["is_NewFile"] || !me["is_Modify"]) 
        { 
                me["is_NewFile"] = 0; 
                me["is_Modify"] = 1; 
                _refresh_status(pl); 
        } 
        sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2]); 
                return; 
        str = me["sText"][me["iS_Row"]+me["iRow"]-2][0..me["iS_Col"]+me["iCol"]-3]; 
        // МьВщЪЧЗёашвЊИНМгЪЃЯТЕФФкШн 
        if (me["iS_Col"]+me["iCol"]-1 < sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])) 
                str += me["sText"][me["iS_Row"]+ 
                me["iRow"]-2][me["iS_Col"]+me["iCol"]-1..<1]; 
        else        go_left = 1;                // вђЮЊЪЧЩОГ§ааЮВЕФзжЃЌЫљвдвЊзѓ 
        me["sText"][me["iS_Row"]+me["iRow"]-2] = str; 
        printf(ESC "[%d;1f%-80s", me["iRow"]+1,        me["sText"][me["iS_Row"]+ 
                me["iRow"]-2][me["iS_Col"]-1..me["iE_Col"]-1]); 
        if (go_left && !bs) _left(pl); 
        else        _refresh_cursor(pl); 
} // _del_char() 
private void _del_line(object pl)        // ЩОГ§ећаа 
{ 
        string *text=({ }); 
        mapping me=pl->query_temp("me"); 
        me["is_NewFile"] = 0; 
        me["is_Modify"] = 1; 
        if (me["iS_Row"]+me["iRow"]-2 > 0) 
                text = me["sText"][0..me["iS_Row"]+me["iRow"]-3]; 
        text += me["sText"][me["iS_Row"]+me["iRow"]-1..<1]; 
        me["sText"] = text; 
        _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]); 
        if (me["iS_Row"]+me["iRow"]-1 > sizeof(me["sText"])) 
                _up(pl);                // ШєЪЧЩОГ§зюссвЛааЃЌОЭвЊЩЯвЦгЮБъ 
        // ШєгЮБъЕФаТЮЛжУГЌЙ§ааЮВЃЌдђвЦЖЏгЮБъЕНааЮВ 
        else if (me["iS_Col"]+me["iCol"]-1 > 
            sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])) 
            _end(pl); 
} // _del_line() 
private void _down(object pl)                // гЮБъЭљЯТвЦвЛаа 
{ 
        int  acc; 
        mapping me=pl->query_temp("me"); 
        // МьВщЪЧЗёвбдкЕЕЮВ 
        if (me["iS_Row"]+me["iRow"]-1 >= sizeof(me["sText"])) 
                // ШєвбЯдЪОЕЕЮВЯТвЛааЃЌдђВЛзіЪТ 
                if (me["iRow"] < 23) return; 
                else 
                {        // ЖрЯдЪгЕЕЮВЯТвЛааЃЌвдЭЛЯдЕЕЮВЕФДцдк 
                        me["iS_Row"]++; 
                        printf(ESC "[24;1f\r\n~"); 
                        me["iRow"] = 22; 
                } 
        else if (++me["iRow"] > 23) 
        {        // Л­УцЩЯОэЃЌЯдЪОЯТвЛаа 
                me["iS_Row"]++;                me["iE_Row"]++; 
                printf(ESC "[24;1f\r\n%s", me["sText"][me["iE_Row"]-1] 
                        [me["iS_Col"]-1..me["iE_Col"]-1]); 
                me["iRow"] = 23; 
        } 
        // ШєгЮБъЕФаТЮЛжУГЌЙ§ааЮВЃЌдђвЦЖЏгЮБъЕНааЮВ 
        if (me["iS_Col"]+me["iCol"]-1 > sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])) 
                me["iCol"] = sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])-me["iS_Col"]+(me["is_Command_Mode"]?1:2); 
        // ШєДЫааЮозжЃЌдђЖЈЮЛдкЕквЛРИ 
        if (me["iCol"] ==0 && me["iS_Col"] ==1) me["iCol"] = 1; 
        if (me["iCol"] > 0)
			_refresh_status(pl); 
        else 
        {        // гЮБъЕФаТЮЛжУдкд­Л­УцЭтЃЌашвЊжиЛцЛ­Уц 
                acc = me["iCol"];
				me["iCol"] = 1; 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]+acc-1); 
        } 
} // _down() 
private void _end(object pl)                // НЋгЮБъвЦЕНааЮВ 
{ 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"]) == 0) return; 
        // МЦЫуааЮВЕФЮЛжУ 
        me["iCol"] = sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])-me["iS_Col"]+(me["is_Command_Mode"]?1:2); 
        if (me["iCol"] == 0) me["iCol"] = 1; // ШєДЫааЮозжЃЌдђЖЈЮЛдкЕквЛРИ 
        if (sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2]) < me["iE_Col"]) 
                    _refresh_status(pl); 
        else 
        {        // гЮБъЕФаТЮЛжУдкд­Л­УцЭтЃЌашвЊжиЛцЛ­Уц 
                me["iCol"] = 79; 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], me["iS_Col"]+ 
                        (sizeof(me["sText"][me["iS_Row"]+me["iRow"]-2])- 
                        me["iE_Col"]+1)); 
        } 
} // _end() 
private void _esc(object pl)                // ДгЪфШыФЃЪНЛиЕНУќСюФЃЪН 
{ 
        mapping me=pl->query_temp("me"); 
        me["is_Command_Mode"] = 1; 
        _left(pl); 
} // _esc() 
private void _file_end(object pl)        // НЋгЮБъвЦЕНЕЕЮВ 
{ 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"]) == 0) return; 
        _goto_line_done(sprintf("%d", sizeof(me["sText"])), pl, 0); 
} // _file_end() 
private void _file_head(object pl)        // НЋгЮБъвЦЕНЕЕЭЗ 
{ 
        mapping me=pl->query_temp("me"); 
        if (sizeof(me["sText"]) == 0) return; 
        _goto_line_done("1", pl, 0); 
} // _file_head() 
private void _goto_line(object pl)        // ЬјЕНЬиЖЈааШЅ 
{ 
        mapping me=pl->query_temp("me"); 
        _message(pl, sprintf("ЧыЪфШыааКХЃЈжБНгАД ENTER ШЁЯћЃЌ1~%d)ЃК", 
                sizeof(me["sText"])), "_goto_line_done", ECHO, 1); 
} // _goto_line() 
protected void _goto_line_done(string str, object pl, int rein) // ШЁЕУааКХ 
{ 
        int no; 
        mapping me=pl->query_temp("me"); 
        if (str == "") return _message_done("", pl); 
        if (sscanf(str, "%d", no)!=1 || no<1 || no>sizeof(me["sText"])) 
                return _message(pl, "ДэЮѓЕФааКХЃЁ", "_message_done", HIDE); 
        me["iCol"] = 1; 
        if (me["iS_Row"]<=no && no<=me["iE_Row"]) 
        {        // жИЖЈааКХдкд­ПЩЪгЗЖЮЇжа 
                me["iRow"] = no-me["iS_Row"]+1; 
                _refresh_status(pl); 
        } 
        else 
        {        // жИЖЈааКХВЛдкд­ПЩЪгЗЖЮЇжаЃЌашвЊжиЛцЛ­Уц 
                me["iS_Row"] = no-11; 
                if (me["iS_Row"] < 1)        me["iS_Row"] = 1; 
                if (me["iE_Row"] < no+11)        me["iE_Row"] = no+11; 
                me["iRow"] = no-me["iS_Row"]+1; 
                _refresh_screen(pl, me["iS_Row"], me["iE_Row"], 1); 
        } 
        if (rein) get_char("_input", HIDE, pl); // МьВщЪЧЗёашвЊЖСШЁЯТДЮЪфШы 
} // _goto_line_done() 
