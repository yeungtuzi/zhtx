//by tlang for 混世神剑

#include <ansi.h>

inherit ROOM;

void init();
int do_open(string arg);
int valid_leave(object ob,string dir);
int close_door();


void create()
{
	set("short", MAG"奇异世界"NOR);
	set("long", "这儿到处是好东东。左边有一道开着的门，右边也有一道门。\n");

	set("exits",([
	"west" : "/d/xueshan/foot",
	]));
	    
    	setup();
}

void init()
{
    add_action("do_open", "open");
}

int do_open(string arg)
{
	object room,ob;

	ob=this_player();
	
	if (!arg || ( arg != "east" && arg!="e"))
        	return notify_fail("你要开什么？\n");
	if (query("exits/east") )
		return notify_fail("东边的门已经是开着的了。\n");
    	if( !ob->query("my_hunter") )
		return notify_fail("贪图小利的人，也配拿神剑？！\n");
       	if(!( room = find_object(__DIR__"myhell")) )
       	room = load_object(__DIR__"myhell");
       	if(objectp(room))
       	{
	       	set("exits/east", __DIR__"myhell");
        	message_vision("$N轻轻地把东边的门一推，只听吱地一声，门开了。\n");
        	room->set("exits/west", __FILE__);
        	message("vision", "外面有人把门推开了。\n", room);
       		remove_call_out("close_door"); 
		call_out("close_door", 5);
	}

	return 1;
}

int valid_leave(object ob, string dir)
{
	if( !ob->query("my_hunter")  && dir=="east" )
		return notify_fail("你觉得有一种神秘的力量让你寸步难行。\n");
	return ::valid_leave(ob,dir);
}

int close_door()
{
 	object room;

	if(!( room = find_object(__DIR__"myhell")) )
        room = load_object(__DIR__"myhell");
    	if(objectp(room))
    	{
		delete("exits/east");
	       	message("vision", "门突然自动掩上了。\n",this_object());
		room->delete("exits/west");
		message("vision", "门突然自动掩上了。\n",room);
        }
    	else message("vision", "ERROR: door not found(close).\n", room);

     		return 1;
}


