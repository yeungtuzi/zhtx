void create()
{
	set_name("渡肉长老", ({
		"durou zhanglao",
		"durou",
		"zhanglao",
		"meat",
	}));
	set("long",
		"他是一位白须白眉的老僧，身穿一袭金丝绣红袈裟。\n"
		"他身材略显佝偻，但却满面红光，目蕴慈笑，显得神完气足。\n"
	);

	set("no_get",1);
	set("nickname", CYN "少林寺" NOR + RED "方丈" NOR);
        set("title", HIR "少林" NOR + MAG "神僧" NOR);
	set("gender", "男性");
	set("attitude", "friendly");
