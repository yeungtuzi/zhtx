// b_header.c

inherit NPC;
inherit F_MASTER;

void create()
{
        set_name("秦振天", ({ "master spearman", "spearman", "master" }) );
        set("nickname", "霸王枪");
        set("gender", "男性" );
        set("age", 37);
        set("str", 32);
        set("cor", 27);
        set("cps", 26);
        set("int", 22);

        set("max_force", 1000);
        set("force", 1000);
        set("force_factor", 30);

        set("rank_info/respect", "秦镖头");

        set("long",@LONG
    秦振天是陈剑秋的八拜兄弟，他和陈剑秋一起创建了振远镖局
他一手五虎断门枪法据说出神入化。
LONG);

        create_family("振远镖局", 1, "镖头");

        set("combat_exp", 1000000);
        set("score", 20000);
	set("shen_type",1);

//        set("chat_chance_combat", 60);
//        set("chat_msg_combat", ({
//                (: perform_action, "sword.counterattack" :)
//        }) );

        set_skill("cuff", 90);
        set_skill("parry", 160);
        set_skill("dodge", 160);
        set_skill("spear", 200);
        set_skill("force", 20);
        set_skill("literate", 50);
	set_skill("five-tiger-spear",160);
	map_skill("spear","five-tiger-spear");


        set("inquiry", ([
                "name": "在下姓秦，人称霸王枪",
                "霸王枪": "江湖上的弟兄看得起在下就这么叫开了，实在是惭愧。",
        ]) );

        setup();
//        carry_object("/d/cloud/obj/npc/b_header2/champion_spear")->wield();
}

void attempt_apprentice(object ob)
{
        if( ((int)ob->query("str") < 25) ){ 
                command("say 学枪法要力大臂稳" + 
RANK_D->query_respect(ob) + "似乎不适合学这种功夫？");
                return;
        }
        command("smile");
        command("say 很好，" + RANK_D->query_respect(ob) + 
"多加努力，本镖局不会亏待你的。\n");
        command("recruit " + ob->query("id") );
}

void recruit_apprentice(object ob)
{
        if( ::recruit_apprentice(ob) )
                ob->set("class", "guardman");
}
 
