                } 
     if ( (int)me->query_skill("fuliu-jian",1) > 199 && random(5) > 3)
                {
                        message_vision(HIC"\n$N试着摸索着箱子的缝隙，突然间....\n"NOR,me);
                        message_vision(HIG"$N有一种如此熟悉亲切的感觉，难以名状,\n"NOR,me);
                        message_vision(HIW"只见天地间一道雳闪，一件神物飞入了你的手中！\n"NOR,me);
                        message_vision(HIY"$N心中一阵狂喜，原来这正是本派世代相传的神兵——小楼一夜听春雨！\n"NOR,me);
                        weapon8->move(me);
                        weapon8->set("owner", me);
                        delete("haveweapon");
                        return 1;
                }
     if ( (int)me->query_skill("snowwhip",1) > 199 && random(5) > 3)
                {
                        message_vision(HIC"\n$N试着摸索着箱子的缝隙，突然间....\n"NOR,me); 
                        message_vision(HIG"$N有一种如此熟悉亲切的感觉，难以名状,\n"NOR,me);
                        message_vision(HIW"只见天地间一道雳闪，一件神物飞入了你的手中！\n"NOR,me);
                        message_vision(HIY"$N心中一阵狂喜，原来这正是本派世代相传的神兵——魔鞭翩珑！\n"NOR,me);
                        weapon9->move(me);
                        weapon9->set("owner", me);
                        delete("haveweapon");
                        return 1;
                }
     if ( (int)me->query_skill("taiji-jian",1) > 199 && random(5) > 3)
                {
                       message_vision(HIC"\n$N试着摸索着箱子的缝隙，突然间....\n"NOR,me);
                       message_vision(HIG"$N有一种如此熟悉亲切的感觉，难以名状,\n"NOR,me);
                       message_vision(HIW"只见天地间一道雳闪，一件神物飞入了你的手中！\n"NOR,me);
                       message_vision(HIY"$N心中一阵狂喜，原来这正是本派世代相传的神兵——真武剑！\n"NOR,me);
                       weapon0->move(me);
                       weapon0->set("owner", me);
                       delete("haveweapon");
                       return 1;
               }
  message_vision(YEL"\n$N在箱子里摸索了半天，一无所获，只好悻悻而返....\n"NOR,me); 
  message_vision(YEL"\n$N想起纵横大半生，至今仍一无所获，不由得意兴索然....\n"NOR,me); 
  delete("haveweapon");
  me->add("combat_exp", -10000);
  return 1;
       }
    }else{ 
      message_vision(HIW"\n箱子里突然崩出个鬼森森的骷髅头，$N大骇之下，只觉得气血不畅，眼前一黑...\n"NOR,me);
      me->die();
    }
  write("箱子里空无一物，什么都没有。\n");  
  return 1;
}

