// trigger.c
// update by dongsw add offline 2002.8

#include <ansi.h>
#define OFFLINE_QUIT_TIME 10
inherit F_CLEAN_UP;

void set_dazuo_trigger(object me);
int main(object me, string arg)
{
        int i,time;
        mapping trigger;
        mapping offline;
        mixed times;
        string verb, replace, *vrbs,cname;

        if( !arg ) {
                trigger = me->query_all_trigger();
                offline = me->query_all_offline();
                
                if( !sizeof(trigger) || !sizeof(offline)) {
                        write("你目前并没有设定任何 trigger。\n");
                        me->disable_trigger();
                } else  {
                        i = me->query_trigger_enabled();
                        me->disable_trigger();
                        write("你目前设定的 trigger 有：\n");
                        vrbs = keys(trigger);
                        times = values(offline);
                        for(i=0; i<sizeof(vrbs); i++)
                        write(sprintf("当出现“%-40s”语句时 延迟 %-2d秒 将触发如下命令：%s\n", vrbs[i]+NOR, times[i], trigger[vrbs[i]]));
                        write("\n你的触发器状态是"+(i?HIG"打开":HIG"关闭")+"。\n"NOR);
                        if( i ) me->enable_trigger();
                }
                return 1;
        }
        if( arg=="clear" )
        {
                me->delete_all_trigger();
                write("清楚所有trigger触发。\n");
                return 1;
        }
        if( arg=="on" )
        {
                me->enable_trigger();
                write("打开trigger触发。\n");
                return 1;
        }
        if( arg=="off" )
        {
                me->disable_trigger();
                write("关闭trigger触发。\n");
                me->delete_temp("offline");
                return 1;
        }
        if( arg=="dazuo" )
        {
                me->delete_all_trigger();
                set_dazuo_trigger(me);
                write("正循环打坐触发器设置完毕，请trigger offline后用dazuo 20指令触发。\n");
                return 1;
        }
                cname = arg;
                cname = replace_string(cname, "$BLK$", BLK);
                cname = replace_string(cname, "$RED$", RED);
                cname = replace_string(cname, "$GRN$", GRN);
                cname = replace_string(cname, "$YEL$", YEL);
                cname = replace_string(cname, "$BLU$", BLU);
                cname = replace_string(cname, "$MAG$", MAG);
                cname = replace_string(cname, "$CYN$", CYN);
                cname = replace_string(cname, "$WHT$", WHT);
                cname = replace_string(cname, "$HIR$", HIR);
                cname = replace_string(cname, "$HIG$", HIG);
                cname = replace_string(cname, "$HIY$", HIY);
                cname = replace_string(cname, "$HIB$", HIB);
                cname = replace_string(cname, "$HIM$", HIM);
                cname = replace_string(cname, "$HIC$", HIC);
                cname = replace_string(cname, "$HIW$", HIW);
                cname = replace_string(cname, "$NOR$", NOR);         
                arg = cname;

        if( arg == "offline" )
        {
                if ( me->query_temp("offline"))
                {
                        tell_object(me,"您已经开启了离线修炼状态，如果您想关闭这种状态请输入 trigger off\n");
                        return 1;
                }
                if (! environment(me)) return notify_fail("你无法做任何事情。\n");
                //if (! environment(me)->query("no_fight"))
                  //      return notify_fail("你必须在没有危险的地方才能开始离线修炼。\n");
                if (me->query("combat_exp") < 600000)
                        return notify_fail("你的战斗经验不足，无法接受控制。\n");
                if (sizeof(filter_array(all_inventory(environment(me)), (: userp :))) > 12)
                        return notify_fail("这里的人太多了，你无法静心修炼。\n");
                       
                tell_object(me,"请在安全地点修炼，否则如果玩家死亡将不会得到复档！\n"
                               "您要开始离线修炼吗？[Y/N]\n");
                input_to("start_offline",me,arg);
                return 1;
        }
        else if( sscanf(arg, "%s %d %s", verb, time, replace )!=3 )
                me->set_trigger(arg, 0,1);
        else if( verb == "trigger" )
                return notify_fail("你不能将 \"trigger\" 指令设定为 pattern 。\n");
        else if( verb == "" )           
                return notify_fail("你要设什麽 trigger？\n");

        else if( strsrch(verb,"(")!=-1 || strsrch(verb,")")!=-1 || strsrch(verb,"\"")!=-1 )
                return notify_fail("你不能使用(,),*,\"等特殊字符来做trigger.\n");  
        else
        {
                return me->set_trigger(verb, replace, time);
        }

        write("Ok.\n");
        return 1;
}

void force_quit( object me ) { me->force_me("quit"); }

private void start_offline(string arg, object me)
{
        if( arg[0]=='y' || arg[0]=='Y' )
        {
                tell_object(me,HIR"您已经开启了离线修炼状态，请您尽快触发首语句，"
                               "\n您的人物将会在"
                               +
                               chinese_number(OFFLINE_QUIT_TIME)
                               +
                               "秒钟后自动退出游戏。\n"NOR);
                me->enable_trigger();
                me->set_temp("offline",1);
                me->start_call_out((: call_other, __FILE__, "force_quit", me :), OFFLINE_QUIT_TIME);
        }
        else 
        {
                tell_object(me,"\n请您继续游戏吧。\n");
        }
        
}
void set_dazuo_trigger(object me)
{
        string arg;
        arg = "你行功完毕，深深地吸了口气，站了起来。";
        me->set_trigger(arg,"exert recover",1);
        arg = "你深深吸了几口气，脸色看起来好多了。";
        me->set_trigger(arg,"dazuo 20",0);
}



int help (object me)
{
        write(@HELP
指令格式 : trigger <触发信息> <触发后欲执行之命令>
 
当你从系统接收到<触发信息>的时候,可以让系统自动执行一个
或者一系列预先定义好的指令(可以是你定义的alias).
 
例如:

      请help offline里面有详尽的介绍。
      
      by YEUNG 1999/07/25.
      update by dongsw 2002/8/14.
HELP
);
        return 1;
}

