$HIG$━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━$NOR$

 $HIY$immortal$NOR$     $HIW$<anything>$NOR$
 
 设定自己成为不死之身，当状态达到昏迷或死亡时数值会停在 -1。

 $HIY$invisibility$NOR$ $HIW$<number>$NOR$
 
 设定隐形的程度。 0 - 10

 $HIY$msg_home$NOR$     $HIW$<anything>$NOR$
 
 设定当自己打 home 回家时显示的讯息。

 $HIY$msg_min$NOR$      $HIW$<anything>$NOR$
 
 设定当使用 goto 到达某处时, 别人所看到的讯息。

 $HIY$msg_mout$NOR$     $HIW$<anything>$NOR$
 
 设定当使用 goto 离开时, 原来房间里的人所看到的讯息。

 $HIY$msg_clone$NOR$    $HIW$<anything>$NOR$
 
 设定当 clone NPC 或 OBJ 时所显示的讯息。
 $n 表示你所 clone 的物件的名字。

 $HIY$msg_dest$NOR$     $HIW$<anything>$NOR$
 
 设定当 dest NPC 或 OBJ 时所显示的讯息。
 但如果该 OBJ 是存在於自己身上时则不会有讯息。

 $HIY$combat verbose $NOR$
 
 设定战斗中是否要显示数字方面的资料。
 
 $HIY$trace_error$NOR$   $HIW$<yes/no>$NOR$
 
 显示 trace error

