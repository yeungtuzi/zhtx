int check_version(object user) {
        mapping allskill;
        string family_name;
        string* skills;
        string classdir;
        int i,tmp;
	int all_pot=0;
	int forcelvl,mud_age;

        allskill = user->query_skills();
  if(allskill) {
        skills=keys(allskill);
        family_name = user->query("family/family_name");
        classdir = family_class[family_name];
//	tell_object(user,"\n\n\n\n\n\n\n\n\n\n请注意，以下的skills除去，如果有什么不对请在平衡前和巫师联系。\n");
        tell_object(user,"Your family: " + family_name + "("+classdir+")\n");
        tell_object(user,"以下skill不属于你的门派,将被删掉!\n");
        for(i=0;i<sizeof(skills);i++) {
                all_pot += check_skill_v1(user,skills[i],allskill[skills[i]],classdir);
        }
	if( all_pot > 1000000) all_pot = 1000000;
	if(all_pot) tell_object(user,sprintf("total %d exp will be add. \n",all_pot));
      }
	mud_age = user->query("mud_age")/86400;
	tmp = mud_age+1;
	i = user->query("faith");	
	if( i > 1500 || tmp*68 > i) {
		user->set("faith",0);
		user->add("faith",tmp*68);
	}
	tmp = user->query("betrayer");
	if(tmp = 0) user->add("faith",400);
	
	tell_object(user,"Total "+user->query("faith")+"点师门忠诚度 ");
	
	forcelvl =  user->query("max_force");
	if (forcelvl > 1800 ) {
		i = forcelvl-1800;
		tell_object(user, "max force will be set to 1800\n");
		user->set("max_force",1800);
		i = i/200;
		if( mud_age -i > 4) { 
			printf("your age will be set to %d\n",mud_age-i+14);
			user->set("mud_age",(mud_age-i)*86400+1);
		}
		else {
			printf("your age will be set to 18\n",mud_age-i);
			user->set("mud_age",4*86400+1);
		}

	}
	user->add("combat_exp",all_pot);
	user->set("ZH_player_version",11);
	user->set("betrayer",0);
	
	allskill= user->query_skill_map();
	if(allskill) {
		skills=keys(allskill);
		for(i=0;i<sizeof(skills);i++) 
		  user->map_skill(skills[i]);
	}	
	tell_object("你已经升级为 纵横天下--I 的一员！Welcome!\n");
        user->save();
	return 0;
}

