private void get_passwd(string pass, object ob)
{
	string my_pass;
	object user;
	string ip;

	write("\n");
	my_pass = ob->query("password");
	if( crypt(pass, my_pass) != my_pass ) {
		write("密码错误！\n");
		destruct(ob);
		return;
	}

	// Check if we are already playing.
	user = find_body(ob->query("id"));
	if (user) {
		if( user->query_temp("netdead") ) {
			reconnect(ob, user);
			return;
		}
		write("您要将另一个连线中的相同人物赶出去，取而代之吗？(y/n)");
		input_to("confirm_relogin", ob, user);
		return;
	}

	if( objectp(user = make_body(ob)) ) {
		if( user->restore() ) {
			log_file( "USAGE", sprintf("%s logged in from %s (%s)\n", (string)user->query("id"),
				query_ip_name(ob), ctime(time()) ) );
			ip = query_ip_name(ob);
        reset_eval_cost(); //这个用来防止too long execution error...

			enter_world(ob, user);
                if(user && wiz_level(user))
                        log_file( "WIZUSAGE", sprintf("%s logged in from %s (%s)\n", (string)user->query("id"),
                                ip, ctime(time()) ) );

                        write("上次登录:  "+ ob->query("last_from")+"("+ctime(ob->query("last_on"))+") 确定：");
			input_to("confirm_last");

			return;
		} else {
			destruct(user);
		}
	}
	write("您的人物储存挡出了一些问题,请通知巫师处理。\n");
	destruct( ob);
    
}

