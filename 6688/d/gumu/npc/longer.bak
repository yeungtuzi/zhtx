// longer.c 小龙女
#include <ansi.h>
inherit NPC;
inherit F_MASTER;
inherit F_QUEST;
inherit "/feature/challenge";

string ask_me();
string ask3();
string ask2();

void create()
{
         set_name("小龙女", ({ "xiao longnv","longnv","xiao"}));
        set("title",HIR "古墓派" NOR + MAG "传人" NOR);
        set("long",
                "她就是古墓派第三代传人小龙女，容颜极美，只是\n"
                "脸上冷冰冰的从来不露喜怒哀乐之色。\n");
        set("gender", "女性");
        set("age", 22);
        set("attitude", "peaceful");
        set("shen_type", 1);
        set("str", 18);
        set("int", 80);
        set("cor", 30);
        set("dex", 50);
        set("per", 50);
        set("cps", 50);
        set("max_kee", 8000);
        set("max_gin", 4000);
        set("max_sen", 4000);                
        set("force", 8000);
        set("max_force", 4000);
        set("force_factor", 250);
        set("combat_exp", 8000000);
        set("score", 800000);
 	set("book_count", 1);         
 	set("rank_info","龙儿");
        set_skill("perception",150);
        set_skill("music",150);
        set_skill("xiantian-gong",100);
        set_skill("quanzhen-jian",100);
        set_skill("taoism",150);
	set_skill("force", 200);
        set_skill("yunu-xinfa", 200);
	set_skill("cuff", 180);
	set_skill("meinu-quan", 200);
        set_skill("dodge", 200);
        set_skill("xianyun", 200);
        set_skill("parry", 180);
        set_skill("whip", 180);
        set_skill("xiangmei-bian", 200);
	set_skill("throwing",180);
	set_skill("zhinv-zhen",200);
        set_skill("literate", 200);
	set_skill("yunu-jianfa",200);
        set_skill("sword",180);

        map_skill("force", "yunu-xinfa");
	map_skill("cuff", "meinu-quan");
        map_skill("dodge", "xianyun");
	map_skill("sword","yunu-jianfa");
        map_skill("parry", "xiangmei-bian");
        map_skill("whip", "xiangmei-bian");
	map_skill("throwing","zhinv-zhen");

	prepare_skill("cuff", "meinu-quan");
	
        set("chat_chance", 100);
	 set("inquiry", ([
//                "淑女剑" : (: ask_me :),
//		"机关"   : (: ask3 :),
//		"左右互搏": (: ask2 :),
		"出墓": "祖师遗命，凡我古墓弟子都不得擅自出去行走江湖，除非，有一个男子肯为你舍弃自己性命。",
        ]) );
      
        create_family("古墓派" , 3, "传人");
        setup();
        carry_object("/d/gumu/obj/lingsuo")->wield();
        carry_object("/d/gumu/obj/white")->wear();
        carry_object("/d/gumu/obj/shoutao")->wear();
        set_temp("apply/dodge",200);
        set_temp("apply/armor_vs_force",500);
}
void attempt_apprentice(object ob)
{
	if((string)ob->query("family/family_name")!="古墓派")
		{
		 command("say " + RANK_D->query_respect(ob) + "若想拜我派需要从入门弟子做起。"); 
                return;
        	}

	if( ob->query("gender")!="女性" || ob->query("husband") || ob->query("marry_betrayer") )
	{
		command("say 师祖传下遗命，我派只能收冰清玉洁的女儿家。");
		command("shake");
		command("say 除非...除非...");
		say("小龙女欲言又止。\n");
		return;
	}	

	 if ((int)ob->query_skill("yunu-xinfa",1) < 50)
		 {
		 command("say " + RANK_D->query_respect(ob) + "玉女心法太低，再回去好好努力吧。"); 
                return;
        	}
	if ( (int)ob->query_dex()<25 && (int)ob->query_skill("dodge",1)<100 )
		{
		command("say" + "我古墓派的功夫以轻灵为主，" + RANK_D->query_respect(ob) + "似乎不太合适。");
        	return;
		}
	else
          {
        command("say 好吧，"+RANK_D->query_respect(ob)+"，我就收下你了！");
        command("recruit "+ob->query("id"));
           }
       
}
void recruit_apprentice(object ob)
{
        if( ::recruit_apprentice(ob) )
	      { 
               	ob->set("title",GRN "古墓派" NOR + MAG +"圣女" NOR);
                return;
              }

}
void re_rank(object student)
{
                	student->set("title",GRN "古墓派" NOR + MAG +"圣女" NOR);             
}

string ask_me()
{
        mapping fam;
        object ob;
	object me=this_player();
            if (!(fam = this_player()->query("family"))
            || fam["family_name"] != "古墓派")
             return RANK_D->query_respect(this_player()) +
                "与本派素无来往，不知此话从何谈起？";
        if((int)me->query_skill("yunu-jianfa",1)<80)
        return "你的玉女剑法太底，要了淑女剑也发挥不出它的威力。";
        if((int)me->query("faith") < 500 )
        return "你心志未坚，我现在还不能给你。\n";
        if (query("book_count") < 1)
                return "你来晚了，本派的淑女剑不在此处。";
        add("book_count", -1);
        ob = new("/d/gumu/obj/sword1");
        ob->move(this_player());
        return "好吧，这把淑女剑你拿回去好好保管。";
}

string ask3()
{	mapping fam;
	object me=this_player();
	if (!(fam = this_player()->query("family")) || fam["family_name"] != "古墓派" )
                return RANK_D->query_respect(this_player()) +
                "与本派素无来往，不知此话从何谈起？";
	if (me->query("score")<500)
		return "墓洞可是我古墓派的重地，不是一般人能进去的。\n";
	else 
		{me->set("jiguan",1);
		return "好吧，我就把机关的秘密告诉你吧，你好自为之。\n";
	}
}
string ask2()
{mapping fam;
	object me=this_player();
	if (!(fam = this_player()->query("family")) || fam["family_name"] != "古墓派" )
                return RANK_D->query_respect(this_player()) +
                "与本派素无来往，不知此话从何谈起？";
	else
	{
	message_vision("小龙女说道：“好吧，我就教你双手互搏吧。”\n",me);
	if (me->query_skill("yunu-xinfa",1)<80 || me->query_int() > 20)               
	{ message_vision("$N练了半天，还是没练会。”\n",me);
               
	return "也许是你玉女心法不够，静不下心来练吧。\n";}
	if (me->query("combat_exp")>150000)
	{message_vision("$N练了半天，还是没练会。”\n",me);
	return "也许是你经验太高，不习惯于左右互搏吧。\n";}
	message_vision("$N练了半天，学会了左右互搏之技。\n",me);
	me->set("hubo",1);
	me->set("suxin",1);
	return "记住，不要用我教你的来作恶，不然我决不轻饶。\n";
	}
}		

void init()
{
        ::init();
        add_action("give_quest","quest");
}	


int valid_bribe(object who,int val) {
	message_vision( (this_object())->query("name")+"向$N一甩袍袖，说道： 什么，你想贿赂我吗？！\n",who);
	return(0);
}


// called when not finish the task
int quest_punish(object who) {
	message_vision( (this_object())->query("name")+"向$N一甩袍袖，说道： 真笨，你好好学学功夫再要任务吧！\n" ,who);
    who->set("quest",0);
    return(0);
}
