void reset()
{
	delete("memory");
}
	
void init()
{       
	object ob;
	ob = this_player();
	::init();
	if (userp(ob))
	if(random(10)>3)
	add_action("do_whisper","whisper");
	add_action("do_sing", "sing");
	add_action("do_answer","answer");
	remove_call_out("greeting");
	call_out("greeting", 1, ob);
	command("prepare taiji-quan");
}

void greeting(object ob)
{
	if( !ob || environment(ob) != environment() ) return;
	if(!userp(ob)) return;
	if(wizardp(ob)) ob->set("env/invisibility",0);
        wiz_status=SECURITY_D->get_status(ob);
	message_vision(	"$N对$n嫣然一笑.\n\n",this_object(),ob );
	if(ob->query("id")=="ture")
	{
	  command("say 噢，"+ob->query("name")+"公子回来了。");
	}
	else if(ob->query("id")=="yeung")
	{	
		say(CYN"夜莺说道:大功告成!\n"NOR);
                command("jump yeung");
		return;
	}
	else if(ob->query("id")=="jenny")
	{	
                command("touch jenny");
                command("sister jenny");
		return;
	}

       else if(wiz_status == "(admin)")
        {       command("bow");
		say(HIG"夜莺说道：这位这位天神老爷请了!\n"NOR);
                command("sister" + ob->query("id"));
		return;
	}

	else
	{
	command("say 这位" + RANK_D->query_respect(ob)
	+ "，你好啊?\n");
	if (ob->query("gender") == "男性"||ob->query("gender") == "无性")
	{
	command("say "+"这位" + RANK_D->query_respect(ob)+"，欢迎你有空来坐坐。");
	command("xixi");
	}
	else
		{
		command("say 总是有男子来惹我恼我，不想今日却来了一位" + RANK_D->query_respect(ob)+"\n");
		}
	}
}

void die()
{
	object ob;
        if( objectp(ob = query_temp("last_damage_from")) )
	{
		command("chat " + HIR + ob->query("name") + "你这" + RANK_D->query_rude(ob) + "，我做鬼也不会放过你！！！\n"NOR);
        	message_vision(HIR"夜莺在倒地身亡的瞬间对$N种下了深重的诅咒！\n"NOR,ob);
        	tell_object(ob,HIR"你死定了！"NOR);
        	ob->set("PK_point",ob->query("PK_point")+10000);
	}
	::die();
}


void defeated_enemy(object victim)
{
	command("nomatch");
}
void destroying(object me, object obj)
{
        destruct(obj);
        return;
}
int accept_fight(object who)
{
	message_vision("\n$N摇了摇头，对$n幽幽叹道：唉，你这又是何苦呢?\n",this_object(),who);
	command("nomatch "+who->query("id"));
}

string ask_mother()
{
	command( "sigh");
	command("cry miss");
	return("咦，你也知道她呀，她原来是纵横天下的玩家，可是后来被迫\n自杀了，她就是我的前身啊....\n");
}

string ask_zhh()
{
	command( "sigh");
	return("她是以前剑神一笑的爱妻。本来一直过着幸福快乐的生活，后来\n因无法忍受师门之变的重大打击，愤然辞世。自从她去世之后，剑神一笑\n也性情大变，成了一个大魔头。从此江湖上就多了许许多多的是是非非，\n风风雨雨......");
}

string ask_hou()
{
	object ob;
	ob = this_player();
	if( ob->query("marks/yeying") )
	{
		command("angry");
		return("我不是已经告诉你了吗？好讨厌！");
	}
	if( ob->query("kar") > 5 )
		return("你问这个干什么呢？\n");
	else
	{
