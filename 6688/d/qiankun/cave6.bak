                        weapon5->move(me);
                        weapon5->set("owner", me);
                        delete("haveweapon");
                        return 1;
                }
     if ( (int)me->query_skill("shenghuo-shengong",1) >199 && random(5) > 3 )
                {
                        message_vision(HIC"\n$N试着摸索着箱子的缝隙，突然间....\n"NOR,me);
                        message_vision(HIG"$N有一种如此熟悉亲切的感觉，难以名状,\n"NOR,me);
                        message_vision(HIW"只见天地间一道雳闪，一件神物飞入了你的手中！\n"NOR,me);
                        message_vision(HIY"$N心中一阵狂喜，原来这正是本派世代相传的神兵——圣火令！\n"NOR,me);
                        weapon6->move(me);
