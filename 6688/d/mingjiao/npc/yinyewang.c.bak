#include <ansi.h>

inherit NPC;

void create()
{
    set_name("殷野王", ({ "yin yewang", "yin", "yewang", }));
	set("long",
        "他是一位手摇折扇的中年男子，身穿一件白布长袍。\n"
        "他是白眉鹰王殷天正之子。一双眼睛犹如冷电，精光四射，气势摄人。\n"
	);


    	set("nickname", "一飞冲天");
	set("gender", "男性");
	set("attitude", "friendly");
	

    	set("age", 44);
	set("shen_type", 1);
	set("str", 25);
	set("int", 25);
	set("con", 25);
	set("dex", 25);
	set("max_kee", 1000);
	set("max_gin", 1000);
	set("force", 1000);
	set("max_force", 1000);
	set("force_factor", 100);
	set("combat_exp", 1000000);
	set("score", 5000);

	set_skill("force", 120);
	set_skill("dodge", 120);
	set_skill("unarmed", 125);
	set_skill("parry", 120);
	set_skill("claw", 125);
	set_skill("literate", 60);
	set_skill("sougu", 120);
	set_skill("taxue-wuhen",120);
	set_skill("moni-xinfa",120);

	map_skill("force", "moni-xinfa");
	map_skill("dodge", "taxue-wuhen");
	map_skill("claw", "sougu");
	map_skill("parry", "sougu");
	set_temp("apply/attack",50);
	set_temp("apply/defense",50);
	set_temp("apply/damage",200);
	set_temp("apply/armor_vs_force",500);

	prepare_skill("claw", "sougu");


	set("chat_chance_combat", 20);
	set("chat_msg_combat", ({
		(: command("perform muyeyingyang") :),
		(: command("exert yihun") :),
	}) );

    	set("title","明教""天微堂堂主");

	setup();

    	//carry_object(__DIR__"obj/baipao")->wear();
    	carry_object(__DIR__"obj/zhanpao1")->wear();
}

