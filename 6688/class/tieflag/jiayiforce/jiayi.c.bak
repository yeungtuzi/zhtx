// jiayi.c
//written by kouga
//puke，14岁就可以有2700内力，简直是BT
//修改，修改，现在只能jiayi到瓶颈+50。
//modified By Emote.12/02/99
#include <ansi.h>

int exert(object me, object target, int amount)
{       
	int skill,force,add_force,max_force;  
	
	if( wizardp(me) )
		return notify_fail("巫师不可以使用嫁衣神功。\n");
	max_force = (int)target->query_skill("force",1)*10+(int)target->query_skill("force")*2+50;
	add_force = 200;
	skill = me->query_skill("jiayiforce",1);  
	if(skill < 105) return notify_fail("你的嫁衣神功太差了，不能为人作嫁！\n"); 
	if( !target || target == me)  return notify_fail("你要对谁使用嫁衣神功？\n" );
        if( me->is_fighting() || target->is_fighting())
                return notify_fail("战斗中无法使用嫁衣神功！\n");
	if((int)me->query("max_force") < 400)
                return notify_fail("你的内力不够强。\n");
	if((int)target->query("max_force")>2500
	|| (int)target->query("max_force")>max_force-200)
		return notify_fail(target->name()+"的内力修为已经很强了，只怕难以接受你的真气。\n");
	if((int)me->query("max_force") <= (int)target->query("max_force"))	
		return notify_fail("你的内力还没有"+target->name()+"的强，不能为其作嫁！\n"); 
	
	log_file("JIAYI",sprintf("%s(%s) transfers force to %s(%s) on %s\n",
               me->name(1), geteuid(me), target->name(1), geteuid(target),ctime(time()) ) );


        message_vision(
                HIY "$N坐了下来运起内功，将手掌贴在$n背心，缓缓地将真气输入$n体内....\n\n"
                "过了不久，$n浑身泛起红光，$N却昏倒在地。\n" NOR,
                me, target );
	me->set_skill("jiayiforce",1);
	me->add("max_force",-400);
	if(add_force>max_force-(int)target->query("max_force"))
	add_force = max_force-target->query("max_force");
	me->set("force",0);
	if(add_force<0)
		add_force = 0;
	if(add_force)
		target->add("max_force",add_force);
	else 
		target->set("max_force",max_force);
	target->set("force",target->query("max_force"));
	me->unconcious();
        return 1;
}

